        my $free_space_advice_for_grid = $du_grid_home * 2.5;
        my $target_grid_home_parent_dir = get_parent_dir_path($target_grid_home);
        if ( !-e $target_grid_home_parent_dir ) {
            $cmd = "mkdir -p $target_grid_home_parent_dir";
            notify("    cmd is $cmd",'A');
            system("$cmd");

            $cmd = "chown -R $grid_user:$group_for_oinstall $target_grid_home_parent_dir";
            notify("    cmd is $cmd",'A');
            system("$cmd");
        }

        if ( !-e $target_grid_home ) {
            $cmd = "mkdir -p $target_grid_home";
            notify("    cmd is $cmd",'A');
            system("$cmd");

            $cmd = "chown -R $grid_user:$group_for_oinstall $target_grid_home";
            notify("    cmd is $cmd",'A');
            system("$cmd");
        }

        my $free_space_for_grid = get_free_space ( $target_grid_home_parent_dir );
