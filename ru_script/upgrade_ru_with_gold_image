sub get_listener_log_by_process {
    my ($input) = @_;
    notify("    get_listener_log_by_process");

    # 根据 tnslsnr 列表来执行lsnrctl status 命令，取得日志文件的位置
    my @listener_log;
    my @copy_file;
    my @cmd = `ps -ef|grep tnslsnr|grep -v grep`;
    notify("        no listener process running") if not defined $cmd[0];
    my $old_env_oracle_home = $ENV{ORACLE_HOME};
    foreach my $line ( @cmd ) {
        ### $line
        chomp $line;
        my @tmp = split/\s+/, $line;
        my ($oracle_home) = $tmp[7] =~ m/^(.+?)\/bin\/tnslsnr/;
        my $lsnrctl = catfile($oracle_home,"bin/lsnrctl");
        my $listener_name = $tmp[8];
        notify("        listener_name: $listener_name");
        $ENV{ORACLE_HOME} = $oracle_home;
        my @result1 = `$lsnrctl status $listener_name`;
        next if not defined $result1[0];
        foreach my $line1 ( @result1 ) {
            if ( $line1 =~ m/^Listener Parameter File/ ) {
                my $parameter_file = (split /\s+/, $line1)[-1];
                notify("        parameter_file: $parameter_file");
                push @copy_file, $parameter_file;
            }
            elsif ( $line1 =~ m/^Listener Log File/ ) {
                my $log_file = (split /\s+/, $line1)[-1];
                notify("        log_file: $log_file");
                push @copy_file, $log_file;
                my ($path_before_alert) = $log_file =~ m/^(.+?)\/alert/;
                # # 取得监听名称
                # $path_before_alert =~ s/\/$//;
                # my @F = split /\//, $path_before_alert;
                # my $listener_name = $F[-1];
                # notify("        listener_name: $listener_name");
                $listener_name = lc $listener_name;
                my $listener_log_path = $path_before_alert . "/trace/${listener_name}.log";
                if ( -e $listener_log_path ) {
                    notify("        listener_log: $listener_log_path");
                    push @listener_log, $listener_log_path;
                    push @copy_file, $listener_log_path;
                }
            }
        }
    }
    ### @listener_log
    ### @copy_file
    $ENV{ORACLE_HOME} = $old_env_oracle_home;

    return [ @listener_log ] if defined $listener_log[0];
    return "not_find" if not defined $listener_log[0];
}

sub check_file_in_n_days {
    my ($file_path,$days) = @_;
    notify("    check_file_in_n_days for $file_path",'A');

    if ( -e $file_path ) {
        # 查找最后修改时间
        my $status = stat($file_path);
        ### $status
        my $epoch_timestamp = (stat($file_path))[9];
        ### $epoch_timestamp
        my $time_diff = check_file_time_by_n_day($epoch_timestamp,$days);
        if ( $time_diff eq "ok" ) {
            notify("    $file_path is active");
            return "ok";
        }
        else {
            notify("    $file_path is inactive");
            return "not_ok";
        }
    }
    else {
        return "not_find";
    }
}

sub get_listenr_log_by_dir {
    notify("    get_listenr_log_by_dir");
    my ($input) = @_;
    # 如果是root，就取得 grid_user 和 oracle_user 的 TNS_ADMIN 环境变量
    # 如果不是root，根据ENV_TYPE，取默认目录的日志

    my @listener_dir;
    push @listener_dir, catfile($input->{oracle_base},"diag/tnslsnr");
    push @listener_dir, catfile($input->{grid_base},"diag/tnslsnr") if $input->{env_type} ne "fs";

    ### @listener_dir
    # 根据默认规则，从监听目录寻找日志

    my @listener_log_list;
    foreach my $dir01 ( @listener_dir ) {
        notify("        find listener log in $dir01 ...");
        opendir (DIR,"$dir01") or die "Can't open dir:$!";
        my @file01 = readdir(DIR);
        closedir(DIR);
        # /u01/app/oracle/diag/tnslsnr/oracle19cdb/listener/trace/*.log
        # 目录结构 第一层为主机名 第二层为监听名
        ### @file01
        foreach my $hostname_dir ( @file01 ){
            ### $hostname_dir
            next if $hostname_dir eq '.' or $hostname_dir eq '..';
            my $path01 = "$dir01/$hostname_dir";
            next if !-d $path01;
            ### $path01
            # /u01/app/oracle/diag/tnslsnr/oracle19cdb

            # 第一层目录是主机名 继续打开这个目录
            opendir (DIR02,"$path01") or die "Can't open dir:$!";
            my @dir02 = readdir(DIR02);
            closedir(DIR02);
            ### @dir02
            foreach my $listener_name_dir ( @dir02 ) {
                ### $listener_name_dir
                next if $listener_name_dir eq '.' or $listener_name_dir eq '..';
                my $path02 = "$path01/$listener_name_dir";
                next if !-d $path02;
                # 第二层目录是监听名 继续循环这一层目录
                ### $path02
                # /u01/app/oracle/diag/tnslsnr/oracle19cdb/listener
                # 日志文件在 /u01/app/oracle/diag/tnslsnr/oracle19cdb/listener/trace/${listener_name_dir}.log
                my $listener_log = catfile($path02,"trace/${listener_name_dir}.log");
                my $check_file = check_file_in_n_days($listener_log,600);
                if ( $check_file eq "ok" ) {
                    notify("        listener_log is $listener_log");
                    push @listener_log_list, $listener_log;
                }
            }
        }
    }

    return "not_find" if not defined $listener_log_list[0];
    return [ @listener_log_list ] if defined $listener_log_list[0];
}

sub get_listener_log_path {
    my ($input) = @_;
    notify("*** get_listener_log_path",'A');
