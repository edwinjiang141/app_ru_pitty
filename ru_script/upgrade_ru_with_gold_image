sub get_srvctl_database_type {
    my ($db_name,$input_oracle_home,$fork) = @_;
    notify("    get_srvctl_database_type for $db_name",'A');
    return("no_crs") if $env_type ne "crs"; # env_type 是全局变量

    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");
    my $srvctl = catfile($oracle_home,"bin/srvctl");

    my $get_random = get_random();
    my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
    my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
    notify("    cmd_log   is $cmd_log",'A');

    my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl config database -d $db_name'" . " 1>$cmd_log 2>$error_log";
    notify("    cmd   is $cmd",'A');
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display_log");
    ### $result1
    ### $result2
    my $db_type;
    foreach my $line ( @$result1 ) {
        if ( $line =~ m/^Type:/ ) {
            my @F = split /\s+/, $line;
            $db_type = $F[1];
        }
    }
    if ( not defined $db_type ) {
        notify("Error!  can not get srvctl database type for $db_name",'A');
        if ( defined $fork ) {
            notify("in fork, db_type is UNKNOWN",'A');
            return "UNKNOWN";
        }
        else {
            notify("db_type is UNKNOWN",'A');
            exit 1;
        }
    }

    $db_type = "rac_one_node" if $db_type eq "RACOneNode";
    notify("    database_type for $db_name is $db_type",'A');
    # RAC / RACOneNode / SINGLE
    return lc $db_type;
}

sub get_local_srvctl_instance_status {  # not_running / running_at_local / running_at_another_node
    my ($db_name,$input_oracle_home,$fork) = @_;
    notify("    get_local_srvctl_instance_status for $db_name",'A');
    return("no_crs") if $env_type ne "crs"; # env_type 是全局变量

    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");
    my $srvctl = catfile($oracle_home,"bin/srvctl");
    my $hostname = get_local_host_name();

    my $get_random = get_random();
    my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
    my $error_log = "/tmp/error_log_" . $db_name ."_" . $get_random . ".log";
    notify("    cmd_log   is $cmd_log",'A');

    my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status database -d $db_name'" . " 1>$cmd_log 2>$error_log";
    notify("        cmd is $cmd",'A');
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    my $srvctl_status = $result1;
    ### $result1
    ### $result2
    my $local_instance_status;
    foreach my $line ( @$result1 ) {
        next if $line !~ m/running on node/;
        my @F = split /\s+/, $line;
        my $running_host = $F[-1];
        notify("        3357 running_host is $running_host",'A');
        $local_instance_status = "running_at_local" if $running_host eq $hostname;
    }
    $local_instance_status = "not_defined" if not defined $local_instance_status;
    notify("        3360 local_instance_status is $local_instance_status",'A');

    my $db_type;
    $db_type = get_srvctl_database_type($db_name,$input_oracle_home) if not defined $fork;
    $db_type = get_srvctl_database_type($db_name,$input_oracle_home,"fork") if defined $fork;
    if ( $db_type eq "rac_one_node" ) {
        if ( $srvctl_status->[0] =~ m/running on node/i ) {
            my @F = split /\s+/, $srvctl_status->[0];
            my $running_host = $F[-1];
            notify("        3369 running_host is $running_host",'A');
            $local_instance_status = "running_at_another_node" if $running_host ne $hostname;
        }
        elsif ( $srvctl_status->[0] =~ m/not running/i ) {
            $local_instance_status = "not_running";
            notify("        3374 local_instance_status is $local_instance_status",'A');
        }
    }
    notify("        3377 local_instance_status is $local_instance_status",'A');

    $local_instance_status = "not_running" if not defined $local_instance_status;
    notify("      * get_local_srvctl_instance_status for $db_name is $local_instance_status",'A');

    return $local_instance_status;
}

