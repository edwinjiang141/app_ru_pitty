sub get_sqlplus_version {

    # 返回sqlplus的版本 19.0.0.0.0 / 19.14.0.0.0 / 12.2.0.1.0 / 11.2.0.4.0
    notify("    get_sqlplus_version",'A');
    $ENV{ORACLE_HOME} = get_oracle_home_with_echo("$oracle_user");
    my $sqlplus = catfile ($ENV{ORACLE_HOME},"bin/sqlplus");
    my @result = `$sqlplus -v`;
    my ($sqlplus_version);
    foreach my $line ( @result ) {
        if ( $line =~ m/Version/ ) {
            my @tmp = split /\s+/, $line;
            $sqlplus_version = $tmp[1];
        }
    }
    if ( not defined $sqlplus_version ) {
        foreach my $line ( @result ) {
            if ( $line =~ m/Release/ ) {
                my @tmp = split /\s+/, $line;
                $sqlplus_version = $tmp[2];
            }
        }
    }
    notify("    sqlplus_version is $sqlplus_version",'A');
    return $sqlplus_version;
}

