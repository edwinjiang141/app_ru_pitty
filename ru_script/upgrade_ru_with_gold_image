        print $fd "    # $cmd\n";
    }

    # 检查JVM组件是否安装或使用
    my $ojvm = check_jvm($fd);

    # 检查实例是否有SYS和MDSYS的无效对象，如果有，做datapatch时会造成组件失效，需要提前告警处理
    check_invalid_object_for_sys_precheck($fd);

    # 检查PDB状态
    check_pdb_status_at_precheck($fd);

    # 检查快照 restore_point_before_datapatch
    check_restore_point_for_precheck($fd);

    # 检查 log_archive_dest_state_N 和 db_recovery_file_dest
    # check_parameter_for_restore_point($oracle_sid,$fd);

    # 检查 umask
    my $msg;
    notify("checking umask","A");
    print $fd "\n";
    print $fd "# check umask\n";
    my $result;

    # $cmd = "umask";
    # $result = execute_cmd($cmd);
    # ### $result
    # if ( $result->[0] ne "0022" ) {
    #     $msg = "Warning! umask for root is wrong: $result->[0]";
    #     # $tag_global = "error_for_umask";      # root umask 不需要报错
    # }
    # else {
    #     $msg = "umask for root is correct: 0022";
    # }
    # notify("$msg");
    # print $fd "    # $msg\n";

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        $cmd = "su - $grid_user -c 'umask'";
        $result = execute_cmd($cmd);
        ### $result
        if ( $result->[0] !~ m/022/ ) {
            $msg = "Warning! umask for $grid_user is wrong: $result->[0]";
            $tag_global = "error_for_umask";
        }
        else {
            $msg = "umask for $grid_user is correct: 0022";
        }
        notify("$msg");
        print $fd "    # $msg\n";
    }

    $cmd = "su - $oracle_user -c 'umask'";
    $result = execute_cmd($cmd);
    ### $result
    if ( $result->[0] !~ m/022/ ) {
        $msg = "Warning! umask for $oracle_user is wrong: $result->[0]";
        $tag_global = "error_for_umask";
    }
    else {
        $msg = "umask for $oracle_user is correct: 0022";
    }
    notify("$msg");
    print $fd "    # $msg\n";

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        # 检查 opatch lspatches
        my $tag01 = check_lspatches_between_rac_node($fd,$tag_global);
        # $tag_global = $tag01 if $tag01 eq "error_for_opatch_lspatches";   # opatch lspatches 可以不一致

        # 检查 oui-patch.xml
        my $tag02 = check_oui_patch_xml($fd,$tag_global);                   # oui.xml 必须一致
        $tag_global = $tag02 if $tag02 eq "error_for_oui_patch_xml";

        # 检查节点间crs version是否一致
        my $tag04 = check_crs_releasepatch_between_rac_node($fd,$tag_global);   # error_for_crs_releasepatch
        $tag_global = $tag04 if $tag04 eq "error_for_crs_releasepatch";

        # 检查节点间sqlplus版本是否一致
        my $tag06 = check_sqlplus_version_between_rac_node($fd,$tag_global);   # error_for_sqlplus_version
        $tag_global = $tag06 if $tag06 eq "error_for_sqlplus_version";

        # 检查CRS
        $tag_global = check_crs($fd,$tag_global);
    }

    # 检查是否存在备份文件，这些文件可能是上一次RU升级时留下的，需要先删除
    my $tag05 = check_backup_file_for_ru($fd,$tag_global);
    $tag_global = $tag05 if $tag05 eq "has_ru_backup_file";
    # backup.for.switch_back

    # 检查是否有解压缩后未使用的GI/OH
    my $oracle_home_for_unzip = $oracle_home . "_unzip_for_switchback";
    my $grid_home_for_unzip = $grid_home . "_unzip_for_switchback";
    if ( -e $oracle_home_for_unzip ) {
