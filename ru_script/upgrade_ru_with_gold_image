sub compare_invalid_object {
    my ($oracle_sid) = @_;
    notify("*** compare_invalid_object",'A');

    my ($object01,$object02);
    my $file_name1 = "invaild_object_" . $oracle_sid . "_" . "before_datapatch" . ".log";
    my $file_path1 = catfile($log_dir,$file_name1);
    my @result1 = get_all_line($file_path1);
    foreach my $line ( @result1 ) {
        #'obj       1  WMSYS                 PACKAGE BODY          LT                              INVALID',
        # obj          0  ATOMICALM             FUNCTION              DT_FN_RERUN_PROCESS_1           INVALID

        next if $line !~ m/^obj/;
        my @F = split /\s+/, $line;
        my $hash;
        $hash->{con_id} = $F[1];
        $hash->{user_name} = $F[2];
        if ( defined $F[6] ) {
            $hash->{object_type} = $F[3] . "_" . $F[4];
            $hash->{object_name} = $F[5];
            $hash->{object_status} = $F[6];
        }
        else {
            $hash->{object_type} = $F[3];
            $hash->{object_name} = $F[4];
            $hash->{object_status} = $F[5];
        }
        push @$object01, { %$hash };
    }

    my $file_name2 = "invaild_object_" . $oracle_sid . "_" . "after_datapatch" . ".log";
    my $file_path2 = catfile($log_dir,$file_name2);
    my @result2 = get_all_line($file_path2);
    foreach my $line ( @result2 ) {
        next if $line !~ m/^obj/;
        my @F = split /\s\s+/, $line;
        my $hash;
        $hash->{con_id} = $F[1];
        $hash->{user_name} = $F[2];
        # $hash->{object_type} = $F[3];
        # $hash->{object_name} = $F[4];
        # $hash->{object_status} = $F[5];
        if ( defined $F[6] ) {
            $hash->{object_type} = $F[3] . "_" . $F[4];
            $hash->{object_name} = $F[5];
            $hash->{object_status} = $F[6];
        }
        else {
            $hash->{object_type} = $F[3];
            $hash->{object_name} = $F[4];
            $hash->{object_status} = $F[5];
        }

        push @$object02, { %$hash };
    }

    ### @result1
    ### @result2
    ### $object01
    ### $object02
    # 进行比较
    # 如果列表1有，列表2没有，说明是消除的无效对象，只需要计算一下差值即可
    my $count;
    $count->{still_exist} = 0;
    $count->{valid} = 0;
    $count->{new} = 0;
    $count->{total_before_patch} = 0;
    $count->{total_after_datapatch} = 0;
    $count->{total_before_patch} = scalar @$object01 if defined $object01->[0];
    $count->{total_after_datapatch} = scalar @$object02 if defined $object02->[0];

    notify("before patch,    the total number of invalid objects for $oracle_sid is: $count->{total_before_patch}");
    notify("after datapatch, the total number of invalid objects for $oracle_sid is: $count->{total_after_datapatch}");

    if ( $count->{total_before_patch} > 1 ) {
        my $msg = "Warning!  before datapatch, the total number of invalid objects for $oracle_sid is: $count->{total_before_patch}";
        print $error_fd "$msg\n";
    }

    if ( $count->{total_after_datapatch} > 1 ) {
        my $msg = "Warning!   after datapatch, the total number of invalid objects for $oracle_sid is: $count->{total_after_datapatch}";
        print $error_fd "$msg\n";
    }
    if ( $count->{total_after_datapatch} > $count->{total_before_patch} ) {
        my $msg = "Error!  after datapatch, invalid objects for $oracle_sid Have increased, before: $count->{total_before_patch} , after: $count->{total_after_datapatch}";
        print $error_fd "$msg\n";
    }

    foreach my $hash1 ( @$object01 ) {
        my $tag = "-";
        foreach my $hash2 ( @$object02 ) {
            if ( $hash1->{con_id} eq $hash2->{con_id}
                and $hash1->{user_name} eq $hash2->{user_name}
                and $hash1->{object_name} eq $hash2->{object_name}
                and $hash1->{object_type} eq $hash2->{object_type}
                ) {
                $tag = "still_exist";
                $count->{still_exist} ++;
            }
        }
        if ( $tag eq "-" ) {
            # 已经消除
            notify("Congratulation! the status of object con_id.$hash1->{con_id}.$hash1->{user_name}.$hash1->{object_name} has become valid now","N");
            $count->{valid} ++;
        }
    }

    # 如果列表2有，列表1没有，说明是新增的无效对象，需要列出具体名称
    foreach my $hash2 ( @$object02 ) {
        my $tag = "-";
        foreach my $hash1 ( @$object01 ) {
            if ( $hash1->{con_id} eq $hash2->{con_id}
                and $hash1->{user_name} eq $hash2->{user_name}
                and $hash1->{object_name} eq $hash2->{object_name}
                and $hash1->{object_type} eq $hash2->{object_type}
                ) {
                $tag = "still_exist";
            }
        }
        if ( $tag eq "-" ) {
            # 新增
            $count->{new} ++;
        }
    }

    if ( $count->{new} < 20 ) {     # 小于20，就打印在屏幕上
        foreach my $hash2 ( @$object02 ) {
            my $tag = "-";
            foreach my $hash1 ( @$object01 ) {
                if ( $hash1->{con_id} eq $hash2->{con_id}
                    and $hash1->{user_name} eq $hash2->{user_name}
                    and $hash1->{object_name} eq $hash2->{object_name}
                    and $hash1->{object_type} eq $hash2->{object_type}
                    ) {
                    $tag = "still_exist";
                }
            }
            if ( $tag eq "-" ) {
                # 新增
                notify("Warning! object con_id.$hash2->{con_id}.$hash2->{user_name}.$hash2->{object_name} is an new invalid object after datapatch");
            }
        }
    }

    notify("after datapatch, the number of objects that remain invalid  for $oracle_sid is: $count->{still_exist}");
    notify("after datapatch, the number of objects that change to valid for $oracle_sid is: $count->{valid}");
    notify("after datapatch, the number of new invalid objects for $oracle_sid is:          $count->{new}");
}

