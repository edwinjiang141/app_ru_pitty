    my $listener_log_path = get_listener_log_path($env_for_log);
    ### $listener_log_path

    #                       '/u01/app/grid/diag/tnslsnr/db19ce01/listener/trace/listener.log',
    #                       '/u01/app/grid/diag/tnslsnr/db19ce01/listener_scan1/trace/listener_scan1.log',
    #                       '/u01/app/grid/diag/tnslsnr/db19ce01/asmnet1lsnr_asm/trace/asmnet1lsnr_asm.log'

    # 执行清理操作
    foreach my $log ( @$listener_log_path ) {
