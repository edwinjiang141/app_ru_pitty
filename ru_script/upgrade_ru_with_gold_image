        my @log2 = get_all_line($error_log);
        if ( defined $log2[0] ) {
            notify("Error!  $cmd is error!");
            print_file($error_log);
            exit 1;
        }
    }

    # # 解压后的目录，不确定是什么名称，需要将目录名修改为 target_grid_home 的最后一层目录
    # chdir($target_grid_home_parent_dir);
    # notify("current work dir is $target_grid_home_parent_dir",'A');
    #
    # # 列出目录名，按时间排序，取最新的一个
    # $cmd = "ls -lt $target_grid_home_parent_dir";
    # my $result = execute_cmd($cmd);
    # my $last_dir_name = (split /\s+/, $result->[1])[-1];
    # notify("last_dir_name is $last_dir_name",'A');
    #
    # # 取得 target_grid_home 的最后一层目录
    # my $target_grid_home_last_dir = basename($target_grid_home);
    # notify("target_grid_home_last_dir is $target_grid_home_last_dir",'A');
    #
    # # 修改当前目录名 为 $target_grid_home_last_dir
    # if ( $target_grid_home_last_dir ne $last_dir_name ) {
    #     $cmd = "mv $last_dir_name $target_grid_home_last_dir";
    #     notify("    cmd is $cmd",'A');
    #     system("$cmd");
    # }

    $cmd = "chown -R $grid_user:$group_for_oinstall $target_grid_home";
