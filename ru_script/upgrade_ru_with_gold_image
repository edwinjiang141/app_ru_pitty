sub replace_oracle_home_for_crontab {
    my ($username,$old_home,$new_home) = @_;
    notify("    replace_oracle_home_for_crontab for $username");
    notify("        old_home is $old_home");
    notify("        new_home is $new_home");

    # 取得$HOME路径
    my $cmd;
    if ( $username eq "root" ) {
        $cmd = "echo \$HOME";
    }
    else {
        $cmd = "su - $username -c 'echo \$HOME'";
    }
    notify("        cmd is $cmd",'A');
    my $result = execute_cmd($cmd);
    my $home = $result->[0];
    notify("        home for $username is $home",'A');

    # 保存crontab到文件
    my $crontab_tmp = catfile($home,"crontab.tmp");
    unlink $crontab_tmp if -e $crontab_tmp;             # 删除现有 crontab.tmp
    if ( $username eq "root" ) {
        $cmd = "crontab -l > $crontab_tmp";
    }
    else {
        $cmd = "su - $username -c 'crontab -l > $crontab_tmp'";
    }
    notify("        cmd is $cmd",'A');
    system("$cmd");

    # 检查当前crontab是否包含 $old_home
    my @file01 = get_all_line_with_space($crontab_tmp);
    notify("        before replace oracle_home for $crontab_tmp");
    foreach my $line ( @file01 ) {
        notify("        $line",'A');
    }
    if ( grep /$old_home/, @file01 ) {
        notify("        find $old_home in $crontab_tmp");
    }
    else {
        my $msg = "Warning! can not find $old_home in $crontab_tmp";
        notify($msg);
        # print $error_fd "$msg\n";
        return;
    }

    replace_oracle_home_for_a_file($crontab_tmp,$old_home,$new_home);

    # 重新写入crontab
    if ( $username eq "root" ) {
        $cmd = "crontab $crontab_tmp";
    }
    else {
        $cmd = "su - $username -c 'crontab $crontab_tmp'";
    }
    notify("        cmd is $cmd",'A');
    system("$cmd");

    if ( $username eq "root" ) {
        $cmd = "crontab -l";
    }
    else {
        $cmd = "su - $username -c 'crontab -l'";
    }
    notify("        cmd is $cmd",'A');
    $result = execute_cmd($cmd);
    notify("        crontab -l is:",'A');
    foreach my $line ( @$result ) {
        notify("            $line",'A');
    }

    # 修改.cron_file /oracle_grid/grid/.cron_file
    # 每个用户$HOME下都可能有.cron_file 不存在时不需要关心
    my $cron_file = catfile($home,".cron_file");
    if ( -e $cron_file ) {
        notify("    modify $cron_file for $username");
        replace_oracle_home_for_a_file($cron_file,$old_home,$new_home);
    }

    notify("    replace_oracle_home_for_crontab for $username is done.");
}

sub replace_oracle_home_for_a_file {
    my ($file_path,$old_home,$new_home) = @_;
    notify("    replace_oracle_home_for_a_file for $file_path");
    notify("        old_home is $old_home");
    notify("        new_home is $new_home");

    # 比对现有文件是否有 $old_home
    my @file01 = get_all_line_with_space($file_path);
    notify("        before replace oracle_home for $file_path");
    foreach my $line ( @file01 ) {
        notify("        $line",'A');
    }
    if ( grep /$old_home/, @file01 ) {
        notify("        find $old_home in $file_path");
    }
    else {
        my $msg = "Warning! can not find $old_home in $file_path";
        notify($msg);
        # print $error_fd "$msg\n";
        return;
    }

    # 备份文件
    my $backup_file_path = $file_path . ".backup_before_replace_oracle_home." . get_locatime_for_file();
    notify("        copy $file_path to $backup_file_path",'A');
    copy($file_path,$backup_file_path);
    if ( !-e $backup_file_path ) {
        notify("Error!  copy $file_path to $backup_file_path is failed !",'A');
        exit 1;
    }

    # 替换ORACLE_HOME，指向新路径
    foreach my $line ( @file01 ) {
        $line =~ s/$old_home/$new_home/g;
    }

    # 重新写入新文件
    notify("        rewrite $file_path",'A');
    open myFile , "> $file_path";
    foreach my $a ( @file01 ) {
        print myFile "$a\n";
    }
    close myFile;
    notify("        write $file_path done",'A');

    # 核对新文件
    notify("        after replace oracle_home for $file_path");
    my @file02 = get_all_line_with_space($file_path);
