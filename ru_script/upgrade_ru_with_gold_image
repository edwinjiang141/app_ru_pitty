    #
    # 取得当前 GI_HOME和DB_HOME
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $grid_home = get_oracle_home_with_echo("$grid_user");

    # 检查是否指定了 target_home 的值
    my $tag_for_exit = "no";
    if ( $target_grid_home eq "not_defined_grid_home"  ) {
