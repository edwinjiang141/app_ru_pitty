    notify("home for $grid_user is $home",'A');
    $cmd = "ls -alt $home/.*backup_for_RU_upgrade* 2>/dev/null";
    $result = execute_cmd($cmd);
    if ( not defined $result->[0] ) {
        # notify("Error!  backup profile for $grid_user is not find");
        # exit 1;
        notify("Warning!  backup profile for $grid_user is not find");
        return "not_find";
    }

    my $last_backup_profile = (split /\s+/, $result->[0])[-1];
    my $old_grid_home;
    my @result = get_all_line($last_backup_profile);
    foreach my $line ( @result ) {
        if ( $line =~ m/\bORACLE_HOME=/ and $line !~ m/^\s*#/ ) {        # 如果前面没有注释，并且包含ORACLE_HOME这一行
            my @F = split /=/, $line;
