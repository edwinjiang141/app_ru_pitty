sub unzip_image_for_switch_back {
    my ($target_home,$type) = @_;
    notify("*** starting unzip_image_for_switch_back $target_home , type: $type",'A');

    my ($image_file_name,$image_path);
    if ( $type eq "db_image" ) {
        $image_file_name = basename($db_image);
        $image_path = $db_image;
    }
    elsif ( $type eq "grid_image" ) {
        $image_file_name = basename($grid_image);
        $image_path = $grid_image;
    }

    # 如果镜像文件不存，就退出
    if ( !-e $image_path ) {
        notify("Error!  $image_path does not exists",'A');
        exit 1;
    }

    # 如果目标ORACLE_HOME存在，就不解压缩
    if ( -e $target_home ) {
        notify("Note: $target_home is exists",'A');
        return;
    }

    my $time_start = time();
    # target_oracle_home
    my $target_oracle_home_parent_dir = get_parent_dir_path($target_home);
    # target_oracle_home_parent_dir 必然存在
    if ( !-e $target_oracle_home_parent_dir ) {
        notify("Error!  $target_oracle_home_parent_dir does not exists",'A');
        exit 1;
    }

    my $sqlplus_version = get_sqlplus_version();
    notify("Error!  sqlplus version $sqlplus_version is not tested",'A') and exit 1 if $sqlplus_version !~ m/^1[2|8|9]/;

    # 如果后缀为tar或者gz，就是tar包
    if ( $image_file_name =~ m/\.tar/ ) {
        # notify("Error!  $image_file_name is not a gold image",'A');
        # exit 1;
        # 复制
        my $cmd = "mkdir -p $target_home";
        notify("    cmd is $cmd",'A');
        system("$cmd");

        chdir($target_home);
        notify("current work dir is $target_home",'A');

        my ($time1,$time2,$time_diff,$tar_file_path,$gz_tag);
        $tar_file_path = $image_path;

        if ( $image_file_name =~ "\.gz" ) {
            $gz_tag = "yes";
            $time1 = time();
            unlink $cmd_log;
            unlink $error_log;
            my $get_random = get_random();
            my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
            my $error_log = "/tmp/error_log_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            $cmd = "cp $image_path $target_home 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system("$cmd");
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
            if ( defined $result1->[0] or defined $result2->[0] ) {
                notify("Error! $cmd is wrong");
                exit 1;
            }
            $time2 = time();
            $time_diff = time_diff($time1,$time2);
            notify("time: $time_diff seconds to cp $image_path $target_home");

            $time1 = time();
            unlink $cmd_log;
            unlink $error_log;
            $get_random = get_random();
            $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
            $error_log = "/tmp/error_log_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            $cmd = "gzip -d $image_file_name 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system("$cmd");
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
            if ( defined $result1->[0] or defined $result2->[0] ) {
                notify("Error! $cmd is wrong");
                exit 1;
            }
            $time2 = time();
            $time_diff = time_diff($time1,$time2);
            notify("time: $time_diff seconds to gzip -d $image_file_name");

            # 此时，它是tar文件名，这个文件名有可能是tar.gz解压缩之后的文件名，也可能原来就是tar文件
            $image_file_name =~ s/\.gz$//;
            $tar_file_path = catfile($target_home,$image_file_name);
        }

        $time1 = time();
        unlink $cmd_log;
        unlink $error_log;
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');
        $cmd = "tar xf $tar_file_path 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system("$cmd");
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        if ( defined $result1->[0] or defined $result2->[0] ) {
            notify("Error! $cmd is wrong");
            exit 1;
        }
        $time2 = time();
        $time_diff = time_diff($time1,$time2);
        notify("time: $time_diff seconds to tar xf $tar_file_path");

        # delete tar
        if ( defined $gz_tag ) {
            my $get_random = get_random();
            my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
            my $error_log = "/tmp/error_log_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            $cmd = "rm -rf $tar_file_path 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system("$cmd");
        }

    }


    # 如果后缀为zip，就是gold image
    if ( $image_file_name =~ m/\.zip/ ) {
        my $cmd = "mkdir -p $target_home";
        notify("    cmd is $cmd",'A');
        system("$cmd");

        chdir($target_home);
        notify("current work dir is $target_home",'A');

        my $time1 = time();
        unlink $cmd_log;
        unlink $error_log;
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');
        $cmd = "echo 'A' | unzip $image_path -d $target_home 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system("$cmd");
        my $time2 = time();
        my $time_diff = time_diff($time1,$time2);
        notify("time: $time_diff seconds to unzip $image_path");
        my @log2 = get_all_line($error_log);
        if ( defined $log2[0] ) {
            notify("Error!  $cmd is error!");
            print_file($error_log);
            exit 1;
        }

    }

    # # 解压后的目录，不确定是什么名称，需要将目录名修改为 target_db_home 的最后一层目录
    # chdir($target_oracle_home_parent_dir);
    # notify("current work dir is $target_oracle_home_parent_dir",'A');
    #
    # # 按时间顺序列出目录，只取第1个目录
    # $cmd = "ls -lt $target_oracle_home_parent_dir";
    # my $result = execute_cmd($cmd);
    # my $last_dir_name = (split /\s+/, $result->[1])[-1];
    # notify("last_dir_name is $last_dir_name",'A');
    #
    # # 取得 target_home 的最后一层目录
    # my $target_oracle_home_last_dir = basename($target_home);
    # notify("target_oracle_home_last_dir is $target_oracle_home_last_dir",'A');
    #
    # # 修改当前目录名 为 $target_oracle_home_last_dir
    # if ( $target_oracle_home_last_dir ne $last_dir_name ) {
    #     $cmd = "mv $last_dir_name $target_oracle_home_last_dir";
    #     notify("    cmd is $cmd",'A');
    #     system("$cmd");
    # }

    $cmd = "chown -R $oracle_user:$group_for_oinstall $target_home" if $type eq "db_image";
    $cmd = "chown -R $grid_user:$group_for_oinstall $target_home" if $type eq "grid_image";
    notify("    cmd is $cmd",'A');
    system("$cmd");

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task unzip image for switch back");
}

sub install_a_db_home_local_19 {
    my ($target_home) = @_;
    notify("*** install_a_db_home_local_19",'A');
    my $time_start = time();
    my $inventory_find = check_inventory_for_a_target_home($target_home);
    if ( $inventory_find eq "yes" ) {
        notify("Warning! $target_home is already installed");
        return;
    }

    my ($runInstaller,$runInstaller_cmd);
    my $hostname = get_local_host_name();
    $runInstaller = catfile($target_home,"runInstaller");
    if ( $env_type eq "crs" ) {
        $runInstaller_cmd = "$runInstaller -silent \\
                              ORACLE_BASE=$oracle_base \\
                              INVENTORY_LOCATION=$oraInventory \\
                              ORACLE_HOME=$target_home \\
                              -waitForCompletion \\
                              -ignoreInternalDriverError \\
                              -ignorePrereqFailure  \\
                              -skipPrereqs  \\
                              oracle.install.option=INSTALL_DB_SWONLY \\
                              oracle.install.db.InstallEdition=$product_type \\
                              oracle.install.db.OSDBA_GROUP=$group_oracledba \\
                              oracle.install.db.OSOPER_GROUP=$group_oracleoper \\
                              oracle.install.db.OSBACKUPDBA_GROUP=$group_backupdba \\
                              oracle.install.db.OSDGDBA_GROUP=$group_dgdba \\
                              oracle.install.db.OSKMDBA_GROUP=$group_kmdba \\
                              oracle.install.db.OSRACDBA_GROUP=$group_racdba \\
                              oracle.install.db.CLUSTER_NODES=$hostname";
    }
    else {
        $runInstaller_cmd = "$runInstaller -silent \\
                              ORACLE_BASE=$oracle_base \\
                              INVENTORY_LOCATION=$oraInventory \\
                              ORACLE_HOME=$target_home \\
                              -waitForCompletion \\
                              -ignoreInternalDriverError \\
                              -ignorePrereqFailure  \\
                              -skipPrereqs  \\
                              oracle.install.option=INSTALL_DB_SWONLY \\
                              oracle.install.db.InstallEdition=$product_type \\
                              oracle.install.db.OSDBA_GROUP=$group_oracledba \\
                              oracle.install.db.OSOPER_GROUP=$group_oracleoper \\
                              oracle.install.db.OSBACKUPDBA_GROUP=$group_backupdba \\
                              oracle.install.db.OSDGDBA_GROUP=$group_dgdba \\
                              oracle.install.db.OSKMDBA_GROUP=$group_kmdba \\
                              oracle.install.db.OSRACDBA_GROUP=$group_racdba";
    }

    if ( !-e $runInstaller ) {
        notify("Error!  can not find $runInstaller",'A');
        exit 1;
    }

    unlink $cmd_log;
    unlink $error_log;
    my $time1 = time();

    my $os_type;
    chomp ($os_type = `uname`);
    $os_type = lc $os_type;

    # notify("runInstaller_cmd is $runInstaller_cmd",'A');
    my $cmd;
    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$target_home;$runInstaller_cmd' 1>$cmd_log 2>$error_log" if $os_type eq "linux";
    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$target_home;echo \'y\' | $runInstaller_cmd' 1>$cmd_log 2>$error_log" if $os_type eq "aix";
    notify("$cmd",'A');
    system($cmd);

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to runInstaller");
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);

    my $run_install_log = "$log_dir/runInstaller." . get_locatime_for_file() . ".log";
    copy ($cmd_log, $run_install_log);
    notify("run_install_log log is $run_install_log");
    my $run_install_error = "$log_dir/runInstaller_error" . get_locatime_for_file() . ".log";
    copy ($error_log, $run_install_error);
    notify("run_install_error log is $run_install_error");

    my $tag;
    foreach my $line ( @$result1 ) {
        if ( $line =~ /FATAL/ ) {
            $tag->{error} = 'yes';
        }
        if ( $line =~ m/Successfully/ ) {
            $tag->{successfully} = 'yes';
        }
        if ( $line =~ m/root\.sh/ ) {
            $tag->{root} = 'yes';
        }
    }
    unless ( defined $tag->{successfully} and $tag->{root} ) {
        notify("Error!  $runInstaller_cmd is wrong, please check $cmd_log and $error_log");
        exit 1;
    }

    notify("$runInstaller is done");

    # /u01/app/oracle/product/19.14.0/db_home/root.sh
    unlink $cmd_log;
    unlink $error_log;
    my $root_sh = catfile($target_home,"root.sh");
    $time1 = time();
    $cmd = "$root_sh 1>$cmd_log 2>$error_log";
    notify("root.sh is $cmd",'A');
    system($cmd);
    $time2 = time();
    $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to $root_sh");
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    $tag = "-";
    foreach my $line ( @$result1 ) {
        if ( $line =~ /FATAL/ ) {
            $tag = 'error';
        }
    }
    if ( $tag eq "error" ) {
        notify("Error!  $root_sh is wrong, please check $cmd_log and $error_log");
        exit 1;
    }

    notify("install_a_db_home_local_19 is done");

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task install_a_db_home_local_19");
}

