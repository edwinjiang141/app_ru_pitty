sub get_all_line {
   my $file = shift;
   return "file not exists" if not defined $file;
   open my $fh, '<', $file or return;
   my @lines = <$fh>;
   @lines = grep { !/^#/ } @lines;
   @lines = grep { !/^\s+#/ } @lines;
   @lines = grep { !/^\s+?$/ } @lines;
   foreach (@lines) {
      chomp;
   }

   if ( wantarray ){
      return @lines;
   }
   else{
      return join '', @lines;
   }
}

