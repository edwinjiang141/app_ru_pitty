        compare_remote_file($file,$oracle_user,$all_node_hostname,$fd); # 传递给 compare_remote_file 过程进行比较
    }
}

sub get_profile_name {
    # 取得grid/oracle的profile名称
    # 读取/etc/passwd，得到用户的shell
    notify("    get_profile_name","A");

    # 此处可以 su - username -c "echo $SHELL" 来取得SHELL环境变量

    # 根据shell类型，确定profile文件名称
    my @passwd = get_all_line("/etc/passwd");
    foreach my $line ( @passwd ) {
        my @F = split /:/, $line;
        my $shell = $F[-1];
        my $profile;
        $profile = ".bash_profile" if $shell =~ m/\/bash/;
        $profile = ".profile" if $shell =~ m/\/sh/;
        $profile = ".profile" if $shell =~ m/\/ksh/;
        $profile_grid = $profile if $F[0] eq $grid_user;
        $profile_oracle = $profile if $F[0] eq $oracle_user;
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        if ( not defined $profile_grid or not defined $profile_oracle ) {
            notify("Error!  can not get profile name for $grid_user and $oracle_user, please check /etc/passwd","A");
            exit 1;
        }
    }
    elsif ( $env_type eq "fs" ) {
        if ( not defined $profile_oracle ) {
            notify("Error!  can not get profile name for $oracle_user, please check /etc/passwd","A");
            exit 1;
        }
    }
    notify("        profile for $grid_user is $profile_grid","A") if defined $profile_grid;
    notify("        profile for $oracle_user is $profile_oracle","A");
}

sub check_restore_point_for_precheck {
    my ($fd) = @_;
    notify("*** do check_restore_point_for_precheck");
    my $restore_point_name = $input->{restore_point_name} ? $input->{restore_point_name} : "restore_point_before_datapatch";
    print $fd "\n";
    print $fd "# checking restore_point $restore_point_name\n";

    my $restore_point_exists_global = "no";
    # 对每个DB进行检查
    my $db_name_and_sid_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        my $oracle_home = get_oracle_home_with_echo("$oracle_user");


        my $sql;
        push @$sql, "set linesize 140;";
        push @$sql, "column restore_point format a20;";
        push @$sql, "column name format a80;";
        push @$sql, "select 'restore_point', name from v\$restore_point;";
        $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

        my $restore_point_exists = 'no';
        foreach my $line ( @$result ) {
            next if $line !~ m/restore_point/;
            # notify("    $line",'A');
            if ( $line =~ m/$restore_point_name/i ) {
                $restore_point_exists = 'yes';
            }
        }

        if ( $restore_point_exists eq "yes" ) {
            $restore_point_exists_global = "yes";
            my $msg = "Error! RESTORE POINT $restore_point_name for sid $oracle_sid is existed";
            notify("$msg",'A');
            print $fd "    # $msg\n";
            print $error_fd "$msg\n";
            $msg = "    # -- sid: $oracle_sid, DROP RESTORE POINT $restore_point_name;";
            notify("$msg",'A');
            print $fd "    # $msg\n";
        }
        else {
            my $msg = "RESTORE POINT $restore_point_name for sid $oracle_sid is not existed";
            notify( "    $msg");
            print $fd "    # $msg\n";
        }
    }

    if ( $restore_point_exists_global eq "yes" ) {
        print $fd "    # Some SID has restore point $restore_point_name\n";
    }
    else {
        print $fd "    # no restore point $restore_point_name, all SID\n";
    }

}

