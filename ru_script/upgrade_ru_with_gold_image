sub record_service_status {
    notify("    record_service_status");
    # 只在CRS/HAS环境下运行
    return if $env_type eq "fs";

    # 备份并删除记录文件
    my $service_running_list_backup = $service_running_list . "." . get_locatime_for_file() . ".log";
    if ( -e $service_running_list ) {
        copy($service_running_list,$service_running_list_backup);
        if ( !-e $service_running_list_backup ) {
            notify("Error!  copy $service_running_list to $service_running_list_backup is failed !",'A');
            exit 1;
        }
        unlink $service_running_list if -e $service_running_list;
   }
    my $fd01 = IO::File->new("> $service_running_list");

    # 对每个DB进行循环
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $srvctl = catfile($oracle_home,"bin/srvctl");
    my $db_name_and_sid = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_and_sid ) {
        my $db_name = $db_name_and_sid->{db_name};
        # srvctl status service -db db19c
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');

        my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status service -db $db_name' 1>$cmd_log 2>$error_log";
        notify("        cmd is $cmd",'A');
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        # 发现有当前节点启动的SERVICE 记录到文件 service.status
        foreach my $line ( @$result1 ) {
            # Service my_service_01 is running on instance(s) db19c1
            # Service my_service_02 is running on instance(s) db19c2
            # Service my_service_03 is running on instance(s) db19c1,db19c2
            my ($service_name,$started_instance);
            my @F = split /\s+/, $line;
            $service_name = $F[1];
            $started_instance = $F[-1];
            # 文件格式为 db_name.service.instance
            # service 有可能没有运行
            $started_instance = "not_running" if $line =~ m/is not running/;
            my $record_line = $db_name . "." . $service_name . "." . $started_instance;
            print $fd01 "$record_line\n";
        }
    }
    $fd01->close();
    my @service_list = get_all_line($service_running_list);
    foreach my $line ( @service_list ) {
        notify("        $line");
    }

}

sub start_service_from_record {
    notify("    start_service_from_record");
    # 只在CRS/HAS环境下运行
    return if $env_type eq "fs";

    if ( !-e $service_running_list ) {
        notify("Waring! $service_running_list is not exist");
        return;
    }

    # 从记录文件 service.status 中查找service清单，并启动
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $srvctl = catfile($oracle_home,"bin/srvctl");
    my @service_list = get_all_line($service_running_list);
    foreach my $line ( @service_list ) {
        notify("        $line");
        my @F01 = split /\./, $line;
        my $db_name = $F01[0];
        my $service_name = $F01[1];
        my $instances = $F01[2];
        if ( $instances eq "not_running" ) {
            notify("        service $service_name is not running, when step_03_switch_grid_home at first node",'A');
            next;
        }
        my @instance_list = split /,/, $instances;
        foreach my $instance ( @instance_list ) {
            my $get_random = get_random();
            my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
            my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');

            my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl start service -db $db_name -service $service_name -instance $instance' 1>$cmd_log 2>$error_log";
            notify("        cmd is $cmd",'A');
            system($cmd);
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display");
        }

        # 确认当前service在正确的instance启动
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');

        $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status service -db $db_name -service $service_name' 1>$cmd_log 2>$error_log";
        notify("        cmd is $cmd",'A');
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        foreach my $line ( @$result1 ) {
            my @F01 = split /\s+/, $line;
            my $instance_running = $F01[-1];
            if ( $instances eq $instance_running ) {
                notify("**** yes, service $service_name for $db_name is running on $instances");
            }
            else {
                my $msg = "Warning! service $service_name for $db_name is not running on $instances, it running on $instance_running";
                notify("$msg",'A');
                # print $error_fd "$msg\n";
                notify("restart service $service_name for $db_name on instance $instances",'A');

                # 停止 service 并重新启动
                $get_random = get_random();
                $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
                $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
                notify("    cmd_log   is $cmd_log",'A');

                my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl stop service -db $db_name -service $service_name' 1>$cmd_log 2>$error_log";
                notify("        cmd is $cmd",'A');
                system($cmd);
                ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display");

                $get_random = get_random();
                $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
