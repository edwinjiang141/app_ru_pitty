        exit 1;
    }
    if ( $target_oracle_home eq "not_defined_oracle_home" ) {
        notify("Error!  must defined --target_oracle_home");
        exit 1;
    }
    step_02_install();
    print_error();

    return if $env_type eq "fs";
    # 如果没有指定TARGET GI和DB 就退出
    if ( $target_grid_home eq "not_defined_grid_home" ) {
        notify("Error!  must defined \$target_grid_home");
        exit 1;
    }
    if ( $target_oracle_home eq "not_defined_oracle_home" ) {
        notify("Error!  must defined \$target_oracle_home");
        exit 1;
    }
    stop_current_node_listener();   # 停止当前节点的监听，VIP和SCAN-IP都切换到其它节点
    step_03_switch_grid_home();
    change_grid_bin_permission();
    print_error();

    if ( $target_oracle_home eq "not_defined_oracle_home" ) {
        notify("Error!  must defined \$target_oracle_home");
        exit 1;
    }
    step_04_switch_db_home();
    my $tag_for_srvctl = confirm_oh_srvctl();
    modify_oh_srvctl() if $tag_for_srvctl eq "error";
    change_oracle_bin_permission();
    start_instance_all();
    start_current_node_listener();  # 将VIP和SCAN-IP切换到原来的节点，并启动当前节点的监听
    print_error();

    return if $env_type eq "fs";
    step_11_switch_back_gi_home_detach();
    print_error();

    step_12_switch_back_gi_home_install();
    print_error();

    return if $env_type eq "fs";
    stop_current_node_listener();   # 停止当前节点的监听，VIP和SCAN-IP都切换到其它节点
    step_13_switch_back_gi_home_switch();
    print_error();

    return if $env_type eq "fs";
    step_14_switch_back_gi_home_start();
    print_error();

    return if $env_type eq "fs";
    step_15_switch_back_gi_home_clear();
    print_error();

    step_21_switch_back_db_home_detach();
    print_error();

    step_22_switch_back_db_home_install();
    print_error();

    step_23_switch_back_db_home_switch();
    $tag_for_srvctl = confirm_oh_srvctl();
    modify_oh_srvctl() if $tag_for_srvctl eq "error";
    print_error();

    step_24_switch_back_db_home_start();
    start_current_node_listener();  # 将VIP和SCAN-IP切换到原来的节点，并启动当前节点的监听
    print_error();

    step_25_switch_back_db_home_clear();

