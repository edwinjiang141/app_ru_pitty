    notify("*** starting $step_name",'A');
    my $time_start = time();

    # 检查unzip是否已经完成

    # 检查输入的参数

    # 如果没有指定TARGET GI和DB 就退出
    if ( $target_grid_home eq "not_defined_grid_home" ) {
