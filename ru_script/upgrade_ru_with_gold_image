sub check_cdb_registry_sqlpatch {
    my ($oracle_sid,$input_oracle_home) = @_;
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    notify("check_cdb_registry_sqlpatch for $oracle_sid");
    my $time1 = time();

    my $sqlplus_version = get_sqlplus_version();

    my $sql;
    push @$sql, "set linesize 200;";
    push @$sql, "column description format a60;";
    push @$sql, "column con format 999;";
    push @$sql, "column status format a12;";
    push @$sql, "column action format a8;";
    push @$sql, "column action_time format a19;";
    if ( $sqlplus_version =~ m/^19/ ) {
        push @$sql, "select con_id con,patch_id,description,to_char(action_time,'YYYY-MM-DD HH24:MI:SS') action_time,action,source_version,target_version,status from cdb_registry_sqlpatch order by action_time desc;";
    }
    else {
        push @$sql, "select con_id con,patch_id,description,to_char(action_time,'YYYY-MM-DD HH24:MI:SS') action_time,action,status from cdb_registry_sqlpatch order by action_time desc;";
    }
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);
    my $file_name = "cdb_registry_sqlpatch_" . $oracle_sid . "_" . get_locatime_for_file() . ".log";
    my $file_path = catfile($log_dir,$file_name);
    notify("write $file_path",'A');
    open myFile , "> $file_path";
    foreach my $line ( @$result ) {
        $line =~ s/^\s+|\s+$//g;
        notify("    $line",'A');
        print myFile "$line\n";
    }
    close myFile;
    notify("write $file_path done",'A');

    # 3      34086870  OJVM RELEASE UPDATE: 19.16.0.0.220719 (34086870)              APPLY     2022-09-15 17:58:03  SUCCESS
    # 3      34133642  Database Release Update : 19.16.0.0.220719 (34133642)         APPLY     2022-09-15 17:58:03  SUCCESS
    # 1      34086870  OJVM RELEASE UPDATE: 19.16.0.0.220719 (34086870)              APPLY     2022-09-15 17:57:51  SUCCESS
    # 1      34133642  Database Release Update : 19.16.0.0.220719 (34133642)         APPLY     2022-09-15 17:57:51  SUCCESS
    # 3      29517242  Database Release Update : 19.3.0.0.190416 (29517242)          APPLY     2021-09-26 18:10:45  SUCCESS
    # 1      29517242  Database Release Update : 19.3.0.0.190416 (29517242)          APPLY     2021-09-26 18:01:55  SUCCESS

    # 检查跟DB补丁和OJVM补丁对应的最新的两行，要求为 APPLY SUCCESS
    my @F1 = grep { /database/i } @$result;
    my @F2 = grep { /ojvm/i } @$result;
    @F2 = grep { /apply/i } @F2;
    my $datapatch;
    if ( defined $F1[0] and $F1[0] =~ m/APPLY/ and $F1[0] =~ m/SUCCESS/ ) {
        $datapatch->{db} = "ok";
    }
    if ( defined $F2[0] and $F2[0] =~ m/APPLY/ and $F1[0] =~ m/SUCCESS/ ) {
        $datapatch->{ojvm} = "ok";
    }

    my $tag = "ok";
    if ( defined $datapatch->{db} ) {
        notify("datapatch for database is done");
    }
    else {
        my $msg = "Error!  datapatch for database is wrong";
        notify("$msg");
        print $error_fd "$msg\n";
        $tag = "error";
        # 列出具体的问题
        my $action = (split /\s+/, $F1[0])[-4];
        my $result = (split /\s+/, $F1[0])[-1];
        notify("    -> last action is $action, result is $result");
    }
    if ( defined $F2[0] ) {
        if ( defined $datapatch->{ojvm} ) {
            notify("datapatch for ojvm is done");
        }
        else {
            my $msg = "Error!  datapatch for ojvm is wrong";
            notify("$msg");
            print $error_fd "$msg\n";
            $tag = "error";
            # 列出具体的问题
            my $action = (split /\s+/, $F2[0])[-4];
            my $result = (split /\s+/, $F2[0])[-1];
            notify("    -> last action is $action, result is $result");
        }
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to check_cdb_registry_sqlpatch for $oracle_sid");

    return $tag;
}

