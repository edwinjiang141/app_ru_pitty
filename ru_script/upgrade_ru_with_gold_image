sub check_crs { #2023-10-23 9:26:56 为支持多个节点同时升级，去掉对offline的报错退出
    notify("check_crs","A");
    my ($fd,$tag_global,$tag_for_error) = @_;

    print $fd "\n" if defined $fd;
    print $fd "# check CRS\n" if defined $fd;

    # 检查CRS资源是否有OFFLINE
    my $get_crsctl_status_res_t = get_crsctl_status_res_t();
    my $tag_crs_status = "ok";
    foreach my $line ( @$get_crsctl_status_res_t ) {
        if ( $line->{resource_name} =~ m/ora.asmgroup/ ) {
            if ( $line->{node} == 3 and $line->{target} eq "OFFLINE" ) {
                my $msg;
                if ( not defined $tag_for_error ) {
                    $msg = "Note: $line->{resource_name} node number is 3, and target_state is $line->{target}, please use: srvctl modify asm -count 2";
                }
                else {
                    $msg = "Note: $line->{resource_name} node number is 3, and target_state is $line->{target}, please use: srvctl modify asm -count 2";
                    print $error_fd "$msg\n";
                }
                print $fd "    # $msg\n" if defined $fd;
                $tag_global = "error" if defined $tag_global;
                notify("    $msg","A");
                $tag_crs_status = "error";
            }
        }
        if ( $line->{target} eq "ONLINE" and $line->{state} ne "ONLINE" ) {
            next if $line->{resource_name} =~ m/ASMNET1LSNR_ASM/;   # 忽略 ora.ASMNET1LSNR_ASM.lsnr
            next if $line->{resource_name} =~ m/ora.asmgroup/ and $line->{node} == 3;   # 忽略 ora.asmgroup
            # ora.asm(ora.asmgroup)
            #       1        ONLINE  ONLINE       db19ce01                 Started,STABLE
            #       2        ONLINE  ONLINE       db19ce02                 Started,STABLE
            #       3        OFFLINE OFFLINE                               STABLE

            my $msg;
            if ( not defined $tag_for_error ) {
                $msg = "Note: $line->{resource_name} status is $line->{state} but target is $line->{target}";
            }
            else {
                $msg = "Error!  $line->{resource_name} status is $line->{state} but target is $line->{target}";
                print $error_fd "$msg\n";
            }
            print $fd "    # $msg\n" if defined $fd;
            $tag_global = "error" if defined $tag_global;
            notify("    $msg","A");
            $tag_crs_status = "error";
        }
    }
    if ( $tag_crs_status eq "ok" ) {
        notify("    crsctl status res -t is ok","A");
        print $fd "    # crsctl status res -t is ok\n" if defined $fd;
    }
    else {
        notify("    crsctl status res -t is OFFLINE","A");
        print $fd "    # crsctl status res -t is OFFLINE\n" if defined $fd;
    }

    # 检查OCR
    my $crs_home = get_crs_home();
    my $ocrcheck = $crs_home . "/bin/ocrcheck";
    my $cmd = "$ocrcheck";
    my $result = execute_cmd($cmd);
    # $result: [
    #            'Status of Oracle Cluster Registry is as follows :',
    #            'Version                  :          4',
    #            'Total space (kbytes)     :     409568',
    #            'Used space (kbytes)      :       2472',
    #            'Available space (kbytes) :     407096',
    #            'ID                       :  903862678',
    #            'Device/File Name         :       +CRS',
    #            'Device/File integrity check succeeded',
    #            'Device/File not configured',
    #            'Device/File not configured',
    #            'Device/File not configured',
    #            'Device/File not configured',
    #            'Cluster registry integrity check succeeded',
    #            'Logical corruption check succeeded'
    #          ]
    my $tag_ocr;
    foreach my $line ( @$result ) {
        $tag_ocr->{file_integrity} = "ok" if $line =~ m/Device\/File integrity check succeeded/;
        $tag_ocr->{cluster_registry_integrity} = "ok" if $line =~ m/Cluster registry integrity check succeeded/;
        $tag_ocr->{logical_corruption_check} = "ok" if $line =~ m/Logical corruption check succeeded/;
    }
    ### $tag_ocr
    if ( defined $tag_ocr->{file_integrity} and defined $tag_ocr->{cluster_registry_integrity} and defined $tag_ocr->{logical_corruption_check} ) {
        notify("    OCR is ok","A");
        print $fd "    # OCR is ok\n" if defined $fd;
    }
    else {
        my $msg = "Error!  ocrcheck is failed";
        print $error_fd "$msg\n";
        print $fd "    # $msg\n" if defined $fd;
        $tag_global = "error" if defined $tag_global;
        notify("    $msg","A");
    }
    # 检查OLR
    $cmd = "$ocrcheck -local";
    $result = execute_cmd($cmd);
    ### $result
    my $tag_olr;
    foreach my $line ( @$result ) {
        $tag_olr->{file_integrity} = "ok" if $line =~ m/Device\/File integrity check succeeded/;
        $tag_olr->{cluster_registry_integrity} = "ok" if $line =~ m/Local registry integrity check succeeded/;
        $tag_olr->{logical_corruption_check} = "ok" if $line =~ m/Logical corruption check succeeded/;
    }
    # $result: [
    #            'Status of Oracle Local Registry is as follows :',
    #            'Version                  :          4',
    #            'Total space (kbytes)     :     409568',
    #            'Used space (kbytes)      :       1152',
    #            'Available space (kbytes) :     408416',
    #            'ID                       : 2066724704',
    #            'Device/File Name         : /u01/app/12c/grid/cdata/rac12c01.olr',
    #            'Device/File integrity check succeeded',
    #            'Local registry integrity check succeeded',
    #            'Logical corruption check succeeded'
    #          ]

    if ( defined $tag_olr->{file_integrity} and defined $tag_olr->{cluster_registry_integrity} and defined $tag_olr->{logical_corruption_check} ) {
        notify("    OLR is ok","A");
        print $fd "    # OLR is ok\n" if defined $fd;
    }
    else {
        my $msg = "Error!  OLR check is failed";
        print $error_fd "$msg\n";
        print $fd "    # $msg\n" if defined $fd;
        $tag_global = "error" if defined $tag_global;
        notify("    $msg","A");
    }
    # 检查VOTING DISK
    my $crsctl = $crs_home . "/bin/crsctl";
    $cmd = "$crsctl query css votedisk";
    $result = execute_cmd($cmd);
    ### $result
    my $tag_voting_disk = "ok";
    foreach my $line ( @$result ) {
        if ( $line =~ m/^\d+\./ ) {   #  1. ONLINE   40345e34852f4f61bfd031421ed653d3 (/dev/asmdisk/crs_disk_1) [CRS]
        ### $line
            $tag_voting_disk = "error" if $line !~ m/ONLINE/;
        }
    }
    if ( $tag_voting_disk eq "ok" ) {
        notify("    voting disk is ok","A");
        print $fd "    # voting disk is ok\n" if defined $fd;
    }
    else {
        my $msg = "Error!  voting disk check is failed";
        print $error_fd "$msg\n";
        print $fd "    # $msg\n" if defined $fd;
        $tag_global = "error" if defined $tag_global;
        notify("    $msg","A");
    }

    return $tag_global if defined $tag_global;
}

