    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    if ( $oracle_home ne "/u01/app/product/19.0.0/db_1" ) {
        my $msg = "Error!  oracle_home must be /u01/app/product/19.0.0/db_1";
        notify( "$msg");
        print $error_fd "$msg\n";
        print $fd "    # $msg\n";
    }

}

sub unzip_check_for_nbcb {      # 此过程暂时没有使用 因此没有做$env_type的判断
    #   要求target_gi_home和db_home 与原有的gi_home/db_home 的基本路径保持一致
