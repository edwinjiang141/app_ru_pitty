sub restart_crs {
    notify("restart_crs",'A');
    my $time_start = time();

    # 重新取得oracle_home
    my $oracle_home = get_oracle_home_with_echo("$grid_user");
    my $crsctl = catfile($oracle_home,"bin/crsctl");
    my $cmd;
    $cmd = "$crsctl stop crs" if $env_type eq "crs";
    $cmd = "$crsctl stop has" if $env_type eq "has";
    notify("    cmd is $cmd");
    system($cmd);
    $cmd = "$crsctl start crs -wait" if $env_type eq "crs";
    $cmd = "$crsctl start has -wait" if $env_type eq "has";
    notify("    cmd is $cmd");
    system($cmd);
    sleep 30;

    # 检查ASM进程
    # 重试5次，每次30秒
    my $asm_status;
    for ( my $i=1; $i <= 5; $i++ ) {
        $asm_status = check_asm_process();
        last if $asm_status eq "asm_is_running";
        notify("retry $i",'A');
        sleep 30;
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task restart_crs");
}

sub check_asm_process {
    notify("check_asm_process",'A');
    # 检查ASM进程
    my $cmd = "ps -ef|grep dbw0|grep ASM|grep -v grep";
    my $result = execute_cmd($cmd);
    if ( not defined $result->[0] ) {
        # 当前节点没有ASM进程
        # 有可能是 flex asm 检查 ASM ONLINE 的数量
        # 判断标准 节点数量大于3个 ASM实例大于或等于3个
        my $crs_home = get_crs_home();
        my $olsnodes = catfile($crs_home,"bin/olsnodes");
        notify("    olsnodes is $olsnodes");
        my @nodes = `$olsnodes`;
        my $nodes = scalar(@nodes);

        my $get_crsctl_status_res_t = get_crsctl_status_res_t();
        my $asm_online_nodes = 0;
        foreach my $hash ( @$get_crsctl_status_res_t ) {
            if ( $hash->{resource_name} eq "ora.asm" and $hash->{state} eq "ONLINE" ) {
                $asm_online_nodes ++;
            }
        }
        if ( $asm_online_nodes >= 3 and $nodes > 3 ) {
            notify("ASM is running , at other node");
            return("asm_is_running");
        }
        else {
            notify("ASM is not running");
            return("asm_is_not_running");
        }
    }
    else {
        notify("ASM is running");
        return("asm_is_running");
    }
}

