sub start_instance_all {
    my ($input_oracle_home) = @_;
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    # 得到DB清单
    notify("start_instance_all",'A');
    my $time_start = time();

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        # 检查ASM进程
        my $asm_status = check_asm_process();
        if ( $asm_status eq "asm_is_not_running" ) {
            notify("Error!  asm is not running");
            exit 1;
        }
    }

    my $db_name_and_sid_list = get_db_list();
    my @pids;
    # 有两种 fork 记录文件：
    #   fork_for_start_sid                  ->  是fork的标志文件，每个子进程生成一个标志文件，表示fork for a sid 开始工作
    #   start_instance_result_for_a_sid     ->  记录启动此实例的结果

    if ( defined $input->{sid_list} ) {
        my $sid_list = $input->{sid_list};
        my @sid = split /,/, $sid_list;
        foreach my $sid ( @sid ) {
            my $db_name = get_db_name_from_sid($sid,$target_oracle_home);
            my $hash;
            $hash->{db_name} = $db_name;
            $hash->{oracle_sid} = $sid;
            push @$db_name_and_sid_list, { %$hash };
        }
    }
    else {
        $db_name_and_sid_list = get_db_list($oracle_home);
    }

    notify("clear start instance result file for fork");
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        my $fork_file = catfile("/tmp","fork_for_start_sid_$oracle_sid");
        notify("do unlink $fork_file");
        unlink $fork_file if -e $fork_file;

        # 清理 start for sid 的结果标记
        # /tmp/start_result_for_sid
        my $start_result_for_sid = "/tmp/start_instance_result_for_" . $oracle_sid;
        notify("do unlink $start_result_for_sid");
        unlink $start_result_for_sid if -e $start_result_for_sid;
    }

    # ========================
    # 并行执行 start_instance()
    # ========================
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name,$oracle_home);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name,$oracle_home);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }
        # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
        if ( $db_type eq "rac" ) {
            my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home);
            if ( $local_node_can_start_rac_db eq "no" ) {
                notify("local node can not start rac db $db_name, so skip it");
                next;
            }
        }

        my $pid = fork();
        my $fork_file = catfile("/tmp","fork_for_start_sid_$oracle_sid");
        my $start_result_for_sid = "/tmp/start_instance_result_for_" . $oracle_sid;

        if ( not defined $pid ) {
            notify("Error!  start $oracle_sid in fork is error! $!");
            next;
        }
        elsif ($pid == 0) {
            # 子进程执行
            notify("this is fork process, for start instance, sid: $oracle_sid");
            notify("9704 pid is $pid");
            notify("9704 fork_file is $fork_file");
            start_instance_fork($db_name_and_sid,$oracle_home,$pid,$fork_file,$start_result_for_sid);
            exit 0;
        }
        else {
            # 父进程记录 PID
            notify("9710 pid is $pid");
            push @pids, $pid;
        }
    }


    # ========================
    # 等待所有子进程完成
    # ========================
    foreach my $pid (@pids) {
        waitpid($pid, 0);
    }

    my ($start_done_sid,$start_skipped_sid,$start_error_sid);
    # 检查结果文件 区分ok/skip/error
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        # 此处检查每个SID的结果文件
        my $start_result_for_sid = "/tmp/start_instance_result_for_" . $oracle_sid;
        notify("check start_result_for_sid $start_result_for_sid");
        my @result = get_all_line($start_result_for_sid);
        if ( grep { /ok/ } @result ) {
            notify("start $oracle_sid is ok");
            push @$start_done_sid, $oracle_sid;
        }
        elsif ( grep {/skip/ } @result ) {
            notify("start $oracle_sid is skipped");
            push @$start_skipped_sid, $oracle_sid;
        }
        elsif ( grep {/error/ } @result ) {
            notify("Error!  start $oracle_sid is error!");
            print $error_fd "Error!  start $oracle_sid is error!\n";
            push @$start_error_sid, $oracle_sid;
        }
    }

    notify("*** start instances result");
    foreach my $oracle_sid ( @$start_done_sid ) {
        notify("\t sid $oracle_sid \t startup is done");
    }
    foreach my $oracle_sid ( @$start_skipped_sid ) {
        notify("\t sid $oracle_sid \t startup is skipped");
    }
    foreach my $oracle_sid ( @$start_error_sid ) {
        notify("\t Error!  sid $oracle_sid \t startup has error, please check!");
        print $error_fd "Error!  sid $oracle_sid startup has error, please check!\n";
    }

    # 如果有启动实例失败，就退出
    if ( defined $start_error_sid->[0] ) {
        notify("Error! some sid startup is error, please check!");
        exit 1;
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task start_instance_all");

}

