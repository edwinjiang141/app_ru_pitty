sub get_open_mode_using_sqlplus {
    my ($oracle_sid,$input_oracle_home) = @_;

    notify("    get_open_mode_using_sqlplus for $oracle_sid",'N');
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    #返回值有   NOMOUNT/MOUNTED/READ WRITE/READ ONLY/READ ONLY WITH APPLY
    #           UNKNOW_ERROR/NO_INSTANCE
    #检查是否有与SID匹配的数据库实例的进程
    my @cmd = `ps -ef|grep 'ora_pmon_$oracle_sid\$'|grep -v grep`;
    if ( defined $cmd[0] ) {
        chomp($cmd[0]);
        my ($sid) = $cmd[0] =~ m/ora_pmon_(.*)$/;
        notify("    ORACLE_SID $oracle_sid match pmon, querying OPEN_MODE",'N');

        my $sql;
        push @$sql, "SELECT OPEN_MODE FROM V\$DATABASE;";
        $result = do_sql_oracle($sql,$oracle_sid,$oracle_home,"not_display");

        my $return = "ok";
        notify("    get_open_mode_using_sqlplus for $oracle_sid result is:",'N');
        foreach my $line ( @$result ) {
            notify("        $line",'N');
        }

        #OPEN_MODE
        #--------------------
        #READ ONLY WITH APPLY
        #Elapsed: 00:00:00.01
        #ORA-01507: database not mounted

        my @open_mode;
        foreach my $line ( @$result ) {
            chomp($line);
            next if $line =~ m/OPEN_MODE/;
            next if $line =~ m/--/;
            next if $line =~ m/\*/;
            next if $line =~ m/ERROR/;
            next if $line =~ m/Elapsed/;
            $line =~ s/^\s+|\s+$//g;
            push @open_mode, $line;
        }

        my $open_mode;
        if ( not defined $open_mode[1] ) {
            $open_mode = $open_mode[0];
            if ( $open_mode =~ m/database not mounted/ ) {
                $open_mode = "nomount";
            }
        }
        else {
            $open_mode = "UNKNOW_ERROR";
        }

