sub get_group_for_oracle {
    my ($cmd,$result,$id_for_oracle,$id_for_grid);
    notify("    get $oracle_user group list","A");

    $cmd = "id $oracle_user";
    $id_for_oracle = execute_cmd($cmd);
    ### $id_for_oracle
    my @F = split /\s+/, $id_for_oracle->[0];
    shift @F;
    foreach my $str ( @F ) {
        ### $str
        if ( $str =~ m/gid/ ) {
            my ($group) = $str =~ m/\((\w*)\)/;
            ### $group
            push @$group_for_oracle, $group;
        }
        elsif ( $str =~ m/groups/ ) {
            my @F2 = split /,/, $str;
            my $idx = 0;
            foreach my $str2 ( @F2 ) {
                my ($group) = $str2 =~ m/\((\w*)\)/;
                ### $group
                push @$group_for_oracle, $group;
                $second_group_for_oracle = $group if $idx == 1;
                $idx ++;
            }
        }
    }
    $group_for_oracle = list_uniq($group_for_oracle);
    ### $group_for_oracle

    $str_group_for_oracle = join(",",@$group_for_oracle);
    notify("        str_group_for_oracle is $str_group_for_oracle","A");
    notify("        second_group_for_oracle is $second_group_for_oracle","A");
}

