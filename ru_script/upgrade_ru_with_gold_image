sub step_03_switch_grid_home {
    $step_name = "step_03_switch_grid_home";

    return if $env_type ne "crs";

    notify("*** starting switch grid home",'A');
    my $time_start = time();
    my $old_grid_home = get_oracle_home_with_echo($grid_user);

    if ( not defined $input->{rootsh_is_failed_at_step_03} ) {
        recored_opatch_lspatches("$grid_user","old",$grid_home);
        record_service_status();

        my $db_name_and_sid = get_db_list();
        foreach my $db_name_and_sid ( @$db_name_and_sid ) {
            my $db_name = $db_name_and_sid->{db_name};
            my $oracle_sid = $db_name_and_sid->{oracle_sid};

            # 如果是RAC ONE NODE，要先检查本地是否启动了实例
            my $db_type = get_srvctl_database_type($db_name);
            my $srvctl_instance_status = get_local_srvctl_instance_status($db_name);
            if ( $db_type eq "rac_one_node" ) {
                next if $srvctl_instance_status ne "running_at_local";
            }
            # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
            if ( $db_type eq "rac" ) {
                my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name);
                if ( $local_node_can_start_rac_db eq "no" ) {
                    notify("local node can not start rac db $db_name, so skip it");
                    next;
                }
            }

            select_invalid_object($oracle_sid);                 # 记录无效对象

            # 记录每个PDB的状态，如果指定了 --save_pdb_open_mode
            if ( defined $input->{save_pdb_open_mode} ) {
                my $sql;
                push @$sql, "ALTER PLUGGABLE DATABASE ALL SAVE STATE;";
                $result = do_sql_oracle($sql,$oracle_sid,$oracle_home,"display");
            }
        }

        # 将scan-ip切换到对方节点
        relocate_scan_ip();

        # 停止所有DB实例
        # 两种做法
        # 1是先取得sid列表，然后挨个停止sid
        # 2是直接srvctl stop instace -node -f 停止所有实例
        # 此处采取第1种方法
        stop_instance_all();

        copy_listener_ora_to_new_gridhome($target_grid_home,$target_oracle_home);        # 复制后修改listener.ora里面的ORACLE_HOME路径
        copy_sqlnet_to_new_gridhome($target_grid_home);
        copy_tnsnames_ora_to_new_gridhome($target_grid_home);

        switch_grid_home_local($target_grid_home);      # 此步骤执行root.sh
    }

    update_etc_oracle_olr_loc($target_grid_home);

    if ( -e "/etc/oratab.ru" ) {
        replace_oracle_home_for_a_file("/etc/oratab.ru",$old_grid_home,$target_grid_home);
        copy("/etc/oratab.ru","/etc/oratab");
    }
    modify_root_profile();
    modify_grid_profile();
    modify_grid_rootconfig();   # MOVE_HOME=true->false

    # 修改crontab里面包含grid_home的内容 (root/grid)
    my @user_list;
    push @user_list, "root";
    push @user_list, $grid_user;
    foreach my $user ( @user_list ) {
        replace_oracle_home_for_crontab($user,$old_grid_home,$target_grid_home);
    }

    recored_opatch_lspatches("$grid_user","new",$target_grid_home);
    compare_opatch_lspatches($grid_user);

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task step_03_switch_grid_home");
}


