            }
        }
    }

    my $oracle_home_for_db = get_oracle_home_with_echo("$oracle_user");
    my $opatch_for_db = catfile($oracle_home_for_db,"OPatch/opatch");
    my $patch_lspatches_for_db = $opatch_for_db . " lspatches";

    my $patch_lspatches_for_db_cmd = "su - $oracle_user -c '$patch_lspatches_for_db' 1>$cmd_log 2>$error_log";
    notify("    cmd is $patch_lspatches_for_db_cmd",'A');
    system($patch_lspatches_for_db_cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    foreach my $line ( @$result1 ) {    # 29585399;OCW RELEASE UPDATE 19.3.0.0.0 (29585399)
        my @tmp = split /;/, $line;     # $tmp[0] 是补丁号
        next if not defined $tmp[1];
        my $patch_number = $tmp[0];
        my $patch_name = lc ( (split /\s+/, $tmp[1])[0] );
        # oracle 用户执行补丁确认
        notify("    opatch lspatches verify for oracle, patch_number: $patch_number, patch_name: $patch_name",'A');
        if ( $patch_name eq "database" or $patch_name eq "ocw" ) {
            $patch_verify_result->{$oracle_user}->{$patch_name} = "ok";
        }
        else {
            $patch_verify_result->{$oracle_user}->{$patch_name} = do_opatch_lspatches_verify($oracle_user,$opatch_for_db,$patch_number);
        }
    }

    ### $patch_verify_result

    foreach my $username ( sort keys %$patch_verify_result ) {
        foreach my $patch_name ( sort keys %{ $patch_verify_result->{$username} } ) {
            my $check_result = $patch_verify_result->{$username}->{$patch_name};
            notify("opatch lspatches verify for $username $patch_name is $check_result",'A');
            if ( $check_result eq "ok" ) {
                my $msg = "opatch lspatches verify for $username $patch_name is passed";
                notify("$msg");
            }
            elsif ( $check_result eq "skip" ) {
                my $msg = "opatch lspatches verify for $username $patch_name is skipped";
                notify("$msg");
            }
            else {
                if ( $patch_name eq "database" or $patch_name eq "ocw" ) {        # opatch lspatches verify 不支持 DBRU/OCWRU
                    my $msg = "opatch lspatches verify for $username $patch_name is ignore";
                    notify("$msg");
                }
                else {
                    my $msg = "Error!  opatch lspatches verify for $username $patch_name is wrong";
                    print $error_fd "$msg\n";
                    notify("$msg");
                    $tag_local = "error_for_opatch_lspatches_verify_from_lspatches";
                    print $fd "    # $msg\n" if defined $fd;
                }
            }
        }
    }

    return($tag_local);
}

sub do_drop_restore_point {
    my ($restore_point_name,$oracle_sid,$input_oracle_home) = @_;
    notify("    do_drop_restore_point for sid $oracle_sid");
    my $time1 = time();
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    my $sql;
    push @$sql, "DROP RESTORE POINT $restore_point_name;";
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

    my $return = "ok";
    foreach my $line ( @$result ) {
        notify("    $line",'A');
        if ( $line =~ /^ORA-/ ) {
            $return = 'error';
        }
    }

    if ( $return eq 'error' ) {
