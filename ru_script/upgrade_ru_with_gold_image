    notify("*** starting do_datapatch_with_ojvm for $db_name",'A');
    my $time_start = time();

    # 启动对方实例（更新srvctl状态）
    start_database_using_srvctl($db_name_and_sid,$oracle_home);

    # 停止DB
    stop_database_using_srvctl($db_name_and_sid,$oracle_home);

    # startup nomount
    startup_instance_to_nomount($oracle_sid,$oracle_home);

    # CLUSTER_DATABASE=FALSE
    modify_cluster_true_or_false($oracle_sid,"no",$oracle_home) if $env_type eq "crs";

    # SHUTDOWN
    stop_instance($db_name_and_sid,$oracle_home);

    # STARTUP UPGRADE
    startup_instance_to_open_upgrade($oracle_sid,$oracle_home);

    # ALTER PLUGGABLE DATABASE ALL OPEN UPGRADE
    open_pdb_upgrade($oracle_sid,$oracle_home);

    # datapatch -verbose
    my $status;
    for ( my $i=1; $i <= 3; $i++ ) {
        $status = do_datapatch($oracle_sid,$i); # 2025-03-10 10:39:58
        last if $status eq "ok";
        if ( $i == 3 ) {
            my $msg = "Error!  datapatch for $oracle_sid has error";
            notify("$msg");
            print $error_fd "$msg\n";
            push @$datapatch_error_sid, $oracle_sid;
        }
    }

    if ( $status eq "ok" ) {
        push @$datapatch_done_sid, $oracle_sid;
    }
    elsif ( $status eq "failed" ) {
        push @$datapatch_error_sid, $oracle_sid;
    }

    # CLUSTER_DATABASE=TRUE
    modify_cluster_true_or_false($oracle_sid,"yes",$oracle_home) if $env_type eq "crs";

    # SHUTDOWN
    stop_instance($db_name_and_sid,$oracle_home);

    # 启动本节点的实例，打开所有PDB
    start_instance($db_name_and_sid,$oracle_home);

