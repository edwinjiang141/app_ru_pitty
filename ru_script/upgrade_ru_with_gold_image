sub compare_opatch_lspatches {
    my ($user) = @_;
    notify("*** compare_opatch_lspatches for $user",'A');

    my ($opatch_log_file_old,$opatch_log_file_new);
    $opatch_log_file_old = "opatch_lspatches_" . $user . "_old";
    $opatch_log_file_new = "opatch_lspatches_" . $user . "_new";
    my $lspatches_file_old = catfile($log_dir,$opatch_log_file_old);
    my $lspatches_file_new = catfile($log_dir,$opatch_log_file_new);
    my @lspatches_old = get_all_line($lspatches_file_old);
    my @lspatches_new = get_all_line($lspatches_file_new);
    my $lspatches;
    foreach my $line ( @lspatches_old ) {
        next if $line !~ m/^\d/;
        notify("$line","N");
        my @tmp = split /;/, $line;
        next if not defined $tmp[1];
        my $name = lc ( (split /\s+/, $tmp[1])[0] );
        my $version;
        ($version) = $tmp[1] =~ m/\s+(\d\d\.\d+\.\d+\.\d+\.\d+)[\s+|\(]/;
        # ocw 可能没有版本号
        if ( not defined $version and $name eq "ocw" ) {
            $version = "19"
        }
        notify("version not matched: $tmp[1]",'A') if not defined $version;
        $version = "19.0.0" if not defined $version;
        notify("$name version: $version",'A') if defined $version;
        $lspatches->{old}->{$name} = $version;
    }
    foreach my $line ( @lspatches_new ) {
        next if $line !~ m/^\d/;
        notify("$line","N");
        my @tmp = split /;/, $line;
        next if not defined $tmp[1];
        my $name = lc ( (split /\s+/, $tmp[1])[0] );
        my $version;
        ($version) = $tmp[1] =~ m/\s+(\d\d\.\d+\.\d+\.\d+\.\d+)[\s+|\(]/;
        # ocw 可能没有版本号
        if ( not defined $version and $name eq "ocw" ) {
            $version = "19"
        }
        notify("version not matched: $tmp[1]",'A') if not defined $version;
        $version = "19.0.0" if not defined $version;
        notify("$name version: $version",'A') if defined $version;
        $lspatches->{new}->{$name} = $version;
    }

    foreach my $patch_name ( sort keys %{ $lspatches->{old} } ) {
        next if not defined $lspatches->{new}->{$patch_name};
        my $old_version = $lspatches->{old}->{$patch_name};
        my $new_version = $lspatches->{new}->{$patch_name};
        notify("patch $patch_name old version: $old_version",'A');
        notify("patch $patch_name new version: $new_version",'A');
        if ( $old_version eq $new_version ) {
            next if $patch_name eq "tomcat";
            next if $patch_name eq "dbwlm";
            my $msg = "the old and new version of $patch_name is same.";
            notify("$msg",'A');
        }
    }
}

