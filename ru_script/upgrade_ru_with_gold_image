    notify("datapatch will skip CLUSTER=false",'A') if $ojvm eq "no";
    # notify("Warning! datapatch will be cluster=false because OJVM is used",'A') if $ojvm eq "yes";

    print_error("not_exit");

    my $time_stop = time();
