    my ($username,$opatch,$patch_number) = @_;
    notify("        do_opatch_lspatches_verify for $username , patch_number $patch_number",'A');
    # opatch lspatches -id 31668882 -verify
    my $opatch_cmd = $opatch . " lspatches -id " . $patch_number . " -verify";
    my $cmd = "su - $username -c '$opatch_cmd' 1>$cmd_log 2>$error_log";
    notify("        cmd is $cmd",'A');
    system($cmd);
    # ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display_log");
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    my $result = "error";
    $result = "error" if defined $result2->[0];
    $result = "ok" if grep { /Inventory check OK: Patch ID $patch_number/ } @$result1;
    $result = "skip" if grep { /Skip verifying patch files/ } @$result1;
    print_cmd_log($cmd_log,$error_log) if $result ne "ok";
    return $result;
}


sub find_oracle_home_for_switch_back {
    notify("find_oracle_home_for_switch_back",'A');
    my ($username) = @_;
    # 对于目录，从以下两个位置去找
    # 现有生效的目录，从profile里面取得
    # 原来的目录，从备份的profile里面取得
    my $oracle_home_after_switch = get_oracle_home_with_echo("$username");

    # 找出最新的备份，还原
    # 取得$HOME路径
    my $cmd = "su - $username -c 'echo \$HOME'";
    my $result = execute_cmd($cmd);
    my $home = $result->[0];
    notify("    home for $username is $home",'A');
    $cmd = "ls -alt $home/.*backup_for_RU_upgrade* 2>/dev/null";
    $result = execute_cmd($cmd);
    if ( not defined $result->[0] ) {
        notify("Error!  backup profile for $username is not find");
        exit 1;
    }
    my $last_backup_profile = (split /\s+/, $result->[0])[-1];
    my @result = get_all_line($last_backup_profile);
    my $oracle_home_before_switch;
    foreach my $line ( @result ) {
        next if $line =~ m/^\s*#/;
        next if $line !~ m/\bORACLE_HOME\s*=/;
        notify("    $line");
        my @F = split /=/, $line;
        # 它有可能是把export写在后面，所以这里可能会有;号
        my @F2 = split /;/, $F[1];
        $oracle_home_before_switch = $F2[0];
    }
    # 如果有空值，报错，如果两个HOME相同，也报错
    if ( not defined $oracle_home_before_switch ) {
        notify("Error!  can not find ORACLE_HOME from backup profile.");
        exit 1;
    }
    # 可能会包含 $ORACLE_BASE，需要echo一下
    notify("    oracle_home_before_switch before echo is $oracle_home_before_switch for $username");
    notify("    oracle_home_after_switch  before echo is $oracle_home_after_switch for $username");
    $cmd = "su - $username -c 'echo $oracle_home_before_switch'";
    $result = execute_cmd($cmd);
    $oracle_home_before_switch = $result->[0];
    $cmd = "su - $username -c 'echo $oracle_home_after_switch'";
    $result = execute_cmd($cmd);
    $oracle_home_after_switch = $result->[0];
    notify("    oracle_home_before_switch after echo is $oracle_home_before_switch for $username");
    notify("    oracle_home_after_switch  after echo is $oracle_home_after_switch for $username");
    if ( $oracle_home_before_switch eq $oracle_home_after_switch ) {
        notify("Error!  oracle_home_before_switch = oracle_home_after_switch for $username");
        exit 1;
    }

    return ($oracle_home_before_switch,$oracle_home_after_switch);
}

sub detach_a_db_home_using_edit {
    my ($db_home_path) = @_;
    notify("detach_a_db_home_using_edit for $db_home_path",'A');
    my $time1 = time();

    # 查找inventory，取得ORACLE_HOME名称
    my $inventory_xml = catfile($oraInventory,"ContentsXML/inventory.xml");
    if ( !-e $inventory_xml ) {
        notify("Error!  $inventory_xml does not exist");
        exit 1;
    }

    # 修改inventory.xml 去掉NODE_LIST
    grep_node_list_from_inventory($inventory_xml);

    my @result = get_all_line($inventory_xml);
    notify("    inventory file before detach: $inventory_xml",'A');
    # 检查是否有NODE_LIST
    my $tag = "ok";
    foreach my $line ( @result ) {
        notify("        $line");
        if ( $line =~ m/NODE_LIST/ ) {
            notify("Error!  inventory contents has NODE_LIST, please check!");
            $tag = "error";
        }
    }
    exit 1 if $tag eq "error";

    my $db_home_name;
    foreach my $line ( @result ) {
        my ($home_path) = $line =~ m/LOC=\"(.*?)\"\s+/;
        next if not defined $home_path;
        my ($home_name) = $line =~ m/HOME NAME=\"(.*?)\"\s+/;
        next if not defined $home_name;
        $db_home_name = $home_name if $home_path eq $db_home_path;
    }
    if ( not defined $db_home_name ) {
        notify("Warning! can not find $db_home_path in $inventory_xml");
        return("not_detach");
    }
    notify("    db_home_name is $db_home_name",'A');
    notify("    db_home_path is $db_home_path",'A');

    # 手动修改inventory，去掉目标行
    # 1.生成一个备份文件
    my $inventory_xml_backup_name = "inventory.xml" . ".backup_before_detach." . get_locatime_for_file();
    my $inventory_xml_backup_path = catfile($oraInventory,"ContentsXML/$inventory_xml_backup_name");

    notify("    copy $inventory_xml to $inventory_xml_backup_path",'A');
    copy($inventory_xml,$inventory_xml_backup_path);
    if ( !-e $inventory_xml_backup_path ) {
        notify("Error!  copy $inventory_xml to $inventory_xml_backup_path is failed !",'A');
        exit 1;
    }

    # 2.授权给grid:oinstall
    $cmd = "chown $grid_user:$group_for_oinstall $inventory_xml_backup_path" if $env_type eq "crs" or $env_type eq "has";
    $cmd = "chown $oracle_user:$group_for_oinstall $inventory_xml_backup_path" if $env_type eq "fs";
    notify("    $cmd",'A');
    system($cmd);

    my @inventory_content_old = get_all_line($inventory_xml);
    my @inventory_content_new;
    # 2.去掉旧OH
    foreach my $line ( @inventory_content_old ) {
        my $new_line = $line;
        my ($home_path) = $line =~ m/LOC=\"(.*?)\"\s+/;
        if ( defined $home_path and $home_path eq $db_home_path ) {    # 此行删除，注释是错误的
            # $new_line =~ s/^/# /;
            notify("    old OH will be deleted: $new_line",'A');
        }
        else {
            push @inventory_content_new, $new_line;
        }
    }
    ### @inventory_content_old
    ### @inventory_content_new

    # 4.写入新文件
    notify("    rewrite $inventory_xml",'A');
    open myFile , "> $inventory_xml";
    foreach my $a ( @inventory_content_new ) {
        print myFile "$a\n";
    }
    close myFile;
    notify("    write $inventory_xml done",'A');

    # 再次检查inventory 标准是 $db_home_path不能再存在
    @result = get_all_line($inventory_xml);
    notify("    inventory file after detach: $inventory_xml",'A');
    foreach my $line ( @result ) {
        notify("        $line");
    }

    my $tag01_edit_error = "no";
    foreach my $line ( @result ) {
        my ($home_path) = $line =~ m/LOC=\"(.*?)\"\s+/;
        next if not defined $home_path;
        my ($home_name) = $line =~ m/HOME NAME=\"(.*?)\"\s+/;
        next if not defined $home_name;
        $tag01_edit_error = "yes" if $home_path eq $db_home_path;        # 如果是由edit过程修改，那么出现这一行就是错误的
    }
    if ( $tag01_edit_error eq "yes" ) {
        notify("Error!  detach $db_home_path error.");
        exit 1;
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("    time: $time_diff seconds to detach $db_home_path");
    return("detach");
}

