sub check_backup_file_for_ru {
    notify("check_backup_file_for_ru","A");
    my ($fd,$tag_local) = @_;
    $tag_local = "do_not_print_file" if not defined $tag_local;

    print $fd "\n" if defined $fd;
    print $fd "# check backup file for ru\n" if defined $fd;

    # 检查指定的备份文件是否存在，如果存在，就提示删除，这些是上一次RU升级时留下的备份文件，会影响这一次RU升级
    # 取得$HOME路径
    my ($backup_file_list,$cmd,$result,$home);

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        $cmd = "su - $grid_user -c 'echo \$HOME'";
        $result = execute_cmd($cmd);
        $home = $result->[0];
        notify("    home for $grid_user is $home",'A');
        $cmd = "ls -alt $home/.*backup_for_RU_upgrade* 2>/dev/null";
        $result = execute_cmd($cmd);
        ### $result
        foreach my $line ( @$result ) {
            my @F = split /\s+/, $line;
            push @$backup_file_list, $F[-1];    # 2025-01-10 10:06:33 重新加进删除列表
        }
        $cmd = "ls -alt $home/.*backup_before_rollback* 2>/dev/null";
        $result = execute_cmd($cmd);
        ### $result
        foreach my $line ( @$result ) {
            my @F = split /\s+/, $line;
            push @$backup_file_list, $F[-1];    # 2025-01-10 10:06:33 加入对 backup_before_rollback 文件的删除
        }
    }

    $cmd = "su - $oracle_user -c 'echo \$HOME'";
    $result = execute_cmd($cmd);
    $home = $result->[0];
    notify("    home for $oracle_user is $home",'A');
    $cmd = "ls -alt $home/.*backup_for_RU_upgrade* 2>/dev/null";
    $result = execute_cmd($cmd);
    ### $result
    foreach my $line ( @$result ) {
        my @F = split /\s+/, $line;
        push @$backup_file_list, $F[-1];    # 2025-01-10 10:06:33 重新加进删除列表
    }
    $cmd = "ls -alt $home/.*backup_before_rollback* 2>/dev/null";
    $result = execute_cmd($cmd);
    ### $result
    foreach my $line ( @$result ) {
        my @F = split /\s+/, $line;
        push @$backup_file_list, $F[-1];    # 2025-01-10 10:06:33 加入对 backup_before_rollback 文件的删除
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        $cmd = "su - $grid_user -c 'echo \$ORACLE_HOME'";
        $result = execute_cmd($cmd);
        my $grid_home = $result->[0];
        notify("    grid_home for $grid_user is $grid_home",'A');
        my $grid_home_02 = get_parent_dir_path($grid_home);
        $cmd = "find $grid_home_02 -name '*backup.for.switch_back*'";
        $result = execute_cmd($cmd);
        ### $result
        foreach my $line ( @$result ) {
            chomp($line);
            push @$backup_file_list, $line;
        }
    }

    $cmd = "su - $oracle_user -c 'echo \$ORACLE_HOME'";
    $result = execute_cmd($cmd);
    my $db_home = $result->[0];
    notify("    oracle_home for $oracle_user is $db_home",'A');
    my $db_home_02 = get_parent_dir_path($db_home);
    $cmd = "find $db_home_02 -name '*backup.for.switch_back*'";
    $result = execute_cmd($cmd);
    ### $result
    foreach my $line ( @$result ) {
        chomp($line);
        push @$backup_file_list, $line;
    }

    foreach my $file ( @$backup_file_list ) {
        my $msg = "Error!  OLD backup file : rm -rf $file";
        notify("        $msg");
        print $error_fd "$msg\n";
        print $fd "  # rm -rf $file\n" if defined $fd;
    }

    return $tag_local;
}

