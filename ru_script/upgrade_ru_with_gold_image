sub restore_rsync {
    my ($fd) = @_;
    notify("*** checking and restore /etc/rsyslog.conf","A");

    # 检查是否有rsync配置文件，如果没有，就跳过
    if ( !-e "/etc/rsyslog.conf" ) {
        notify("not find /etc/rsyslog.conf");
        return;
    }

    # 检查是否有rsync配置文件的备份，如果没有，就跳过
    if ( !-e "/etc/rsyslog.conf.backup.for.ru" ) {
        notify("not find /etc/rsyslog.conf.backup.for.ru");
        return;
    }

    # 比较rsync配置文件是否有变动，如果有变动，就从备份中恢复
    my @rsync_config_before = get_all_line("/etc/rsyslog.conf");
    my @rsync_config_after = get_all_line("/etc/rsyslog.conf.backup.for.ru");
    my $tag = "yes";        # 默认假设内容一致
    # 每一行与进行比较，不相同说明内容不一致
    my $idx = 0;
    foreach my $line_of_before ( @rsync_config_before ) {
        if ( not defined $rsync_config_after[$idx] ) {
            $tag = "no";
            last;
        }
        my $line_of_after = $rsync_config_after[$idx];
        $tag = "no" if $line_of_before ne $line_of_after;
        $idx ++;
    }
    if ( $tag ne "yes" ) {
        my $msg = "Warning!  contents of /etc/rsyslog.conf is not consistent with /etc/rsyslog.conf.backup.for.ru";
        notify("$msg");
        # 将现有文件改名 加上时间戳
        my $backup_for_rsync = "/etc/rsyslog.conf." . get_locatime_for_file();
        notify("copy /etc/rsyslog.conf $backup_for_rsync");
        copy("/etc/rsyslog.conf",$backup_for_rsync);
        if ( !-e $backup_for_rsync ) {
            notify("Error!  copy /etc/rsyslog.conf to $backup_for_rsync is failed !",'A');
            exit 1;
        }
        # 恢复备份文件
        notify("copy /etc/rsyslog.conf.backup.for.ru /etc/rsyslog.conf");
        copy("/etc/rsyslog.conf.backup.for.ru","/etc/rsyslog.conf");
    }
    else {
        my $msg = "contents of /etc/rsyslog.conf is consistent with /etc/rsyslog.conf.backup.for.ru";
        notify("$msg");
    }
}

sub check_rsync {
    my ($fd) = @_;
    notify("checking /etc/rsyslog.conf","A");
    print $fd "\n";
    print $fd "# checking /etc/rsyslog.conf\n";
    if ( !-e "/etc/rsyslog.conf" ) {
        my $msg = "Error!  /etc/rsyslog.conf is not exist";
        notify("    $msg");
        print $error_fd "$msg\n";
        print $fd "    # $msg\n";
    }

    my @rsyslog = get_all_line_with_space("/etc/rsyslog.conf");
    my @last_six_lines = @rsyslog[-6..-1];
    # 过滤掉注释行
    my @last_lines = grep { !/^#/ && /\S/ } @last_six_lines;
    ### @last_lines
    # *.err;kern.debug;daemon.notice  /var/adm/messages
    # *.debug @10.99.200.33
    my $pattern1 = qr/^\*\.(err;kern\.debug;daemon\.notice\s+\/var\/adm\/messages)/;
    my $pattern2 = qr/^\*\.(debug\s+\@10\.99\.200\.33)/;

    my $tag = "no";
    foreach my $line (@last_lines) {
        chomp $line;
        ### $line
        unless ($line =~ $pattern1 || $line =~ $pattern2) {
            $tag = "yes";
            notify("    tag_yes:$line");
            ### tag_yes:$line
        }
    }

    if ( $tag eq "yes" ) {
        my $msg = "Error!  /etc/rsyslog.conf is wrong";
        notify("    $msg");
        print $error_fd "$msg\n";
        print $fd "    # $msg\n";
    }
    else {
        my $msg = "/etc/rsyslog.conf is correct";
        notify("    $msg");
        print $fd "    # $msg\n";
    }
}

