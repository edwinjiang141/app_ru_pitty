sub check_parameter_for_restore_point {
    my ($oracle_sid,$fd) = @_;
    notify("*** do check_parameter_for_restore_point");
    print $fd "\n" if defined $fd;
    print $fd "# checking check_parameter_for_restore_point\n" if defined $fd;

    # 检查 log_archive_dest 参数是否有配置归档路径
    # 检查 db_recovery_file_dest 参数是否配置，如果有配置，检查它是否与归档路径相同
    # 以上检查不符合，都报错
    my $log_archive_dest_check = "n/a";
    my $db_recovery_file_dest_check = "n/a";

    my ($archive_destination,$db_recovery_file_dest);
    my $sql;
    push @$sql, "set linesize 140;";
    push @$sql, "column name format a40;";
    push @$sql, "column value format a90;";
    push @$sql, "SELECT name,value from v\$parameter order by name;";
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);
    foreach my $line ( @$result ) {
        next if $line =~ m/state/;
        notify("    $line",'A') if $line =~ m/dest/i;
    }

    foreach my $line01 ( @$result ) {
        $line01 =~ s/^\s+|\s+$//g;
        my @F01 = split /\s+/, $line01;
        my $parameter = $F01[0];
        my $value = $F01[1];

        if ( $parameter =~ m/log_archive_dest/i and defined $value and $value =~ m/LOCATION/i ) {
            my @tmp = split /\s+/, $value;
            # LOCATION=/u01/app/oracle/archive/pdb19c
            $archive_destination = (split /=/, $tmp[0])[1];
            if ( -e $archive_destination ) {
                notify("archive_destination is $archive_destination");
                $log_archive_dest_check = "ok";
            }
            else {
                my $msg = "Error! path for archive_destination is not exists";
                notify("$msg",'A');
                print $fd "    # $msg\n";
                print $error_fd "$msg\n";
            }
        }
    }

    if ( not defined $archive_destination ) {
        my $msg = "Error! archive_destination is not defined, please check log_archive_dest_N";
        notify("$msg",'A');
        print $fd "    # $msg\n";
        print $error_fd "$msg\n";
    }

    foreach my $line01 ( @$result ) {
        $line01 =~ s/^\s+|\s+$//g;
        my @F01 = split /\s+/, $line01;
        my $parameter = $F01[0];
        my $value = $F01[1];

        if ( $parameter eq "db_recovery_file_dest" ) {
            if ( defined $value ) {
                $db_recovery_file_dest = $value;
                if ( -e $db_recovery_file_dest ) {
                    notify("db_recovery_file_dest is $value");
                    if ( $db_recovery_file_dest ne $archive_destination ) {
                        $db_recovery_file_dest_check = "ok";
                    }
                    else { # 与归档路径相同，报错
