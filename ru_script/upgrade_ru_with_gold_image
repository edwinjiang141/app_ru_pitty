sub get_pdb_status {
    my ($oracle_sid,$input_oracle_home) = @_;
    notify("    get_pdb_status for $oracle_sid","N");
    # 检查PDB状态，返回各个pdb的状态，种子PDB除外
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    my $sql;
    push @$sql, "set linesize 140;";
    push @$sql, "column name format a100;";
    push @$sql, "column OPEN_MODE format a10;";
    push @$sql, "select CON_ID,NAME,OPEN_MODE from V\$CONTAINERS;";
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home,"not_display");
        #     CON_ID NAME 												OPEN_MODE
        # ---------- ---------------------------------------------------------------------------------------------------- ----------
        # 	 1 CDB$ROOT												READ WRITE
        # 	 2 PDB$SEED												READ ONLY
        # 	 3 PDB0 												MOUNTED

    my $pdb;

    my @result = @{ $result };
    foreach my $line ( @result ) {
        next if $line =~ m/Elapsed/;
        $line =~ s/^\s+|\s+$//g;
        # notify("$line");
        my @F = split /\s+/,$line;
        my $hash;
        $hash->{con_id} = $F[0];
        $hash->{name} = $F[1];
        if ( defined $F[3] ) {
            $hash->{open_mode} = $F[2] . " " . $F[3];
        }
        else {
            $hash->{open_mode} = $F[2];
        }
        # next if $hash->{name} eq 'CDB$ROOT';
        next if $hash->{name} eq 'PDB$SEED';
        next if $hash->{con_id} == 0;
        push @$pdb, { %$hash };
    }

    return $pdb;
}

sub check_pdb_status_at_precheck {
    my ($fd) = @_;
    notify("    check_pdb_status_at_precheck","A");
    print $fd "\n";
    print $fd "# check_pdb_status_at_precheck\n";

    my $tag = "ok";
    # 对每个DB进行检查
    my $db_name_and_sid_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $oracle_home = get_oracle_home_with_echo("$oracle_user");
        # 检查每个SID的OPEN_MODE
        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $open_mode !~ m/read/i ) {
            my $msg = "Error!  SID $oracle_sid OPEN MODE is $open_mode";
            notify("$msg");
            print $fd "    # $msg\n";
            print $error_fd "$msg\n";
            $tag = "error";
            next;
        }
        my $pdb_status = get_pdb_status($oracle_sid,$oracle_home);

        foreach my $pdb ( @$pdb_status ) {
            my $pdb_name = $pdb->{name};
            my $open_mode = $pdb->{open_mode};
            # if ( $open_mode ne "READ WRITE" ) {
            if ( $open_mode !~ m/read/i ) {
                my $msg = "Error!  SID $oracle_sid PDB $pdb_name open_mode is $open_mode";
                notify("$msg");
                print $fd "    # $msg\n";
                print $error_fd "$msg\n";
                $tag = "error";
            }
        }
    }

    if ( $tag eq "error" ) {
        print $fd "    # Error!  Some PDB open_mode is not READ WRITE\n";
    }
    else {
        notify("        All PDB open_mode is READ WRITE");
        print $fd "    # All PDB open_mode is READ WRITE\n";
    }

}

sub update_timezone {
    my ($oper_type) = @_;

    my $step_name = "update_timezone $oper_type";
    notify("*** starting $step_name",'A');
    my $time_start = time();

    my $db_name_and_sid_list;
    # 得到db_name_and_sid_list 从两种方式，1是指定了 --sid_list，2是没有指定，从srvctl中获取
    if ( defined $input->{sid_list} ) {
        my $sid_list = $input->{sid_list};
        my @sid = split /,/, $sid_list;
        foreach my $sid ( @sid ) {
            my $db_name = get_db_name_from_sid($sid,$target_oracle_home);
            my $hash;
            $hash->{db_name} = $db_name;
            $hash->{oracle_sid} = $sid;
            push @$db_name_and_sid_list, { %$hash };
        }
    }
    else {
        $db_name_and_sid_list = get_db_list($oracle_home);
    }

    # db_name_and_sid_list 已经得到，后面的操作单机与RAC没有区别
    # 首先启动所有SID
    notify("got db_name_and_sid_list, start every sid");
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name,$oracle_home);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name,$oracle_home);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }
        # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
        if ( $db_type eq "rac" ) {
            my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home);
            if ( $local_node_can_start_rac_db eq "no" ) {
                notify("local node can not start rac db $db_name, so skip it");
                next;
            }
        }

        # 执行update timezone
        update_timezone_for_a_sid($db_name_and_sid,$oper_type);

    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task $step_name");
}

sub update_timezone_for_a_sid {
    my ($db_name_and_sid,$oper_type) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};

    notify("*** starting update_timezone for $db_name",'A');
    my $time_start = time();

    # 启动对方实例（更新srvctl状态）
    start_database_using_srvctl($db_name_and_sid);

    # 停止DB
    stop_database_using_srvctl($db_name_and_sid);

    # startup nomount
    startup_instance_to_nomount($oracle_sid);

    # CLUSTER_DATABASE=FALSE
    modify_cluster_true_or_false($oracle_sid,"no") if $env_type eq "crs";

    # SHUTDOWN
    stop_instance($db_name_and_sid);

    # 启动本节点的实例，打开所有PDB
    start_instance($db_name_and_sid,$oracle_home);

    # 在这里创建还原点

    my $status;
    for ( my $i=1; $i <= 3; $i++ ) {
        if ( $oper_type eq "check" ) {
            $status = do_utltz_sql_check($oracle_sid);
        }
        elsif ( $oper_type eq "apply" ) {
            $status = do_utltz_sql_apply($oracle_sid);
        }

        last if $status eq "ok";
        if ( $i == 3 ) {
            my $msg = "Error!  upgrade timezone for $oracle_sid has error";
            notify("$msg");
            print $error_fd "$msg\n";
        }
    }

    if ( $status eq "ok" ) {
        notify("upgrade timezone for $oracle_sid successfully");
    }
    elsif ( $status eq "failed" ) {
        my $msg = "Error!  upgrade timezone for $oracle_sid failed";
        notify("$msg");
        print $error_fd "$msg\n";
    }

    # CLUSTER_DATABASE=TRUE
    modify_cluster_true_or_false($oracle_sid,"yes") if $env_type eq "crs";

    # SHUTDOWN
    stop_instance($db_name_and_sid);

    # 启动本节点的实例，打开所有PDB
    start_instance($db_name_and_sid);

    # 启动对方实例
    start_database_using_srvctl($db_name_and_sid);

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task update_timezone for $db_name");
}

