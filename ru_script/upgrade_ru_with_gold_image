sub update_etc_oracle_olr_loc {
    my ($target_grid_home) = @_;

    my $olr_loc = "/etc/oracle/olr.loc";
    my $backup_file_name = "/etc/oracle/olr.loc.before_update_by_ru." . get_locatime_for_file();
    copy ($olr_loc, $backup_file_name);

    my @olr_loc = get_all_line($olr_loc);
    foreach my $line ( @olr_loc ) {
        if ( $line =~ m/^crs_home=/ ) {
            $line = "crs_home=$target_grid_home";
        }
    }

    # 重新写入
    my $fd = IO::File->new("> $olr_loc");
    foreach my $line ( @olr_loc ) {
        print $fd "$line\n";
    }
    $fd->close();

    @olr_loc = get_all_line($olr_loc);
    foreach my $line ( @olr_loc ) {
        notify($line);
    }
}

