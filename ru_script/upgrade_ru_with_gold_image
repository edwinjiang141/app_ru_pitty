sub create_restore_point {
    my ($oracle_sid,$input_oracle_home) = @_;

    # 从 archive log list 中检查归档模式
    my $sql;
    push @$sql, "set linesize 140;";
    push @$sql, "ARCHIVE LOG LIST;";
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);
    my $archive_mode = "yes";
    my @result01 = @{ $result };
    foreach my $line ( @result01 ) {
        notify("    $line",'A');
        # Database log mode	       Archive Mode
        # Database log mode	       No Archive Mode
        $archive_mode = "no" if $line =~ m/No Archive Mode/i;
    }

    if ( $archive_mode eq "no" ) {
        notify("****** Database log mode for $oracle_sid is: 'No Archive Mode'",'A');
        notify("****** can not create restore point for $oracle_sid",'A');
        sleep 5;
        return;
    }

    my ($db_recovery_file_dest,$db_recovery_file_dest_size);

    # 判断传递进来的 db_recovery_file_dest 参数 按传递的 db_recovery_file_dest 来配置
    if ( defined $input->{db_recovery_file_dest} and $env_type eq "fs" ) {
        if ( !-e $input->{db_recovery_file_dest} ) {
            notify("****** $input->{db_recovery_file_dest} is not exists.",'A');
            notify("****** skip create restore point for $oracle_sid",'A');
            sleep 5;
            return;
        }

        # 检查权限
        my $test_file_name = "test_file_for_ru." . get_locatime_for_file();
        my $test_file = catfile($input->{db_recovery_file_dest},$test_file_name);
        $cmd = "su - $oracle_user -c 'touch $test_file' 1>$cmd_log 2>$error_log";
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        if ( defined $result2->[0] ) {
            notify("****** Warning! $cmd is failed , skip create restore point for $oracle_sid ");
            sleep 5;
            return;
        }
        unlink $test_file if -e $test_file;

        $db_recovery_file_dest = $input->{db_recovery_file_dest};
        # 取得 $input->{db_recovery_file_dest} 的文件系统空间
        # 取得对应的dest文件系统大小 大小为G
        my ($free_space,$mount_dir) = get_free_space($db_recovery_file_dest);
        $db_recovery_file_dest_size = int($free_space / 1024 / 1024);
        notify("    free space for db_recovery_file_dest_size is: $db_recovery_file_dest_size",'A');

        # 此处设置一个最小值为50G
        my $tmp_size = int($db_recovery_file_dest_size / 4);
        if ( $tmp_size > 50 ) {
            $db_recovery_file_dest_size = int($db_recovery_file_dest_size / 4) . "G";
        }
        else {
            $db_recovery_file_dest_size = "50G";
        }
        notify("new db_recovery_file_dest is $db_recovery_file_dest");
        notify("new db_recovery_file_dest_size is $db_recovery_file_dest_size");
    }
    else {
        if ( $env_type eq "fs" ) {
            notify("****** not defined --db_recovery_file_dest, skip create restore point for $oracle_sid",'A');
            sleep 5;
            return;
        }
        else {  # rac/has 环境
            # 2025-05-20 21:22:19
            # CRS/HAS环境，默认创建还原点
            # if ( not defined $input->{create_restore_point} ) {
            #     notify("****** not defined --create_restore_point, skip create restore point for $oracle_sid",'A');
            #     sleep 5;
            #     return;
            # }
        }
    }

    notify("create_restore_point for $oracle_sid",'A');
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    my $time1 = time();
    if ( $env_type ne "fs" ) {
        ($db_recovery_file_dest,$db_recovery_file_dest_size) = get_recovery_dest_and_size($oracle_sid,$oracle_home);
    }

    # # 先检查是否已经有还原点，如果有，则需要先删除
    my $restore_point_name = $input->{restore_point_name} ? $input->{restore_point_name} : "restore_point_before_datapatch";
    drop_restore_point($restore_point_name,$oracle_sid,$oracle_home);

    undef $sql;
    push @$sql, "ALTER SYSTEM SET db_recovery_file_dest_size = $db_recovery_file_dest_size;";
    push @$sql, "ALTER SYSTEM SET db_recovery_file_dest = '$db_recovery_file_dest';";
    push @$sql, "CREATE RESTORE POINT $restore_point_name GUARANTEE FLASHBACK DATABASE;";
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

    my $return = "ok";
    my @result = @{ $result };
    foreach my $line ( @result ) {
        notify("    $line",'A');
        if ( $line =~ /^ORA-/ ) {
            $return = 'error';
        }
    }

    if ( $return eq 'no' ) {
        notify("Error!  CREATE RESTORE POINT $restore_point_name for $oracle_sid has error",'A');
        exit 1;
    }
    else {
        notify("    CREATE RESTORE POINT $restore_point_name for $oracle_sid is done",'A');
    }

    my $time2 = time();
    my $time_diff = time_diff($time2,$time1);
    notify("time: $time_diff seconds to create_restore_point for $oracle_sid");
}

