sub drop_restore_point {
    my ($restore_point_name,$oracle_sid,$oracle_home) = @_;
    notify("    drop_restore_point for sid $oracle_sid");
    my $time1 = time();

    # 先检查是否已经有还原点，如果有，则提示需要先删除

    my $sql;
    push @$sql, "set linesize 140;";
    push @$sql, "column restore_point format a20;";
    push @$sql, "column name format a80;";
    push @$sql, "select 'restore_point', name from v\$restore_point;";
