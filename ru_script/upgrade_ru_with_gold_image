=head1 SYNOPSIS

upgrade_ru_with_gold_image [option]

operation:


 --perl upgrade_ru_with_gold_image -h
    ******************************************************************************
    ******************************************************************************
    # step_00 的步骤，这些步骤不影响生产，可以提前操作
    perl upgrade_ru_with_gold_image --step_00_precheck
    perl upgrade_ru_with_gold_image --step_00_backup --backup_dir=/u01/backup

    一键式补丁升级操作 -> 针对单机文件系统环境
        /usr/bin/perl upgrade_ru_with_gold_image --step_00_unzip \
            --unzip_switch_back_image \
            --target_oracle_home=/u01/app/oracle/product/19.26/db_home \
            --db_image=/u01/iso/gold_image_db_home_linux_19.26.zip

        # step_51/step_52 二选一
        /usr/bin/perl upgrade_ru_with_gold_image \
            --step_51_switch_one_node_to_different_path_not_start_instance \
            --target_oracle_home=/u01/app/oracle/product/19.26/db_home
        /usr/bin/perl upgrade_ru_with_gold_image \
            --step_52_switch_one_node_to_original_path_not_start_instance \
            --target_oracle_home=/u01/app/oracle/product/19.26/db_home

        perl upgrade_ru_with_gold_image --step_08_datapatch --sid_list=orcl --db_recovery_file_dest=/u01/app/oracle/archivelog/ORCL
        perl upgrade_ru_with_gold_image --step_09_verify

        回退
            perl upgrade_ru_with_gold_image --step_81_rollback_software --backup_dir=/u01/backup
            perl upgrade_ru_with_gold_image --step_82_rollback_datapatch
            perl upgrade_ru_with_gold_image --step_83_rollback_start_database

    ******************************************************************************
    ******************************************************************************
    # step_00 的步骤，需要在每个节点都进行操作，这些步骤不影响生产，可以提前操作
    perl upgrade_ru_with_gold_image --step_00_precheck
    perl upgrade_ru_with_gold_image --step_00_backup --backup_dir=/u01/backup

    一键式补丁升级操作 -> 针对 CRS 环境
        # 解压缩
        # 注意 -> --unzip_switch_back_image 这个参数是针对 step_52 ，它会多解压缩一套GRID_HOME+DB_HOME
        #         step_51 不需要这个参数

        perl upgrade_ru_with_gold_image --step_00_unzip \
            --target_grid_home=/u01/app/19.16/grid_home \
            --target_oracle_home=/u01/app/oracle/product/19.16/db_home \
            --grid_image=/u01/iso/gold_image_grid_home_linux_19.16.zip \
            --db_image=/u01/iso/gold_image_db_home_linux_19.16.zip

        perl upgrade_ru_with_gold_image --step_00_unzip \
            --unzip_switch_back_image \
            --target_grid_home=/u01/app/19.16/grid_home \
            --target_oracle_home=/u01/app/oracle/product/19.16/db_home \
            --grid_image=/u01/iso/gold_image_grid_home_linux_19.16.zip \
            --db_image=/u01/iso/gold_image_db_home_linux_19.16.zip

        # 执行RU升级 分成step_51/step_52两条路线

        step_51,切换到不同目录，并且启动实例( rolling 方式升级 )
        -> 按照节点顺序，在每个节点分别进行操作
        perl upgrade_ru_with_gold_image \
            --step_51_switch_one_node_to_different_path_start_instance \
            --target_grid_home=/u01/app/19.16/grid_home \
            --target_oracle_home=/u01/app/oracle/product/19.16/db_home

        step_51,切换到不同目录，并且不启动实例( non-rolling 方式升级 )
        -> 按照节点顺序，在每个节点分别进行操作
        perl upgrade_ru_with_gold_image \
            --step_51_switch_one_node_to_different_path_not_start_instance \
            --target_grid_home=/u01/app/19.16/grid_home \
            --target_oracle_home=/u01/app/oracle/product/19.16/db_home

        step_52,切换到相同目录，并且启动实例( rolling 方式升级 )
        -> 按照节点顺序，在每个节点分别进行操作
        /usr/bin/perl upgrade_ru_with_gold_image \
            --step_52_switch_one_node_to_original_path_start_instance \
            --target_grid_home=/u01/app/19.16/grid_home \
            --target_oracle_home=/u01/app/oracle/product/19.16/db_home

        step_52,切换到相同目录，并且不启动实例( non-rolling 方式升级 )
        -> 按照节点顺序，在每个节点分别进行操作
        /usr/bin/perl upgrade_ru_with_gold_image \
            --step_52_switch_one_node_to_original_path_not_start_instance \
            --target_grid_home=/u01/app/19.16/grid_home \
            --target_oracle_home=/u01/app/oracle/product/19.16/db_home

        所有节点完成升级后 进行datapatch
        -> 只在节点1进行操作
            perl upgrade_ru_with_gold_image --step_08_datapatch
            perl upgrade_ru_with_gold_image --step_09_verify


