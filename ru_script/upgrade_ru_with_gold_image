    }
    else {
        notify("    not find old_grid_home from $last_backup_profile");
        return "not_find";
    }
}

sub check_srvctl_config_database_find_crs_db_name {
    notify("check_srvctl_config_database_find_crs_db_name",'A');
    my ($srvctl,$instance_name) = @_;
    my (@result,@tmp,$crs_db_name);

    # 得到当前的DB资源清单
    @result = `$srvctl config database`;
    foreach my $line ( @result ) {
        chomp($line);
    }
    ### @result
    my $tag = "-";
    foreach my $db (@result) {      # 查找每个DB资源，找出Database instances这一行，是否与ORACLE_SID匹配
        last if $tag eq "yes";
        chomp($db);
        my @cmd = `$srvctl config database -d $db`;
        foreach my $line ( @cmd ) {
            chomp($line);
        }
        ### srvctl_config_database_-d:@cmd
        foreach my $line ( @cmd ) {
            last if $tag eq "yes";
            chomp $line;
            next if $line !~ m/Database instance/;     # 找到Database instances这一行，将其拆分，得到instance列表
            my @tmp1 = split /:/, $line;                # Database instances: db11g1,db11g2
            my @instance_list = split/,/, $tmp1[1];
            foreach my $sid ( @instance_list ) {        # 与ORACLE_SID进行比较
                $sid =~ s/^\s+|\s+$//g;
                if ( $sid eq $instance_name ) {
                    $tag = "yes";
                    $crs_db_name = $db;
                    notify("CRS_DB_NAME is $crs_db_name");
                    last;
                }
            }
        }
    }

    if ( $tag eq "-" ) {
        notify("Error!  Can not find CRS_DB_NAME, please check srvctl config database -d db_unique_name");
        $crs_db_name = "not_find";
        exit 1;
        # return $crs_db_name;
    }
    else {
        return $crs_db_name;
    }
}

sub start_crs_for_rollback {
    notify("*** start_crs_for_rollback",'A');
    my $time_start_01 = time();

    # 重新取得oracle_home
    my $oracle_home = get_oracle_home_with_echo("$grid_user");
    my $crsctl = catfile($oracle_home,"bin/crsctl");
    my $cmd;
    $cmd = "$crsctl start crs -wait 1>$cmd_log 2>$error_log" if $env_type eq "crs";
    $cmd = "$crsctl start has -wait 1>$cmd_log 2>$error_log" if $env_type eq "has";
    notify("    cmd is $cmd");
    system($cmd);
    sleep 30;
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        #2022-09-16 15:05:04	    cmd is /u01/app/19.3.0/grid/bin/crsctl start crs
        #CRS-6706: Oracle Clusterware Release patch level ('724960844') does not match Software patch level ('896235792'). Oracle Clusterware cannot be started.
        #CRS-4000: Command Start failed, or completed with errors.
        #解决方法
        #    clscfg -localpatch
        #    $ORACLE_HOME/crs/install/rootcrs.sh -lock
        #    crsctl start crs
    ### $result1
    ### $result2
    if ( $result1->[0] =~ m/CRS-6706/ ) {
        my $cmd;
        $cmd = "$crsctl stop crs -f 1>$cmd_log 2>$error_log" if $env_type eq "crs";
        $cmd = "$crsctl stop has -f 1>$cmd_log 2>$error_log" if $env_type eq "has";
        notify("    cmd is $cmd");
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        ### $result1
        ### $result2

        my $clscfg = catfile($oracle_home,"bin/clscfg");
        $cmd = "$clscfg -localpatch 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd");
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        ### $result1
        ### $result2

        my $rootcrs;
        $rootcrs = catfile($oracle_home,"crs/install/rootcrs.sh") if $env_type eq "crs";
        $rootcrs = catfile($oracle_home,"crs/install/roothas.sh") if $env_type eq "has";
        $cmd = "$rootcrs -lock 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd");
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        ### $result1
        ### $result2

        $cmd = "$crsctl start crs -wait 1>$cmd_log 2>$error_log" if $env_type eq "crs";
        $cmd = "$crsctl start has -wait 1>$cmd_log 2>$error_log" if $env_type eq "has";
        notify("    cmd is $cmd");
        system($cmd);
        sleep 30;
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        ### $result1
        ### $result2
        if ( $result1->[0] !~ m/CRS-4123/ ) {       #CRS-4123: Oracle High Availability Services has been started
            notify("Error!  start crs error");
            exit 1;
        }
    }

    # 检查ASM进程
    # 重试N次，每次30秒
    my $asm_status;
    for ( my $i=1; $i <= 5; $i++ ) {
        $asm_status = check_asm_process();
        last if $asm_status eq "asm_is_running";
        notify("retry $i",'A');
        sleep 30;
    }

    if ( $asm_status ne "asm_is_running" ) {
        my $msg = "Error!  asm is not running";
        notify("$msg",'A');
        print $error_fd "$msg\n";
    }

    my $time_stop_01 = time();
    my $time_diff = time_diff($time_start_01,$time_stop_01);
    notify("time: $time_diff seconds to task start_crs_for_rollback");
}

