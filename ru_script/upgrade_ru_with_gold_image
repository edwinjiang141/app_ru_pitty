sub open_pdb {
    my ($oracle_sid,$input_oracle_home) = @_;
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    # 如果指定了 --save_pdb_open_mode 就不执行ALTER PLUGGABLE DATABASE ALL OPEN
    if ( defined $input->{save_pdb_open_mode} ) {
        notify("    skip 'ALTER PLUGGABLE DATABASE ALL OPEN' for $oracle_sid due to defined --save_pdb_open_mode",'A');
        return;
    }

    notify("do open_pdb for $oracle_sid");
    my $time1 = time();

    my $sql;
    push @$sql, "ALTER PLUGGABLE DATABASE ALL OPEN;";
    push @$sql, "SHOW PDBS;";
