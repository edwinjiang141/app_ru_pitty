        @tmp = grep !/^Filesystem|^tmpfs|^none|cdrom|\/lib\/|proc|fd|mnttab|\/var\/run|devices|objfs|^ctfs|volatile|\/dev\/odm|\/dev\/vx\/dmp|\/dev\/vx\/rdmp/,@tmp;
