sub grep_node_list_from_inventory {
    my $inventory_file = shift;

    my $tag_of_inventory = "ok";
    my @result_of_inventory = get_all_line($inventory_file);
    notify("    inventory.xml: $inventory_file",'A');
    foreach my $line ( @result_of_inventory ) {
        notify("        $line");
        if ( $line =~ m/NODE_LIST/ ) {
            $tag_of_inventory = "node_list";
        }
        if ( $line =~ m/NODE NAME/ ) {
            $tag_of_inventory = "node_name";
        }
        if ( $line =~ m/NODE_LIST/ ) {
            $tag_of_inventory = "node_list";
        }
        if ($line =~ /^(<HOME NAME[^>]*[^\/])>/) {
            notify("    Missing '/' before the '>' ",'A');
            $tag_of_inventory = "miss_tag";
        }

    }

    return if $tag_of_inventory eq "ok";

    notify("    grep_node_list_from_inventory for $inventory_file",'A');
    # 手动修改inventory，去掉目标行
    # 1.生成一个备份文件
    my $inventory_xml_backup_name = ".backup_before_grep_node_list." . get_locatime_for_file();
    my $inventory_xml_backup_path = $inventory_file . $inventory_xml_backup_name;

    notify("        copy $inventory_file to $inventory_xml_backup_path",'A');
    copy($inventory_file,$inventory_xml_backup_path);
    if ( !-e $inventory_xml_backup_path ) {
        notify("Error!  copy $inventory_file to $inventory_xml_backup_path is failed !",'A');
        exit 1;
    }

    # 授权给grid:oinstall
    $cmd = "chown $grid_user:$group_for_oinstall $inventory_xml_backup_path" if $env_type eq "crs" or $env_type eq "has";
    $cmd = "chown $oracle_user:$group_for_oinstall $inventory_xml_backup_path" if $env_type eq "fs";
    notify("        $cmd",'A');
    system($cmd);

    my @inventory_content_old = get_all_line($inventory_file);
    my @inventory_content_new;
    # 去掉 NODE_LIST 和 NODE NAME
    notify("    before grep NODE_LIST for $inventory_file");
    foreach my $line ( @inventory_content_old ) {
        notify("        $line");
        next if $line =~ m/NODE_LIST/i;
        next if $line =~ m/NODE NAME/i;
        next if $line =~ m/^<\/HOME>/i; #   </HOME>
        # <HOME NAME开头的行 结尾处不包含 / 符号 需要加上
        # <HOME NAME="OraDB19Home1" LOC="/u01/app/oracle/product/19.3.0/db_1" TYPE="O" IDX="2"/>
        # <HOME NAME="OraDB19Home1" LOC="/u01/app/oracle/product/19.3.0/db_1" TYPE="O" IDX="2">
        if ( $line =~ m/^<HOME NAME/ ) {
            $line =~ s/^(<HOME NAME[^>]*[^\/])>/$1\/>/;
        }
        push @inventory_content_new, $line;
    }
    ### @inventory_content_old
    ### @inventory_content_new

    # 4.写入新文件
    notify("        rewrite $inventory_file",'A');
    open myFile , "> $inventory_file";
    foreach my $a ( @inventory_content_new ) {
        print myFile "$a\n";
    }
    close myFile;
    notify("        write $inventory_file done",'A');

    # 授权给grid:oinstall
    $cmd = "chown $grid_user:$group_for_oinstall $inventory_file" if $env_type eq "crs" or $env_type eq "has";
    $cmd = "chown $oracle_user:$group_for_oinstall $inventory_file" if $env_type eq "fs";
    notify("        $cmd",'A');
    system($cmd);

    @inventory_content_new = get_all_line($inventory_file);
    notify("    after grep NODE_LIST for $inventory_file");
    foreach my $line ( @inventory_content_new ) {
        notify("        $line");
    }

