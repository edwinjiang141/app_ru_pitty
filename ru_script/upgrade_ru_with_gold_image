    my $restore_point_exists = 'no';
    foreach my $line ( @$result ) {
        next if $line !~ m/restore_point/;
        # notify("    $line",'A');
        if ( $line =~ m/$restore_point_name/i ) {
            $restore_point_exists = 'yes';
        }
    }

    if ( $restore_point_exists eq "yes" ) {
        notify("NOTE! RESTORE POINT $restore_point_name for sid $oracle_sid is existed",'A');
