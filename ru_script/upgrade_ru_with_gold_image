sub only_drop_null_dir {
    my ($dir) = @_;
    notify("only_drop_null_dir for $dir",'A');

    if ( -e $dir ) {
        # 检查大小，如果>1m，就不删除，报错退出
        my @size = `du -sk $dir`;
        my $size = shift @size;
        chomp $size;
        notify("    du -sk is $size",'A');
        $size = (split /\s/,$size)[0];
        if ( $size > 1024 ) {
            notify("Error!  $dir is not null",'A');
            exit 1;
        }
        # 小于1m，说明是空目录，删除
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');
        my $cmd = "rm -rf $dir 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system("$cmd");
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display_log");
        if ( defined $result2->[0] ) {
            notify("Error!  $cmd is error!");
            print_file($error_log);
            exit 1;
        }
    }
}

