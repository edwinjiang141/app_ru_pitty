sub get_crs_home {
    notify("    get_crs_home",'A');

    # 检查是否有CRS进程，如果有，取得CRS_HOME
    my @cmd = `ps -ef|grep ohasd.bin|grep -v grep`;
    my $crs_home;
    if ( defined $cmd[0] ) {
        $crs_home = $cmd[0];
        $crs_home =~ s/\s+reboot.*$//;
        $crs_home =~ s/\s+restart*$//;
        $crs_home = (split /\s+/,$crs_home)[-1];
        ($crs_home) = $crs_home =~ m/(.*)\/bin\/ohasd\.bin/;
        $crs_home =~ s/^\s+|\s+$//g;
        notify("    crs_home is $crs_home");
    }
    if ( defined $crs_home ) {
        return $crs_home;
    }
    else {
        notify("    get_crs_home from profile");
        # 从profile中获取
        my $oracle_home = get_oracle_home_with_echo("$grid_user");
        my $srvctl = catfile($oracle_home,"bin/srvctl");
        if ( !-e $srvctl ) {
            notify("    can not find crs_home");
            return "error";
        }
        else {
            $crs_home = $oracle_home;
            return $crs_home;
        }
    }
}

sub get_db_list {
    my ($input_oracle_home) = @_;
    notify("get_db_list",'A');
    # 得到DB清单以及对应的ORACLE_SID
    unlink $cmd_log;
    unlink $error_log;
    my $get_random = get_random();
    my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
    my $error_log = "/tmp/error_log_" . $get_random . ".log";
    notify("    cmd_log   is $cmd_log",'A');

    my ($db_name_list,$db_name_and_sid);
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        # 如果CRS没起来，就不执行后面的操作
        my $crs_home = get_crs_home($oracle_home);
        if ( $crs_home eq "error" ) {
            notify("Error!  crs is not running",'A');
            exit 1;
        }
        my $srvctl = catfile($oracle_home,"bin/srvctl");
        my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl config database' 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);

        foreach my $db_name ( @$result1 ) {
            notify("db_name is $db_name",'A');

            # 对每个 db_name 执行 srvctl config database -d db_name 如果有报错，就跳过这个DB_NAME
            unlink $cmd_log;
            unlink $error_log;
            my $get_random = get_random();
            my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
            my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            my $srvctl = catfile($oracle_home,"bin/srvctl");
            my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl config database -d $db_name' 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system($cmd);
            my ($tmp_result1,$tmp_result2) = print_cmd_log($cmd_log,$error_log);
            next if $tmp_result1->[0] =~ m/1229/;       # 1229 表示DB的ORACLE_HOME与当前ORACLE_HOME不一致

            # 对于RAC DB，有可能3个节点只允许2个节点启动，所以要跳过没有配置的节点
            # PRKO-3133
            my $db_type = get_srvctl_database_type($db_name,$oracle_home);
            if ( $db_type eq "rac" ) {
                my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home);
                if ( $local_node_can_start_rac_db eq "no" ) {
                    notify("local node can not start rac db $db_name, so skip it");
                    next;
                }
            }

            push @$db_name_list, $db_name;
        }

        if ( not defined $db_name_list->[0] ) {
            # srvctl config database 为空
            notify("Error!  $srvctl config database is null",'A');
            exit 1;
        }
        ### $db_name_list

        foreach my $db_name ( @$db_name_list ) {
            my $oracle_sid = get_sid_from_db_name($db_name,$oracle_home);
            my $hash;
            $hash->{db_name} = $db_name;
            $hash->{oracle_sid} = $oracle_sid;
            # 如果指定了 --skip_sid_list=sid1,sid2
            my $tag = "not_skip";
            if ( defined $input->{skip_sid_list} ) {
                my @sid = split /,/, $input->{skip_sid_list};
                foreach my $sid ( @sid ) {
                    $tag = "skip" if $sid eq $oracle_sid;
                }
            }
            push @$db_name_and_sid, { %$hash } if $tag eq "not_skip";
        }
    }
    else {
        # 对于单机，采用另外的方法来取得DB_NAME和SID
        # 查找dbw0进程名称，此名称就是sid
        # 如果指定了--sid_list，那么sid=db_name
        my $sid_list = get_sid_list($oracle_home);
        foreach my $sid ( @$sid_list ) {
            my $hash;
            $hash->{db_name} = $sid;
            $hash->{oracle_sid} = $sid;
            push @$db_name_and_sid, { %$hash };
        }
    }

    return $db_name_and_sid;
}

sub get_sid_list {
    my ($input_oracle_home) = @_;
    notify("get_sid_list",'A');
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    my @cmd = `su - $oracle_user -c id`;
    my $tmp = $cmd[0];
    $tmp =~ s/^\s+//g;
    my ($id) = $tmp =~ m/\((.*)\)\s+gid/;
    $id =~ s/^\s+|\s+$//g;
    $id = substr($id,0,8);
    notify("id is $id",'N');

    # 如果指定了--sid_list参数，就直接以sid_list返回
    # 如果没有指定--sid_list，按照以前的过程进行处理
    my $sid_list;
    if ( defined $input->{sid_list} ) {
        my @sid = split /,/, $input->{sid_list};
        foreach my $sid ( @sid ) {
            push @$sid_list, $sid;
        }
    }
    else {
        @cmd = `ps -ef|grep ora_pmon|grep -v grep|grep $id`;
        foreach my $line ( @cmd ) {
            chomp($line);
            $line =~ s/^\s+|\s+$//g;
            notify("line is $line",'N');
            my @F = split /\s+/, $line;
            notify("F[0] is $F[0]",'N');
            next if $F[0] ne $id;                       # 如果用户ID不一致，就跳过这一行
            my ($sid) = $line =~ m/ora_pmon_(.*)$/;
            push @$sid_list, $sid;
        }
        if ( not defined $sid_list ) {
            if ( $env_type eq "fs" ) {          # fs类型，直接把ORACLE_SID环境变量放进列表
                                                # 如果有指定--sid参数，直接把参数值作为SID
                if ( $ORACLE_SID ne "not_defined" ) {
                    push @$sid_list, $ORACLE_SID;
                }
                else {
                    my $cmd = "su - $oracle_user -c 'echo \$ORACLE_SID'";
                    my $result = execute_cmd($cmd);
                    if ( defined $result->[0] ) {
                        my $sid = $result->[0];
                        push @$sid_list, $sid;
                    }
                    else {
                        notify("Error!  not found ORACLE_SID for $oracle_user",'A');
                        exit 1;
                    }
                }
            }
            else {                                      # 其它类型，按报错处理
                notify("Error!  not found pmon for $oracle_user",'A');
                exit 1;
            }
        }
    }

    return($sid_list);
}

sub stop_instance_all {
    my ($input_oracle_home) = @_;
    notify("stop_instance_all",'A');
    my $time_start = time();
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    my $dbstatus = check_db_process_no_sid($oracle_home);
    if ( $dbstatus eq "db_is_not_running" ) {
        notify("    database instance is not running",'A');
        return;
    }

    my $db_name_and_sid = get_db_list($oracle_home);
    my @pids;

    # 2025-10-21 17:34:08 改成fork并行 适应一体机多个实例的环境
    # 有两种 fork 记录文件：
    #   fork_for_stop_a_sid                 ->  是fork的标志文件，每个子进程生成一个标志文件，表示fork for a sid 开始工作
    #   stop_instance_result_for_a_sid      ->  记录shutdown immediate此实例的结果

    notify("clear stop instance result file for fork");
    foreach my $db_name_and_sid ( @$db_name_and_sid ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        my $fork_file = catfile("/tmp","fork_for_stop_sid_$oracle_sid");
        notify("do unlink $fork_file");
        unlink $fork_file if -e $fork_file;

        # 清理 stop for sid 的结果标记
        # /tmp/stop_result_for_sid
        my $stop_result_for_sid = "/tmp/stop_instance_result_for_" . $oracle_sid;
        notify("do unlink $stop_result_for_sid");
        unlink $stop_result_for_sid if -e $stop_result_for_sid;
    }


    # ========================
    # 并行执行 stop_instance()
    # ========================
    foreach my $db_name_and_sid ( @$db_name_and_sid ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        my $pid = fork();
        my $fork_file = catfile("/tmp","fork_for_stop_sid_$oracle_sid");
        my $stop_result_for_sid = "/tmp/stop_instance_result_for_" . $oracle_sid;

        if ( not defined $pid ) {
            notify("Error!  stop $oracle_sid in fork is error! $!");
            next;
        }
        elsif ($pid == 0) {
            # 子进程执行
            notify("this is fork process, for stop instance, sid: $oracle_sid");
            notify("10138 pid is $pid");
            notify("10138 fork_file is $fork_file");
            do_stop_instance_in_fork($db_name_and_sid,$oracle_home,$pid,$fork_file,$stop_result_for_sid) if !-e $fork_file;
            exit 0;
        }
        else {
            # 父进程记录 PID
            notify("10141 pid is $pid");
            push @pids, $pid;
        }
    }

    # ========================
    # 等待所有子进程完成
    # ========================
    foreach my $pid (@pids) {
        waitpid($pid, 0);
    }

    my ($stop_done_sid,$stop_skipped_sid,$stop_error_sid);
    # 检查结果文件 区分ok/skip/failed
    foreach my $db_name_and_sid ( @$db_name_and_sid ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        # 此处检查每个SID的结果文件
        my $stop_result_for_sid = "/tmp/stop_instance_result_for_" . $oracle_sid;
        notify("check stop_result_for_sid $stop_result_for_sid");
        my @result = get_all_line($stop_result_for_sid);
        if ( grep { /ok/ } @result ) {
            notify("stop $oracle_sid is ok");
            push @$stop_done_sid, $oracle_sid;
        }
        elsif ( grep {/skip/ } @result ) {
            notify("stop $oracle_sid is skipped");
            push @$stop_skipped_sid, $oracle_sid;
        }
        elsif ( grep {/error/ } @result ) {
            notify("Error!  stop $oracle_sid is error!");
            print $error_fd "Error!  stop $oracle_sid is error!\n";
            push @$stop_error_sid, $oracle_sid;
        }
    }

    notify("*** stop instances result");
    foreach my $oracle_sid ( @$stop_done_sid ) {
        notify("\t sid $oracle_sid \t shutdown is done");
    }
    foreach my $oracle_sid ( @$stop_skipped_sid ) {
        notify("\t sid $oracle_sid \t shutdown is skipped");
    }
    foreach my $oracle_sid ( @$stop_error_sid ) {
        notify("\t Error!  sid $oracle_sid \t shutdown has error, please check!");
        print $error_fd "Error!  sid $oracle_sid shutdown has error, please check!\n";
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task stop_instance_all");

}

sub do_stop_instance_in_fork {
    my ($db_name_and_sid,$input_oracle_home,$pid,$fork_file,$stop_result_for_sid) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};

    notify("do_stop_instance_in_fork for $oracle_sid, pid is $pid",'A');
    notify("do touch $fork_file",'A');
    system("touch $fork_file");

    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");
    notify("do_stop_instance_in_fork for $db_name",'A');
    my $time_start = time();

    my $db_type = get_srvctl_database_type($db_name,$oracle_home,"fork");
    notify("10238, db_type for $db_name is $db_type",'A');
    my $srvctl_instance_status = get_local_srvctl_instance_status($db_name,$oracle_home,"fork");
    notify("10240, srvctl_instance_status for $db_name is $srvctl_instance_status",'A');
    # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
    if ( $db_type eq "rac" ) {
        my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home,"fork");
        notify("10244, local_node_can_start_rac_db for $db_name is $local_node_can_start_rac_db",'A');
        if ( $local_node_can_start_rac_db eq "no" ) {
            notify("local node can not start rac db $db_name, so skip it");
            # 此处写入 skip 到result文件
            my $fd = IO::File->new("> $stop_result_for_sid");
            print $fd "stop $oracle_sid is skipped\n";
            $fd->close();
            notify("shutdown instance $oracle_sid is skipped , because local node can not start rac db $db_name",'A');
            return;
        }
    }

    if ( $db_type eq "UNKNOWN" ) {
        notify("get_srvctl_database_type for $db_name is UNKNOWN, failed to stop");
        # 此处写入 skip 到result文件
        my $fd = IO::File->new("> $stop_result_for_sid");
        print $fd "stop $oracle_sid is error\n";
        $fd->close();
        notify("shutdown instance $oracle_sid is error , because get_srvctl_database_type for $db_name is UNKNOWN",'A');
        return;
    }

    my $stop_result;
    if ( $db_type eq "rac_one_node" ) {
        if ( $srvctl_instance_status eq "running_at_local" ) {
            $stop_result = shutdown_instance_using_sqlplus_fork($oracle_sid,$oracle_home);
        }
    }
    else {
        $stop_result = shutdown_instance_using_sqlplus_fork($oracle_sid,$oracle_home);
    }
    notify("10275, stop_result for $oracle_sid is $stop_result",'A');

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        unlink $cmd_log;
        unlink $error_log;
        my $srvctl = catfile($oracle_home,"bin/srvctl");
        my $hostname = get_local_host_name();
        my $cmd;

        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
        notify("    cmd_log: $cmd_log",'A');

        if ( $env_type eq "crs" ) {
            if ( $db_type eq "rac" ) {
                $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl stop instance -d $db_name -instance $oracle_sid -force'" . " 1>$cmd_log 2>$error_log";
            }
            elsif ( $db_type eq "rac_one_node" ) {
                if ( $srvctl_instance_status eq "running_at_local" ) {
                    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl stop database -d $db_name -force'" . " 1>$cmd_log 2>$error_log";
                }
                else {
                    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status database -d $db_name'" . " 1>$cmd_log 2>$error_log";
                }
            }
        }
        elsif ( $env_type eq "has" ) {
            $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl stop database -d $db_name -force'" . " 1>$cmd_log 2>$error_log";
        }

        if ( defined $cmd ) {
            notify("    cmd is $cmd",'A');
            system($cmd);
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        }

        my $dbstatus = check_db_process($oracle_sid);
        notify("10311, dbstatus for $oracle_sid is $dbstatus",'A');
        if ( $dbstatus eq "db_is_not_running" ) {
            # 记录 ok 到 result 文件
            my $fd = IO::File->new("> $stop_result_for_sid");
            print $fd "stop $oracle_sid is ok\n";
            $fd->close();
            notify("shutdown instance $oracle_sid done",'A');
        }
        else {
            # 此处改为记录 error 到result文件
            my $fd = IO::File->new("> $stop_result_for_sid");
            print $fd "stop $oracle_sid is error\n";
            $fd->close();
            notify("Error!  shutdown instance $oracle_sid error",'A');
            # exit 1;
        }
        if ( $stop_result eq "skip" ) {
            my $fd = IO::File->new("> $stop_result_for_sid");
            print $fd "stop $oracle_sid is skipped\n";
            $fd->close();
            notify("shutdown instance $oracle_sid is skipped , because no process for $oracle_sid",'A');
        }
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task do_stop_instance_in_fork for $db_name");
}

