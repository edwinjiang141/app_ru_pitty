sub get_parent_dir_path {
    my $dir = shift;
    notify("    get_parent_dir_path for $dir",'A');

    if ( -f $dir ) {        # 如果是文件，就返回错误
        notify("Error!  $dir is a file",'A');
        exit 1;
    }

    my @F = split /\//, $dir;
    # 去掉最后一个元素
    pop @F;

    my $up_dir = join("/",@F);
    notify("        the parent dir of $dir is $up_dir",'A');
    if ( !-e $up_dir ) {
        notify("Warning!  $up_dir is not exist!",'A');
        # exit 1;
    }
    return $up_dir;
}

sub check_target_grid_db_dir {
    notify("check_target_grid_db_dir",'A');
    my $tag;

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        if ( -e $target_grid_home ) {
            # 检查大小，如果>1m，就退出
            my @size = `du -sk $target_grid_home`;
            my $size = shift @size;
            chomp $size;
            $size =~ s/^\s+|\s+$//g;        # 去掉前后空格
            notify("    du -sk is $size",'A');
            $size = (split /\s/,$size)[0];
            if ( $size > 1024 ) {
                notify("Error!  $target_grid_home is exists",'A');
                $tag->{target_grid_home_exist} = "yes";
            }
        }
    }

    if ( -e $target_oracle_home ) {
        # 检查大小，如果>1m，就退出
        my @size = `du -sk $target_oracle_home`;
        my $size = shift @size;
        chomp $size;
        $size =~ s/^\s+|\s+$//g;        # 去掉前后空格
        notify("    du -sk is $size",'A');
        $size = (split /\s/,$size)[0];
        if ( $size > 1024 ) {
            notify("Error!  $target_oracle_home is exists",'A');
            $tag->{target_oracle_home_exist} = "yes";
        }
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        if ( defined $tag->{target_oracle_home_exist} or defined $tag->{target_grid_home_exist} ) {
            notify("please delete the existing target grid_home or oracle_home",'A');
            exit;
        }
    }
    elsif ( $env_type eq "fs" ) {
        if ( defined $tag->{target_oracle_home_exist} ) {
            notify("    please delete the existing target oracle home",'A');
            exit;
        }
    }
}

sub unzip_grid_image {
    notify("*** starting unzip grid image",'A');

    if ( !-e $grid_image ) {
        notify("Error!  $grid_image does not exists",'A');
        exit 1;
    }

    my $time_start = time();
    # 如果target_grid_home已经存在，就删除
    my $target_grid_home_parent_dir = get_parent_dir_path($target_grid_home);
    if ( -e $target_grid_home_parent_dir ) {
        notify("$target_grid_home_parent_dir is exists",'A');
    }
    else {
        $cmd = "mkdir -p $target_grid_home_parent_dir";
        notify("    cmd is $cmd",'A');
        system("$cmd");

        $cmd = "chown -R $grid_user:$group_for_oinstall $target_grid_home_parent_dir";
        notify("    cmd is $cmd",'A');
        system("$cmd");
    }

    my $grid_image_file_name = basename($grid_image);

    # 如果后缀为tar或者gz，就是tar包
    if ( $grid_image_file_name =~ m/\.tar/ ) {
        # 复制 现在的规则是 tar包不包含目录名称，因此可以像unzip一样，先建立目标目录，然后再cd进去解压缩，这样就不用修改目录名称了
        my $cmd = "mkdir -p $target_grid_home";
        notify("    cmd is $cmd",'A');
        system("$cmd");

        chdir($target_grid_home);
        notify("current work dir is $target_grid_home",'A');

        my ($time1,$time2,$time_diff,$tar_file_path,$gz_tag);
        $tar_file_path = $grid_image;

        if ( $grid_image_file_name =~ "\.gz" ) {        # 只在gz时做cp和gzip -d
            $gz_tag = "yes";
            $time1 = time();
            unlink $cmd_log;
            unlink $error_log;
            my $get_random = get_random();
            my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
            my $error_log = "/tmp/error_log_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            $cmd = "cp $grid_image $target_grid_home 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system("$cmd");
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
            if ( defined $result1->[0] or defined $result2->[0] ) {
                notify("Error! $cmd is wrong");
                exit 1;
            }
            $time2 = time();
            $time_diff = time_diff($time1,$time2);
            notify("time: $time_diff seconds to cp $grid_image $target_grid_home");

            $time1 = time();
            unlink $cmd_log;
            unlink $error_log;
            $get_random = get_random();
            $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
            $error_log = "/tmp/error_log_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            $cmd = "gzip -d $grid_image_file_name 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system("$cmd");
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
            if ( defined $result1->[0] or defined $result2->[0] ) {
                notify("Error! $cmd is wrong");
                exit 1;
            }
            $time2 = time();
            $time_diff = time_diff($time1,$time2);
            notify("time: $time_diff seconds to gzip -d $grid_image_file_name");

            # 此时，它是tar文件名，这个文件名有可能是tar.gz解压缩之后的文件名，也可能原来就是tar文件
            $grid_image_file_name =~ s/\.gz$//;
            $tar_file_path = catfile($target_grid_home,$grid_image_file_name);
        }

        $time1 = time();
        unlink $cmd_log;
        unlink $error_log;
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');
        $cmd = "tar xf $tar_file_path 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system("$cmd");
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        if ( defined $result1->[0] or defined $result2->[0] ) {
            notify("Error! $cmd is wrong");
            exit 1;
        }
        $time2 = time();
        $time_diff = time_diff($time1,$time2);
        notify("time: $time_diff seconds to tar xf $tar_file_path");

        # delete tar 只在gz时才需要
        if ( defined $gz_tag ) {
            my $get_random = get_random();
            my $cmd_log = "/tmp/cmd_log_" . $get_random . ".log";
            my $error_log = "/tmp/error_log_" . $get_random . ".log";
            notify("    cmd_log   is $cmd_log",'A');
            $cmd = "rm -rf $tar_file_path 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system("$cmd");
        }

    }

    # 如果后缀为zip，就是gold image
    if ( $grid_image_file_name =~ m/\.zip/ ) {
        my $cmd = "mkdir -p $target_grid_home";
