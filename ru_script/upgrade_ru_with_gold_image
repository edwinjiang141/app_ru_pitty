         notify("*** backup grid_home",'A');
        my $grid_home_backup = catfile($backup_dir,"grid_home_backup_for_ru.tar");
        if ( -e $grid_home_backup ) {
            notify("Warning! backup for grid_home is exists, please check $grid_home_backup",'A');
