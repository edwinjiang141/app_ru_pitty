sub get_db_name_from_sid {
    my ($sid,$input_oracle_home) = @_;
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    my $db_name_for_return;
    my $db_name_and_sid = get_db_list($oracle_home);
    foreach my $db_name_and_sid ( @$db_name_and_sid ) {
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $db_name = $db_name_and_sid->{db_name};
        notify("    oracle_sid for $db_name is $oracle_sid");
        if ( $oracle_sid eq $sid ) {
            $db_name_for_return = $db_name;
            last;
        }
    }

    if ( not defined $db_name_for_return ) {
        notify("Error!  can not find db_name for $sid");
        exit 1;
    }
    notify("db_name for $sid is $db_name_for_return");
    return $db_name_for_return;
}

sub do_srvctl_modify_database_oraclehome_for_a_sid_and_a_db_home {
    my ($db_name,$target_oracle_home) = @_;

    notify("*** do_srvctl_modify_database_oraclehome_for_a_sid_and_a_db_home for $db_name",'A');
    my $time_start = time();

    unlink $cmd_log;
    unlink $error_log;
    my $get_random = get_random();
    my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
    my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
    notify("    cmd_log   is $cmd_log",'A');
    my $srvctl = catfile($target_oracle_home,"bin/srvctl");
    my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl modify database -d $db_name -oraclehome $target_oracle_home' 1>$cmd_log 2>$error_log";
    notify("    cmd is $cmd",'A');
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    if ( defined $result1->[0] or defined $result2->[0] ) {
        notify("Error!  $cmd is wrong");
        print_file($error_log);
        exit 1;
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task do_srvctl_modify_database_oraclehome_for_a_sid_and_a_db_home for $db_name");
}

sub start_mrp {
    my ($oracle_sid,$input_oracle_home) = @_;
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    notify("do start_mrp for $oracle_sid");
    my $time1 = time();

    my $sql;
    push @$sql, "ALTER DATABASE RECOVER MANAGED STANDBY DATABASE USING CURRENT LOGFILE DISCONNECT FROM SESSION;";
    $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

    my $return = "ok";
    my @result = @{ $result };
    my $tag = "na";
    foreach my $line ( @result ) {
        notify("    $line",'A');
        $tag = "error" if $line =~ m/^ORA/;
    }

    if ( $tag ne "na" ) {
        notify("Error!  start MRP for $oracle_sid has error");
        exit 1;
    }
    else {
        notify("start MRP for $oracle_sid is done");
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to start MRP for $oracle_sid");
}

sub step_08_datapatch {
    my $step_name = "step_08_datapatch";
    notify("*** starting $step_name",'A');
    my $time_start = time();

    notify("grid_user     is $grid_user") if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_user   is $oracle_user");
    notify("grid_base     is $grid_base") if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_base   is $oracle_base");
    notify("oraInventory  is $oraInventory");
    notify("grid_home     is $grid_home") if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_home   is $oracle_home");

    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $opatch = catfile($oracle_home,"OPatch/opatch");
    my $cmd = "su - $oracle_user -c '$opatch lspatches'";
    notify("$cmd",'A');
    my $result = execute_cmd($cmd);
    my $ojvm = "no";
    foreach my $a ( @$result ) {
        notify("$a",'A');
        $ojvm = "yes" if $a =~ m/OJVM/;
    }

    # 检查Simple.pm文件
    replace_perl_simple_pm();

    # 清理前面的进度文件
    my $progress_file = catfile($log_dir,"progress_for_ru");
    unlink $progress_file if -e $progress_file;

    # 清理所有的记录文件
    my $db_name_and_sid_list;
    my @pids;

    # 得到db_name_and_sid_list 从两种方式，1是指定了 --sid_list，2是没有指定，从srvctl中获取
    if ( defined $input->{sid_list} ) {
        my $sid_list = $input->{sid_list};
        my @sid = split /,/, $sid_list;
        foreach my $sid ( @sid ) {
            my $db_name = get_db_name_from_sid($sid,$target_oracle_home);
            my $hash;
            $hash->{db_name} = $db_name;
            $hash->{oracle_sid} = $sid;
            push @$db_name_and_sid_list, { %$hash };
        }
    }
    else {
        $db_name_and_sid_list = get_db_list($oracle_home);
    }

    # db_name_and_sid_list 已经得到，后面的操作没有区别

    # 首先启动所有SID
    start_instance_all($oracle_home);

    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 此处记录所有OPEN_MODE不是read write的PDB，放到Error队列，提示这些PDB没有做datapatch
        my $pdb_status = get_pdb_status($oracle_sid,$oracle_home);
        foreach my $pdb ( @$pdb_status ) {
            my $pdb_name = $pdb->{name};
            my $open_mode = $pdb->{open_mode};
            if ( $open_mode ne "READ WRITE" ) {
                my $msg = "Error!  sid $oracle_sid PDB $pdb_name open_mode is $open_mode , skip DATAPATCH!";
                notify($msg);
                print $error_fd "$msg\n";
            }
        }
    }

    notify("clear datapatch result file for fork");
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $fork_file = catfile("/tmp","fork_for_datapatch_$oracle_sid");
        notify("do unlink $fork_file");
        unlink $fork_file if -e $fork_file;

        # 清理datapatch for sid的结果标记
        # /tmp/datapatch_result_for_sid
        my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
        notify("do unlink $datapatch_result_for_sid");
        unlink $datapatch_result_for_sid if -e $datapatch_result_for_sid;

        # 清理cdb层面的util结果标记
        my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
        notify("do unlink $cdb_utlrp_result_for_sid");
        unlink $cdb_utlrp_result_for_sid if -e $cdb_utlrp_result_for_sid;

        # 清除每个PDB的命令文件和日志文件 此时需要CDB为启动状态
        my $pdbs = get_pdb_list($oracle_sid,$oracle_home);
        if ( $pdbs->[0] ne "nopdb" ) {
            foreach my $pdb_name ( @$pdbs ) {
                # sql_running_sid_pdb.sql
                my $sql_running = "/tmp/" . "sql_running_" . $oracle_sid . "_" . $pdb_name . ".sql";
                notify("do unlink $sql_running");
                unlink $sql_running if -e $sql_running;
                my $sql_running_log = "/tmp/" . "sql_running_" . $oracle_sid . "_" . $pdb_name . ".log";
                notify("do unlink $sql_running_log");
                unlink $sql_running_log if -e $sql_running_log;

                # 清理pdb层面的util结果标记
                # /tmp/pdb_utlrp_result_for_pdb_name
                my $pdb_utlrp_result_for_pdb_name = "/tmp/pdb_utlrp_result_for_" . $oracle_sid . "_" . $pdb_name;
                notify("do unlink $pdb_utlrp_result_for_pdb_name");
                unlink $pdb_utlrp_result_for_pdb_name if -e $pdb_utlrp_result_for_pdb_name;
            }
        }
    }

    # 对每个DB进行 datapatch
    notify("starting datapatch for every sid");
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name,$oracle_home);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name,$oracle_home);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }
        # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
        if ( $db_type eq "rac" ) {
            my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home);
            if ( $local_node_can_start_rac_db eq "no" ) {
                notify("local node can not start rac db $db_name, so skip it");
                next;
            }
        }

        # 只对主库进行datapatch 备库直接跳过
        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $open_mode ne "READ WRITE" ) {
            notify("Note: only READ WRITE can do datapatch, open mode for $oracle_sid is $open_mode");

            # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
            my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
            my $fd = IO::File->new("> $datapatch_result_for_sid");
            print $fd "datapatch skipped for standby db $oracle_sid\n";
            push @$datapatch_done_sid, $oracle_sid;
            $fd->close();

            # 启动MRP
            start_mrp($oracle_sid,$oracle_home);
            next;
        }

        # 检查当前实例是否有SYS和MDSYS的无效对象，如果有，就跳过，不做datapatch，避免组件失效
        my $sys_object_status = check_invalid_object_for_sys($oracle_sid,$oracle_home);
        notify("SID $oracle_sid sys_object_status is $sys_object_status");
        if ( $sys_object_status eq "error" ) {  # 做一次编译无效对象的操作
            compile_invalid_objects_for_a_sid($oracle_sid,$oracle_home);
            $sys_object_status = check_invalid_object_for_sys($oracle_sid,$oracle_home);
        }
        if ( $sys_object_status ne "ok" ) {
            if ( not defined $input->{force} ) {        # 指定 force 参数 可以继续运行datapatch
                notify("Error!  SYS/MDSYS has invalid object for SID $oracle_sid, can not do DATAPATCH");
                notify("    skip datapatch for $oracle_sid, because SID $oracle_sid sys_object_status is $sys_object_status");
                notify("    please retry, with --force");
                # 此处写入fork记录文件，标记为错误
                # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
                my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
                my $fd = IO::File->new("> $datapatch_result_for_sid");
                print $fd "datapatch for $oracle_sid skipped because sys has invalid objects\n";
                push @$datapatch_error_sid, $oracle_sid;
                $fd->close();

                next;
            }
        }
        record_invalid_object($oracle_sid,"before_datapatch");

        # 创建闪回点，如果不具备创建闪回点的条件，就跳过，不做datapatch
        create_restore_point($oracle_sid,$oracle_home) if defined $input->{create_restore_point_before_datapatch};
        # create_restore_point($oracle_sid,$oracle_home);

        # select currently_used, name from  dba_feature_usage_statistics where name like '%Java%';
        # SELECT comp_id, version, status FROM dba_registry WHERE comp_id='JAVAVM';

        my $sql;
        push @$sql, "set linesize 140;";
        push @$sql, "column name format a70;";
        push @$sql, "column comp_name format a50;";
        push @$sql, "column status format a10;";
        push @$sql, "SELECT comp_id, version, status FROM dba_registry WHERE comp_id='JAVAVM';";
        push @$sql, "select currently_used, name from  dba_feature_usage_statistics where name like '%Java%';";
        $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

        my $return = "ok";
        my @result = @{ $result };
        foreach my $line ( @result ) {
            notify("$line");
        }
        # JServer JAVA Virtual Machine                        VALID
        # FALSE  Oracle Java Virtual Machine (user)
        # TRUE   Oracle Java Virtual Machine (system)
        if ( $result[0] =~ m/JAVAVM/ ) {      # 有JVM组件
            notify("JServer JAVA Virtual Machine is installed");
            # 再检查 Oracle Java Virtual Machine (user) 是否为 FALSE
            my $tag = "-";
            foreach my $line ( @result ) {
                if ( $line =~ m/Oracle Java Virtual Machine \(user\)/ and $line =~ /FALSE/ ) {
                    notify("JAVAVM is installed but not used for $oracle_sid!");
                    $ojvm = "no";
                }
            }
        }
        else {
            notify("JServer JAVA Virtual Machine is not installed for $oracle_sid!");
            $ojvm = "no";
        }

        # 此处开始放入后台 以子进程方式运行
        # 删除标志文件
        my $pid = fork();
        my $fork_file = catfile("/tmp","fork_for_datapatch_$oracle_sid");
        if ( not defined $pid ) {
            notify("Error!  datapatch for $oracle_sid in fork is error!");
            next;
        }
        elsif ( $pid == 0 ) {   # 子进程
            notify("this is fork process, for datapatch, sid: $oracle_sid");
            notify("16231 pid is $pid");
            notify("16231 fork_file is $fork_file");
            do_datapatch_in_fork($oracle_sid,$oracle_home,$db_name_and_sid,$pid,$fork_file) if !-e $fork_file;
            exit 0;
        }
        else {  # 父进程
            notify("11301 pid is $pid");
            push @pids, $pid;
            next;
        }
    }

    # ========================
    # 等待所有子进程完成
    # ========================
    foreach my $pid (@pids) {
        waitpid($pid, 0);
    }
    notify("datapatch for all sid is done.");

    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $fork_file = catfile("/tmp","fork_for_datapatch_$oracle_sid");
        notify("do unlink $fork_file");
        unlink $fork_file if -e $fork_file;
    }

    # 执行第二阶段 utrlrp
    my @pids_for_utlrp;
    my @pids_for_pdb;

    notify("do utlrp.sql");
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 跳过备库
        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $open_mode ne "READ WRITE" ) {
            notify("Note: only READ WRITE can do utlrp.sql, open mode for $oracle_sid is $open_mode");

            # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
            my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
            my $fd = IO::File->new("> $cdb_utlrp_result_for_sid");
            notify("@?/rdbms/admin/utlrp.sql skipped , because open_mode for cdb $oracle_sid is $open_mode , must be READ_WRITE");
            print $fd "utlrp skipped , because open_mode for cdb $oracle_sid is $open_mode , must be READ_WRITE\n";
            $fd->close();

            next;
        }

        # 跳过 SYS和MDSYS 含有无效对象的库
        my $sys_object_status = check_invalid_object_for_sys($oracle_sid,$oracle_home);
        notify("SID $oracle_sid sys_object_status is $sys_object_status");
        if ( $sys_object_status eq "error" ) {  # 做一次编译无效对象的操作
            compile_invalid_objects_for_a_sid($oracle_sid,$oracle_home);
            $sys_object_status = check_invalid_object_for_sys($oracle_sid,$oracle_home);
        }
        if ( $sys_object_status ne "ok" ) {
            if ( not defined $input->{force} ) {
                notify("    skip utlrp.sql for $oracle_sid, because SID $oracle_sid sys_object_status is $sys_object_status");
                # 此处写入fork记录文件，标记为错误
                # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
                my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
                my $fd = IO::File->new("> $cdb_utlrp_result_for_sid");
                notify("@?/rdbms/admin/utlrp.sql skipped for cdb $oracle_sid because sys has invalid objects");
                print $fd "@?/rdbms/admin/utlrp.sql skipped because sys has invalid objects for $oracle_sid\n";
                $fd->close();

                next;
            }
        }

        # 此处应该重新fork
        my $pid = fork();
        my $fork_file = catfile("/tmp","fork_for_utlrp_$oracle_sid");

        if ( not defined $pid ) {
            notify("Error!  fork for $oracle_sid to utlrp is error! $!");
            next;
        }
        elsif ( $pid == 0 ) {
            # 子进程执行
            notify("this is fork process , for utlrp, sid: $oracle_sid");
            notify("16322 pid is $pid");
            notify("16322 fork_file is $fork_file");

            # 重新编译无效对象
            # do_utlrp_sql($oracle_sid,$oracle_home);
            do_utlrp_sql_using_catcon($oracle_sid,$oracle_home);    # 2026-01-19 7:11:20 19.13之后，utlrp.sql被替换成catcon
            # 此处要跳过不是 READ WRITE 模式的PDB
            # my $pdb_status = get_pdb_status($oracle_sid,$oracle_home);
            # foreach my $pdb ( @$pdb_status ) {
            #     my $pdb_name = $pdb->{name};
            #     my $open_mode = $pdb->{open_mode};
            #     if ( $open_mode ne "READ WRITE" ) {
            #         my $msg = "Error!  sid $oracle_sid PDB $pdb_name open_mode is $open_mode , can not do UTLRP !";
            #         notify($msg);
            #         print $error_fd "$msg\n";
            #         next;
            #     }
            #     next if $pdb_name eq 'CDB$ROOT';        # root cdb 前面已经执行过UTLRP了
            #
            #     # 此处对每个PDB进行并行操作 在fork里面再次进行fork
            #     my $pid02 = fork();
            #     if ( not defined $pid02 ) {
            #         notify("Error!  do_utlrp_sql_for_pdb for $oracle_sid PDB $pdb_name in fork is error!");
            #         next;
            #     }
            #     elsif ( $pid02 == 0 ) {
            #         notify("this is fork of fork process , for do_utlrp_sql_for_pdb, sid: $oracle_sid, pdb: $pdb_name");
            #         do_utlrp_sql_for_pdb($oracle_sid,$pdb_name,$oracle_home,$pid02);
            #         exit 0;
            #     }
            #     else {
            #         # 父进程记录 PID
            #         notify("16359 pid is $pid");
            #         push @pids_for_pdb, $pid;
            #     }
            # }

            # # ========================
            # # 等待第二层fork中的所有子进程完成
            # # ========================
            # foreach my $pid (@pids_for_pdb) {
            #     waitpid($pid, 0);
            # }

            record_invalid_object($oracle_sid,"after_datapatch");
            compare_invalid_object($oracle_sid);        # 分析比较无效对象

            # 检查cdb_registry_sqlpatch
            select_cdb_registry_sqlpatch($oracle_sid,$oracle_home);

            exit 0;
        }
        else {
            # 父进程记录 PID
            notify("16382 pid is $pid");
            push @pids_for_utlrp, $pid;
        }

    }

    # ========================
    # 等待所有utlrp子进程完成
    # ========================
    foreach my $pid (@pids_for_utlrp) {
        waitpid($pid, 0);
    }

    my ($datapatch_error_sid,$datapatch_done_sid,$datapatch_skip_sid);
    # 此处检查datapatch和utlrp操作的结果文件
    notify("*** datapatch is done.");
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $pdbs = get_pdb_list($oracle_sid,$oracle_home);
        notify("*** step_08_datapatch result for $oracle_sid:");

        my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
        next if !-e $datapatch_result_for_sid;
        notify("datapatch_result_for_sid for $oracle_sid is: $datapatch_result_for_sid","N");
        my @result = get_all_line($datapatch_result_for_sid);
        if ( grep { /sucesfull/ } @result ) {
            notify("datapatch for $oracle_sid is ok");
            push @$datapatch_done_sid, $oracle_sid;
        }
        elsif ( grep {/skipped because sys has invalid objects/ } @result ) {
            notify("Error!  datapatch for $oracle_sid is skipped sys has invalid objects");
            print $error_fd "Error!  datapatch for $oracle_sid is skipped sys has invalid objects!\n";
            push @$datapatch_skip_sid, $oracle_sid;
        }
        elsif ( grep {/skipped for standby db/ } @result ) {
            # notify("Warning! datapatch for $oracle_sid is skipped because standby");
            notify("datapatch for $oracle_sid is skipped because standby");
            # print $error_fd "Warning! datapatch for $oracle_sid is skipped because standby!\n";
            push @$datapatch_skip_sid, $oracle_sid;
        }
        elsif ( grep {/failed/ } @result ) {
            notify("Error!  datapatch for $oracle_sid is failed!");
            print $error_fd "Error!  datapatch for $oracle_sid is failed!\n";
            push @$datapatch_error_sid, $oracle_sid;
        }

        my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
        next if !-e $cdb_utlrp_result_for_sid;
        notify("    cdb_utlrp_result_for_sid for $oracle_sid is: $cdb_utlrp_result_for_sid","N");
        @result = get_all_line($cdb_utlrp_result_for_sid);
        if ( grep { /sucesfull/ } @result ) {
            notify("    utlrp.sql for $oracle_sid is ok");
        }
        elsif ( grep {/skipped for standby cdb/ } @result ) {
            notify("utlrp.sql skipped for standby cdb $oracle_sid");
        }
        elsif ( grep {/utlrp.sql skipped because sys has invalid objects/ } @result ) {
            notify("Error!  utlrp.sql skipped sys has invalid objects for $oracle_sid");
            print $error_fd "Error!  utlrp.sql skipped sys has invalid objects for $oracle_sid!\n";
        }
        elsif ( grep {/failed/ } @result ) {
            notify("Error!  utlrp.sql for $oracle_sid is failed!");
            print $error_fd "Error!  utlrp.sql for $oracle_sid is failed!\n";
        }

        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $pdbs->[0] ne "nopdb" and $open_mode eq "READ WRITE" ) {
            foreach my $pdb_name ( @$pdbs ) {
                # /tmp/pdb_utlrp_result_for_pdb_name
                my $pdb_utlrp_result_for_pdb_name = "/tmp/pdb_utlrp_result_for_" . $oracle_sid . "_" . $pdb_name;
                next if !-e $pdb_utlrp_result_for_pdb_name;
                notify("    pdb_utlrp_result_for_pdb_name for $oracle_sid.$pdb_name is: $pdb_utlrp_result_for_pdb_name","N");
                my @result = get_all_line($pdb_utlrp_result_for_pdb_name);
                if ( grep { /sucesfull/ } @result ) {
                    notify("    utlrp.sql for $oracle_sid.$pdb_name is ok");
                }
                elsif ( grep {/failed/ } @result ) {
                    notify("Error!  utlrp.sql for $oracle_sid.$pdb_name is failed!");
                    print $error_fd "Error!  utlrp.sql for $oracle_sid.$pdb_name is failed!\n";
                }
            }
        }
    }

    notify("****** datapatch result ***");
    foreach my $oracle_sid ( @$datapatch_done_sid ) {
        notify("\t sid $oracle_sid \t datapatch is done");
    }
    foreach my $oracle_sid ( @$datapatch_skip_sid ) {
        notify("\t sid $oracle_sid \t datapatch is skipped");
    }
    foreach my $oracle_sid ( @$datapatch_error_sid ) {
        notify("\t Error!  sid $oracle_sid \t datapatch has error, please check!");
        print $error_fd "Error!  sid $oracle_sid datapatch has error, please check!\n";
    }

    # 对每个SID 检查还原点是否存在
    my $restore_point_exists_global = "no";
    my $restore_point_name = $input->{restore_point_name} ? $input->{restore_point_name} : "restore_point_before_datapatch";
    # 对每个DB进行检查
    # my $db_name_and_sid_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $oracle_home = get_oracle_home_with_echo("$oracle_user");
        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $open_mode ne "READ WRITE" ) {
            notify("open mode for $oracle_sid is $open_mode , skip check restore_point_name");
            next;
        }

        my $sql;
        push @$sql, "set linesize 140;";
        push @$sql, "column restore_point format a20;";
        push @$sql, "column name format a80;";
        push @$sql, "select 'restore_point', name from v\$restore_point;";
        $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

        my @result01 = @{ $result };
        my $restore_point_exists = 'no';
        foreach my $line ( @result01 ) {
            next if $line !~ m/restore_point/;
            # notify("    $line",'A');
            if ( $line =~ m/$restore_point_name/i ) {
                $restore_point_exists = 'yes';
            }
        }

        if ( $restore_point_exists eq "yes" ) {
            $restore_point_exists_global = "yes";
            my $msg = "Error! RESTORE POINT $restore_point_name for sid $oracle_sid is existed";
            notify("$msg",'A');
            print $error_fd "$msg\n";
            $msg = "    # -- sid: $oracle_sid, DROP RESTORE POINT $restore_point_name;";
            notify("$msg",'A');

            # 要非常显目地提示，必须手动删除还原点
            # my $restore_point_name = $input->{restore_point_name} ? $input->{restore_point_name} : "restore_point_before_datapatch";
            notify("    restore_point_name is: $restore_point_name",'A');
            notify("    还原点的名称是       : $restore_point_name",'A');
            $msg = "Error!  datapatch is failed, must drop retore point for sid: $oracle_sid : $restore_point_name";
            notify("$msg",'A');
            print $error_fd "$msg\n";
            $msg = "Error!  datapatch失败，SID $oracle_sid 的还原点必须手动删除              : $restore_point_name";
            notify("$msg",'A');
            print $error_fd "$msg\n";
            $msg = "Error!  !!! do not forget";
            notify("$msg",'A');
            print $error_fd "$msg\n";
            $msg = "Error!  !!! 切记切记";
            notify("$msg",'A');
            print $error_fd "$msg\n";
        }
        else {
            my $msg = "RESTORE POINT $restore_point_name for sid $oracle_sid is not existed";
            notify( "    $msg");
        }
    }

    if ( $restore_point_exists_global eq "yes" ) {
        notify("    Some SID has restore point $restore_point_name");
    }
    else {
        notify("    no restore point $restore_point_name, all SID");
    }

    delete_backup_file_for_ru() if $env_type ne "crs" and $GLOBAL->{datapatch} eq "ok";

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task $step_name");
}

