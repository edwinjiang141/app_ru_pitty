        # my $cmd = "find $dir -name '*.tr*' -mtime +" . $keep_trace_days . ' -exec rm -rf {} \\;';
        my $cmd = "find $dir -name '*.tr*' -mtime +" . $keep_trace_days . ' | xargs rm -f';
        print $fd "    # $cmd\n";
    }

    # 清理监听日志
    print $fd "\n";
    print $fd "# clear listener logs\n";

    my $env_for_log;
    my $os_type;
    chomp ($os_type = `uname`);
    $env_for_log->{os_type} = $os_type;

    # 以下给出每个参数的默认值
    $env_for_log->{grid_user} = $grid_user;
    $env_for_log->{oracle_user} = $oracle_user;

    # 取得重要环境变量
    $env_for_log->{oracle_base} = get_oracle_base_with_echo($oracle_user);
    $env_for_log->{oracle_home} = get_oracle_home_with_echo($oracle_user);
    $env_for_log->{environment_type} = get_environment_type();
    $env_for_log->{env_type} = get_environment_type();
    if ( $env_for_log->{environment_type} ne "fs" ) {
        $env_for_log->{grid_home} = get_grid_home();
        $env_for_log->{grid_base} = get_grid_base();
        $env_for_log->{crs_home} = $env_for_log->{grid_home};
