    my $old_oracle_home = get_oracle_home_with_echo("$oracle_user");
    return if $old_oracle_home eq $target_oracle_home;

    unlink $cmd_log;
    unlink $error_log;

    # 取得$HOME路径
    my $cmd = "su - $oracle_user -c 'echo \$HOME'";
    my $result = execute_cmd($cmd);
