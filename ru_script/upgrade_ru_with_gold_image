sub check_jvm {
    notify("*** check_jvm",'A');
    my ($fd) = @_;
    print $fd "\n";
    print $fd "# check OJVM\n";

    my $ojvm_global = "no";
    # 对每个DB进行 datapatch
    my $db_name_and_sid_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $ojvm = "no";
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }

        # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
        if ( $db_type eq "rac" ) {
            my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name);
            if ( $local_node_can_start_rac_db eq "no" ) {
                notify("local node can not start rac db $db_name, so skip it");
                next;
            }
        }

        # 此处检查每个实例的OPEN_MODE
        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $open_mode !~ m/read/i ) {
            my $msg = "Error!  SID $oracle_sid OPEN MODE is $open_mode";
            notify("$msg");
            print $fd "    # $msg\n";
            print $error_fd "$msg\n";
            next;
        }

        # select currently_used, name from  dba_feature_usage_statistics where name like '%Java%';
        # SELECT comp_id, version, status FROM dba_registry WHERE comp_id='JAVAVM';

        my $sql;
        push @$sql, "set linesize 140;";
        push @$sql, "column name format a70;";
        push @$sql, "column comp_name format a50;";
        push @$sql, "column status format a10;";
        push @$sql, "SELECT comp_id, version, status FROM dba_registry WHERE comp_id='JAVAVM';";
        push @$sql, "select currently_used, name from  dba_feature_usage_statistics where name like '%Java%';";
        $result = do_sql_oracle($sql,$oracle_sid);

        my $return = "ok";
        foreach my $line ( @$result ) {
            notify("    $line");
        }
        # JServer JAVA Virtual Machine                        VALID
        # Elapsed: 00:00:00.04
        # FALSE  Oracle Java Virtual Machine (user)
        # TRUE   Oracle Java Virtual Machine (system)
        # Elapsed: 00:00:00.01
        if ( $result->[0] =~ m/JAVAVM/ ) {      # 有JVM组件
            notify("JServer JAVA Virtual Machine is installed");
            # 再检查 Oracle Java Virtual Machine (user) 是否为 FALSE
            my $tag = "-";
            foreach my $line ( @$result ) {
                if ( $line =~ m/Oracle Java Virtual Machine \(user\)/ and $line =~ /FALSE/ ) {
                    notify("JAVAVM is installed but not used for $oracle_sid");
                    print $fd "    # JAVAVM is installed but not used for $oracle_sid\n";
                    $ojvm = "no";
                }
                if ( $line =~ m/Oracle Java Virtual Machine \(user\)/ and $line =~ /TRUE/ ) {
                    # notify("Warning! JAVAVM is installed and been used, must do OJVM datapatch for $oracle_sid!");
                    notify("JAVAVM is installed and been used for $oracle_sid!");
                    print $fd "    # Warning! JAVAVM is installed and been used for $oracle_sid\n";
                    $ojvm = "yes";
                }
            }
        }
        else {
            notify("JServer JAVA Virtual Machine is not installed for $oracle_sid");
            print $fd "    # JServer JAVA Virtual Machine is not installed\n";
            $ojvm = "no";
        }

        if ( $ojvm eq "yes" ) {
            $ojvm_global = "yes";
            # notify("Warning! JAVAVM is installed and been used, must do OJVM datapatch for $oracle_sid!");
            notify("JAVAVM is installed and been used for $oracle_sid!");
            print $fd "    # Warning! JAVAVM is installed and been used for $oracle_sid\n";
            # print $fd "    # MUST DO ojvm datapatch for $oracle_sid\n";
        }
        else {
            print $fd "    # NOT DO ojvm datapatch for $oracle_sid\n";
        }
    }

    if ( $ojvm_global eq "yes" ) {
        print $fd "    # MUST APPLY ojvm patch\n";
    }
    else {
        print $fd "    # NO NEED to apply ojvm patch\n";
    }

    return $ojvm_global;
}

