sub get_crs_releasepatch {
    my ($grid_home) = @_;
    notify("    get_crs_releasepatch for $grid_home");
    # Oracle Clusterware release patch level is [476343201] and the complete list of patches [26839277 28566910 28662603 28662626 28662640 ] have been applied on the local node.
    # Oracle Clusterware release patch level is [724960844] and the complete list of patches [29401763 29517242 29517247 29585399 ] have been applied on the local node. The release patch string is [19.3.0.0.0].
    my $crsctl = catfile($grid_home,"bin/crsctl");
    my $cmd;
    $cmd = "$crsctl query crs releasepatch" if $env_type eq "crs";
    $cmd = "$crsctl query has releasepatch" if $env_type eq "has";
    my $result = execute_cmd($cmd);
    my ($crs_releasepatch) = $result->[0] =~ m/patch level is\s+\[(\d+)\]\s+/;
    notify("    crs_releasepatch is $crs_releasepatch");
    return $crs_releasepatch;
}

