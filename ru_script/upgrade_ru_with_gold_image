    $result = execute_cmd($cmd);
    my $shell = $result->[0];
    notify("shell for $oracle_user is $shell",'A');

    # 如果SHELL是bash，PROFILE是.bash_profile
    # 如果SHELL是sh，profile是.profile
    my $profile;
    if ( $shell =~ m/\/bash/ ) {
        $profile = ".bash_profile";
    }
    elsif ( $shell =~ m/\/sh/ ) {
        $profile = ".profile";
    }
    elsif ( $shell =~ m/\/ksh/ ) {
        $profile = ".profile";
    }

    my $profile_path = catfile($home,$profile);
    my $profile_backup_file_name = $profile . ".backup_for_RU_upgrade." . get_locatime_for_file();
    my $profile_backup_file_path = catfile($home,$profile_backup_file_name);
    notify("copy $profile_path to $profile_backup_file_path",'A');
    copy($profile_path,$profile_backup_file_path);
    if ( !-e $profile_backup_file_path ) {
        notify("Error!  copy $profile_path to $profile_backup_file_path is failed !",'A');
        exit 1;
    }

    # 此时grid用户的profile已经被修改，不能直接获取$old_grid_home，需要从step_03的备份中获取
    my $old_grid_home = "not_find";
    $old_grid_home = get_old_grid_home_from_step_03() if $env_type ne "fs";

    # 修改
    notify("modify ORACLE_HOME from $old_oracle_home to $target_oracle_home",'A');
    my @profile = `cat $profile_path`;
    my $new_profile;
    foreach my $a ( @profile ) {
        chomp $a;
        #print("$a\n");
        if ( $a =~ m/\bexport\s+ORACLE_HOME=/ and $a !~ m/^\s*#/ ) {        # 如果前面没有注释，并且包含export ORACLE_HOME这一行
            # 前面加上注释
            $a =~ s/^/# /;
            push @$new_profile, $a;
            # 修改成新路径
            $a = "export ORACLE_HOME=$target_oracle_home";
        }
        if ( $a =~ m/\bORACLE_HOME=/ and $a !~ m/^\s*#/ ) {             # 如果前面没有注释，并且包含ORACLE_HOME这一行
            # 前面加上注释
            $a =~ s/^/# /;
            push @$new_profile, $a;
            # 修改成新路径
            $a = "export ORACLE_HOME=$target_oracle_home";
        }
        if ( $a =~ m/\bexport\s+GI_HOME=/ and $a !~ m/^\s*#/ ) {        # 如果前面没有注释，并且包含export GI_HOME这一行
            # 前面加上注释
            $a =~ s/^/# /;
            push @$new_profile, $a;
            # 修改成新路径
            $a = "export GI_HOME=$target_grid_home";
        }
        if ( $a =~ m/\bGI_HOME=/ and $a !~ m/^\s*#/ ) {        # 如果前面没有注释，并且包含GI_HOME这一行
            # 前面加上注释
            $a =~ s/^/# /;
            push @$new_profile, $a;
            # 修改成新路径
            $a = "export GI_HOME=$target_grid_home";
        }
        if ( $a =~ m/\bGRID_HOME=/ and $a !~ m/^\s*#/ ) {        # 如果前面没有注释，并且包含GRID_HOME这一行
            # 前面加上注释
            $a =~ s/^/# /;
            push @$new_profile, $a;
            # 修改成新路径
            $a = "export GRID_HOME=$target_grid_home";
        }
        if ( $a =~ m/\bexport\s+GRID_HOME=/ and $a !~ m/^\s*#/ ) {        # 如果前面没有注释，并且包含export GRID_HOME这一行
            # 前面加上注释
            $a =~ s/^/# /;
            push @$new_profile, $a;
            # 修改成新路径
            $a = "export GRID_HOME=$target_grid_home";
        }
        # 替换绝对路径 $grid_home 和 $oracle_home
        if ( $a =~ m/$old_oracle_home\b/ ) {
            $a =~ s/$old_oracle_home/$target_oracle_home/g;
        }
        if ( $old_grid_home ne "not_find" ) {
            if ( $a =~ m/$old_grid_home\b/ ) {
                $a =~ s/$old_grid_home/$target_grid_home/g;
            }
        }

        push @$new_profile, $a;
    }
    # printx $new_profile;
    notify("rewrite $profile_path",'A');
    open myFile , "> $profile_path";
    foreach my $a ( @$new_profile ) {
        print myFile "$a\n";
    }
    close myFile;
    notify("write $profile_path done",'A');

    # 修改第2个profile 此文件不是每个环境都有，如无可忽略
    my $profile_second = catfile($home,"profile");
    if ( -e $profile_second ) {
        notify("modify second profile for oracle",'A');
        my $profile_backup_file_path = $profile_second . ".profile02_backup";
        notify("copy $profile_second to $profile_backup_file_path",'A');
        copy($profile_second,$profile_backup_file_path);
        if ( !-e $profile_backup_file_path ) {
            notify("Error!  copy $profile_second to $profile_backup_file_path is failed !",'A');
            exit 1;
        }
        replace_oracle_home_for_a_file($profile_second,$old_grid_home,$target_grid_home);
        replace_oracle_home_for_a_file($profile_second,$old_oracle_home,$target_oracle_home);
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task modify_oracle_profile");
}

sub get_old_grid_home_from_step_03 {
    # 找出最新的备份，取得 ORACLE_HOME
    # 取得$HOME路径
    my $cmd = "su - $grid_user -c 'echo \$HOME'";
    my $result = execute_cmd($cmd);
