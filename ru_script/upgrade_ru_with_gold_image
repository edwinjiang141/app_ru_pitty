sub start_database_using_srvctl_fork {
    my ($db_name_and_sid,$input_oracle_home,$pid,$fork_file,$start_result) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};

    notify("start_database_using_srvctl_fork for $db_name, pid is $pid",'A');
    notify("do touch $fork_file",'A');
    system("touch $fork_file");

    if ( $env_type eq "fs" ) {
        start_instance_fork($db_name_and_sid,$oracle_home,$pid,$fork_file,$start_result);
        return;
    }

    my $time_start = time();

    unlink $cmd_log;
    unlink $error_log;
    my $get_random = get_random();
    my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
    my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
    notify("    cmd_log   is $cmd_log",'A');

    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");
    my $srvctl = catfile($oracle_home,"bin/srvctl");
    my $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl start database -d $db_name' 1>$cmd_log 2>$error_log";
    notify("    cmd is $cmd",'A');
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);

    $get_random = get_random();
    $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
    $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
    notify("    cmd_log   is $cmd_log",'A');

    if ( $env_type eq "crs" ) {
        # 此处添加检查语句
        my $all_node_hostname = get_all_node_hostname();
        my $nodes = join(',',@$all_node_hostname);
        # srvctl status instance -db orcl -node rac12c01
        my $hostname = get_local_host_name();
        my $db_type = get_srvctl_database_type($db_name,$oracle_home,"fork");
        $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status instance -d $db_name -n $nodes' 1>$cmd_log 2>$error_log" if $db_type eq "rac";
        $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status database -d $db_name' 1>$cmd_log 2>$error_log" if $db_type eq "rac_one_node";
    }
    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status database -d $db_name' 1>$cmd_log 2>$error_log" if $env_type eq "has";
    notify("    cmd is $cmd",'A');
    system($cmd);

    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    my $tag = "no";
    foreach my $line ( @$result1 ) {
        if ( $line =~ m/is running/ ) {
            $tag = "yes";
        }
    }
    if ( $tag eq "yes" ) {
        notify("srvctl start database -d $db_name is done",'A');
        # 此处写入 ok 到result文件
        my $fd = IO::File->new("> $start_result");
        print $fd "ok! srvctl start database -d $db_name is done.\n";
        $fd->close();
    }
    else {
        my $msg = "Error!  srvctl start database -d $db_name has error";
        notify("$msg",'A');
        print $error_fd "$msg\n";
        # 此处写入 error 到result文件
        my $fd = IO::File->new("> $start_result");
        print $fd "error! srvctl start database -d $db_name has error.\n";
        $fd->close();
    }

    # 打开所有节点的PDB , 如果是RAC ONE NODE，要先检查本地是否启动了实例
    my $db_type = get_srvctl_database_type($db_name,$oracle_home);
    my $srvctl_instance_status = get_local_srvctl_instance_status($db_name);
    if ( $db_type eq "rac_one_node" ) {
        if ( $srvctl_instance_status eq "running_at_local" ) {
            my $pdb = check_pdb($oracle_sid);
            # 打开所有节点的PDB
            open_pdb_all_node($oracle_sid) if $pdb eq "yes";
        }
    }
    # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
    elsif ( $db_type eq "rac" ) {
        my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name);
        if ( $local_node_can_start_rac_db eq "no" ) {
            notify("local node can not start rac db $db_name, so skip it");
        }
        else {
            my $pdb = check_pdb($oracle_sid);
            # 打开所有节点的PDB
            open_pdb_all_node($oracle_sid) if $pdb eq "yes";
        }
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task start_database_using_srvctl_fork for $db_name");
}

