sub get_inventory_loc {
    # 根据操作系统读取 oraInst.loc
    my $ora_inst_loc;
    my $os_type;
    chomp ($os_type = `uname`);
    if ( lc $os_type eq "linux" ) {
        $ora_inst_loc = "/etc/oraInst.loc";
    }
    elsif ( lc $os_type eq "aix" ) {
        $ora_inst_loc = "/etc/oraInst.loc";
    }
    notify("    get_inventory_loc from $ora_inst_loc");
    my @ora_inst_loc = get_all_line($ora_inst_loc);
    # 取得  inventory_loc=/u01/app/oraInventory
    #       inst_group=oinstall
    my ($inventory_loc,$inst_group);
    foreach my $line ( @ora_inst_loc ) {
        if ( $line =~ m/inventory_loc/i ) {
            my @F = split /=/,$line;
            $inventory_loc = $F[1] if defined $F[1];
        }
        if ( $line =~ m/inst_group/i ) {
            my @F = split /=/,$line;
            $inst_group = $F[1] if defined $F[1];
        }
    }
    notify("    ora_inst_loc : $ora_inst_loc");
    notify("    inventory_loc: $inventory_loc");
    notify("    inst_group   : $inst_group");
    return($inventory_loc,$inst_group);
}

#初始化日志，将日志文件权限修改为o+w,g+w，当日志大于100M时，删除它
sub init_log {
    my $log_dir = shift;
    #初始化日志 日志默认在$HOME下，除非指定 --log_dir 参数
    if ( not defined $log_dir ) {
        $log_dir = catfile($ENV{HOME},"oTools_log") if defined $ENV{HOME} and -e $ENV{HOME};      # 取得用户的$HOME环境变量
        $log_dir = "/tmp" if not defined $log_dir;
    }
    if ( !-e $log_dir ) {
        mkdir $log_dir or die "Can't mkdir : $log_dir";
    }

    my $host_name;
    chomp ($host_name = `hostname`);
    $host_name = (split /\./,$host_name)[0];

    my $time_str = strftime '%Y-%m-%d %H:%M:%S', localtime;

    my $log_file_name = "oTools_"  . $host_name . ".log";
    $log_file_path = catfile ($log_dir, $log_file_name);

    #如果日志超过500M，则删除
    if ( -e $log_file_path ) {
       my @size = `du -sk $log_file_path`;
       my $size = shift @size;
       $size = (split /\s/,$size)[0];
       if ( $size > 502400 ) {
            #system ("rm -rf $log_file_path");
            unlink $log_file_path;
            #建立文件，并且改权限为g+w,o+w
            system ("touch $log_file_path");
            system ("chmod o+w $log_file_path");
            system ("chmod g+w $log_file_path");
       }
    }
    else {
        #建立文件，并且改权限为g+w,o+w
        system ("touch $log_file_path");
        system ("chmod o+w $log_file_path");
        system ("chmod g+w $log_file_path");
    }

    #以追加模式打开日志，写入当前时间
    $log_fd = IO::File->new(">> $log_file_path");
    print $log_fd "Oracle ACS oTools started.\n";
    print $log_fd "    time     : $time_str\n";
    print $log_fd "    filename : $0\n";
    print $log_fd "    ARGV     : \n" if defined $ARGV[0];
    print $log_fd "    no ARGV  . \n" if not defined $ARGV[0];
    # 打印所有参数
    foreach my $parameter ( @ARGV ) {
        print $log_fd "             $parameter\n";
    }

    # 初始化错误日志
    my $error_log_file_name = "Error_Message_"  . get_locatime_for_file() . ".log";
    $error_log_file_path = catfile ($log_dir, $error_log_file_name);
    unlink $error_log_file_path if -e $error_log_file_path;
    $error_fd = IO::File->new("> $error_log_file_path");
    print $error_fd "****** Error Messages:\n";

    #return $log_file_path;
}

sub notify {
    my ($txt,$tag) = @_;

    # 1>/tmp/cmd_log 2>/tmp/error_log 这些内容不打印
    # $txt =~ s/1>\/tmp\/cmd_log//g;
    # $txt =~ s/2>\/tmp\/error_log//g;

    #将传入的文本，写入到日志，加上时间戳
    #同时打印到屏幕，除非指定 tag = N

    my $time_str = strftime '%Y-%m-%d %H:%M:%S', localtime;
    print $log_fd "$time_str\t";
    print "$time_str\t" unless defined $tag and lc $tag eq 'n';

    my $print;
    if ( $txt =~ m/^\*\*\*\s/ ) {       # 如果是3个*，就顶格打印，不带*，就加两个空格
        $txt =~ s/^\*\*\*\s//g;
        $print = "$txt\n";
    }
    elsif ( $txt =~ m/^\*\*\*\*/ ) {    # 如果是6个*，替换掉3个*
        $txt =~ s/^\*\*\*//;
        $print = "$txt\n";
    }
    elsif ( $txt =~ m/^\s*Error/i ) {
        # print "\033[31m这是红色文本\033[0m\n";  # \033[31m开启红色，\033[0m重置颜色
        my $red = "\033[31m";
        my $reset = "\033[0m";
        $txt =~ s/^\s*//g;
        # $txt = $red . $txt . $reset;
        $txt =~ s/(Error)/$red$1$reset/;
        $print = "!!! $txt\n";
    }
    else {
        $print = "    $txt\n";
    }

    print $log_fd $print;
    print $print unless defined $tag and lc $tag eq 'n';

}

sub printx {
    my $input = shift;

    my $type_input = ref($input);
    $type_input = "str" if not defined $type_input;
    print "input type: $type_input\n" if length $type_input > 3;

    if ( $type_input eq "HASH") {   #是HASH的引用
        foreach my $key ( sort keys %$input ) {
            print "key: $key\n";
            my $value = $input->{$key};
            printx($value);
        }
    }
    elsif ( $type_input eq "ARRAY" ) {
        foreach my $list ( @$input ) {
            printx($list);
        }
    }
    else {  #不是任何引用，是实际的字符串
        if ( defined $input ) {
            print("    value -> $input\n");
        }
    }
}

sub print_hash {
    my $input = shift;

    my $type_input = ref($input);
