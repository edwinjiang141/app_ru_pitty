        my $msg = "Error!  ALTER PLUGGABLE DATABASE ALL OPEN for $oracle_sid has error";
        notify("$msg");
        print $error_fd "$msg\n";
    }

    # 此处检查PDB的状态
    my $pdb_status = get_pdb_status($oracle_sid,$oracle_home);
    foreach my $pdb ( @$pdb_status ) {
        my $pdb_name = $pdb->{name};
        my $open_mode = $pdb->{open_mode};
        if ( $open_mode ne "READ WRITE" ) {
            my $msg = "Error!  sid $oracle_sid PDB $pdb_name open_mode is $open_mode , please check !";
            notify($msg);
            print $error_fd "$msg\n";
        }
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to open_pdb for $oracle_sid");
}

