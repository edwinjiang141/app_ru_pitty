sub get_progress {
    notify("get_progress",'A');
    my ($progress_file,$progress_list) = @_;

    my @progress_file = get_all_line_without_null($progress_file);
    my @F = split /=/, $progress_file[0];
    my $progress = $F[1];
    my $idx = 0;
    foreach my $a ( @$progress_list ) {
        $idx ++;
        last if $progress eq $a;
    }
    notify("    progress is: $progress, idx is: $idx",'A');

    return ($progress,$idx);
}

sub update_progress_file {
    notify("update_progress_file",'A');
    my ($progress_file,$progress) = @_;

    my @progress_file = get_all_line_without_null($progress_file);

    my $fd = IO::File->new("> $progress_file");
    my $line = "done=$progress";
    print $fd "$line\n";
    $fd->close();
}

