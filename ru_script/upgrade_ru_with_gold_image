                        notify("$msg",'A');
                        print $fd "    # $msg\n";
                        print $error_fd "$msg\n";
                    }
                }
                else {
                    my $msg = "Error! path for db_recovery_file_dest is not exists";
                    notify("$msg",'A');
                    print $fd "    # $msg\n";
                    print $error_fd "$msg\n";
                }
            }
        }
    }

    if ( not defined $db_recovery_file_dest ) {
        my $msg = "Error! db_recovery_file_dest is not defined, please check db_recovery_file_dest";
        notify("$msg",'A');
        print $fd "    # $msg\n";
        print $error_fd "$msg\n";
    }
