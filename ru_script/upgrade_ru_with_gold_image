sub oinstall_group_add {
    # 升级到19.14之后，如果oracle用户没有出现在/etc/group的oinstall这一列中，oracle的数据库实例无法与ASM实例做通信，无法MOUNT
    # 所以需要将oracle用户添加进oinstall组
    notify("    oinstall_group_add",'A');

    my $sqlplus_version = get_sqlplus_version();

    my @file = get_all_line("/etc/group");
    my $tag;
    foreach my $line ( @file ) {
        next if $line !~ m/^$group_for_oinstall/;
        notify("    $line",'A');
        $tag->{oracle_not_in_oinstall} = "yes" if $line !~ m/$oracle_user/;
        $tag->{grid_not_in_oinstall} = "yes" if $line !~ m/$grid_user/;
    }
    my $cmd;
    if ( $sqlplus_version =~ m/19/ ) {
        if ( defined $tag->{oracle_not_in_oinstall}  ) {
            $cmd = "usermod -a -G $group_for_oinstall $oracle_user";
            notify("    cmd is $cmd",'A');
        }
        elsif ( defined $tag->{grid_not_in_oinstall} and $env_type ne "fs" ) {
            $cmd = "usermod -a -G $group_for_oinstall $grid_user";
            notify("    cmd is $cmd",'A');
        }
        else {
            notify("    $oracle_user is in $group_for_oinstall",'A') if $env_type eq "fs";
            notify("    $grid_user and $oracle_user is in $group_for_oinstall",'A') if $env_type eq "crs" or $env_type eq "has";
        }
    }
    else {
        notify("    sqlplus_version is $sqlplus_version, not affected by oinstall group displayed in /etc/group",'A');
    }
}

sub oinstall_group_add_OLD {
    # 升级到19.14之后，如果oracle用户没有出现在/etc/group的oinstall这一列中，oracle的数据库实例无法与ASM实例做通信，无法MOUNT
    # 所以需要将oracle用户添加进oinstall组

    my $sqlplus_version = get_sqlplus_version();

    my @file = get_all_line("/etc/group");
    my $tag;
    foreach my $line ( @file ) {
        next if $line !~ m/^oinstall/;
        notify("$line",'A');
        $tag->{oracle_not_in_oinstall} = "yes" if $line !~ m/$oracle_user/;
        $tag->{grid_not_in_oinstall} = "yes" if $line !~ m/$grid_user/;
    }
    my $cmd;
    if ( $sqlplus_version =~ m/19/ ) {
        if ( defined $tag->{oracle_not_in_oinstall}  ) {
            $cmd = "usermod -a -G oinstall $oracle_user";
            notify("    cmd is $cmd",'A');
        }
        elsif ( defined $tag->{grid_not_in_oinstall} and $env_type ne "fs" ) {
            $cmd = "usermod -a -G oinstall $grid_user";
            notify("    cmd is $cmd",'A');
        }
        else {
            notify("$oracle_user is in oinstall",'A') if $env_type eq "fs";
            notify("$grid_user and $oracle_user is in oinstall",'A') if $env_type eq "crs" or $env_type eq "has";
        }
    }
    else {
        notify("sqlplus_version is $sqlplus_version, not affected by oinstall group displayed in /etc/group",'A');
    }
}

