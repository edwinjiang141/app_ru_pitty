    precheck_for_nbcb($fd) if defined $input->{vip_for_nbcb};    # --vip_for_nbcb  宁波银行

    $fd->close();

    notify("precheck_file is write to $precheck_file");

    # 检查文件内容
    my @precheck_file = get_all_line_with_space($precheck_file);
