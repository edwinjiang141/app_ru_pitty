sub precheck_for_nbcb {
    my ($fd) = @_;
    # grid_home   必须是        /u01/grid/product/19.0.0/grid_1
    # oracle_home 必须是        /u01/app/product/19.0.0/db_1

    # 取得当前 GI_HOME和DB_HOME
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        my $grid_home = get_oracle_home_with_echo("$grid_user");

        if ( $grid_home ne "/u01/grid/product/19.0.0/grid_1" ) {
            my $msg = "Error!  grid_home must be /u01/grid/product/19.0.0/grid_1";
            notify( "$msg");
            print $error_fd "$msg\n";
            print $fd "    # $msg\n";
        }
