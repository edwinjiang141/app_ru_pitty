sub step_09_verify {
    my $step_name = "step_09_verify";
    notify("*** starting $step_name",'A');
    my $time_start = time();
    my $tag = "ok";

    my $time_str = strftime '%Y-%m-%d %H:%M:%S', localtime;
    my $hostname = get_local_host_name();
    my $verify_file = catfile($log_dir, "verify_for_ru_" . $hostname . ".acs");
    # 写入记录文件 每次都重写覆盖
    my $fd = IO::File->new("> $verify_file");

    # 检查软件版本
    my ($oracle_home,$grid_home,$crsctl);
    $oracle_home = get_oracle_home_with_echo("$oracle_user");

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        $grid_home = get_oracle_home_with_echo("$grid_user");
        $crsctl = catfile($grid_home,"bin/crsctl");
        my $cmd;
        $cmd = "$crsctl query crs releasepatch" if $env_type eq "crs";
        $cmd = "$crsctl query has releasepatch" if $env_type eq "has";
        my $result = execute_cmd($cmd);
        my $crs_patch;
        my $sqlplus_version = get_sqlplus_version();
        ($crs_patch) = $result->[0] =~ m/release patch string is \[(.*?)\]/ if $sqlplus_version =~ m/^19/;
        ($crs_patch) = $result->[0] =~ m/patch level is \[(.*?)\]/ if $sqlplus_version =~ m/^12/;

        notify("crs_patch is $crs_patch");      # 此处需要判断版本是否正确
    }

    # 检查 opatch lspatches 一致
    my $tag01 = check_lspatches_between_rac_node() if $env_type eq "crs";

    # 验证RU补丁
    my $tag02 = opatch_lspatches_verify_from_lspatches();

    # 检查 oui-patch.xml
    my $tag03 = check_oui_patch_xml() if $env_type eq "crs";

    # 检查节点间crs version是否一致
    my $tag04 = check_crs_releasepatch_between_rac_node() if $env_type eq "crs";   # error_for_crs_releasepatch

    # 检查节点间sqlplus版本是否一致
    my $tag06 = check_sqlplus_version_between_rac_node() if $env_type eq "crs";   # error_for_sqlplus_version

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        # 检查ASM实例
        my $cmd = "ps -ef|grep dbw0|grep ASM|grep -v grep";
        my $result = execute_cmd($cmd);
        if ( not defined $result->[0] ) {
            my $msg = "Error!  ASM is not running";
            notify("$msg");
            print $error_fd "$msg\n";
            $tag = "error";
        }
        else {
            notify("ASM is running");
        }
        # 检查CRS
        my $tag_global = "ok";
        check_crs($fd,$tag_global,"verify");
    }

    check_oracle_bin_permission();              # 检查文件权限

    # 检查DB实例
    my $tag_for_datapatch;
    my $db_name_and_sid_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_and_sid_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $oracle_home = get_oracle_home_with_echo("$oracle_user");

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }
        # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
        if ( $db_type eq "rac" ) {
            my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name);
            if ( $local_node_can_start_rac_db eq "no" ) {
                notify("local node can not start rac db $db_name, so skip it");
                next;
            }
        }

        my $dbstatus = check_db_process($oracle_sid);
        if ( $dbstatus ne "db_is_running" ) {
            my $msg = "Error!  database instance $oracle_sid is not running";
            notify("$msg");
            print $error_fd "$msg\n";
        }
        else {
            notify("database instance $oracle_sid is running");
            compare_invalid_object($oracle_sid);            # 分析比较无效对象
            $tag_for_datapatch = check_cdb_registry_sqlpatch($oracle_sid);       # 分析 cdb_registry_sqlpatch

            # 检查还原点是否存在 存在是不正确的
            my $restore_point_name = $input->{restore_point_name} ? $input->{restore_point_name} : "restore_point_before_datapatch";
            my $sql;
            push @$sql, "set linesize 140;";
            push @$sql, "column restore_point format a20;";
            push @$sql, "column name format a80;";
            push @$sql, "select 'restore_point', name from v\$restore_point;";
            $result = do_sql_oracle($sql,$oracle_sid,$oracle_home);

            my @result01 = @{ $result };
            my $restore_point_exists = 'no';
            foreach my $line ( @result01 ) {
                next if $line !~ m/restore_point/;
                # notify("    $line",'A');
                if ( $line =~ m/$restore_point_name/i ) {
                    $restore_point_exists = 'yes';
                }
            }

            if ( $restore_point_exists eq "yes" ) {
                my $msg = "Error! RESTORE POINT $restore_point_name for sid $oracle_sid is existed";
                notify("$msg",'A');
                print $fd "    # $msg\n";
                print $error_fd "$msg\n";
                $msg = "    # -- sid: $oracle_sid, DROP RESTORE POINT $restore_point_name;";
                notify("$msg",'A');
                print $fd "    # $msg\n";
                $tag = "error";
            }
            else {
                my $msg = "RESTORE POINT $restore_point_name for sid $oracle_sid is not existed";
                notify( "    $msg");
                print $fd "    # $msg\n";
            }
        }

    }

    recored_opatch_lspatches("$grid_user","new",$grid_home) if $env_type eq "crs" or $env_type eq "has";
    recored_opatch_lspatches("$oracle_user","new",$oracle_home);

    compare_service_from_record();      # 检查service启动的实例是否与记录文件一致

    # $tag = "error" if defined $tag01 and $tag01 ne "do_not_print_file";  # opatch lspatches 可以不一致，只需要记录即可
    $tag = "error" if defined $tag02 and $tag02 ne "ok";
    $tag = "error" if defined $tag03 and $tag03 ne "do_not_print_file";
    $tag = "error" if defined $tag04 and $tag04 ne "do_not_print_file";
    $tag = "error" if defined $tag06 and $tag06 eq "error_for_sqlplus_version";    # error_for_sqlplus_version
    $tag = "error" if defined $tag_for_datapatch and $tag_for_datapatch ne "ok";

    # 检查 /etc/rsyslog.conf
    restore_rsync();
    check_rsync($fd) if defined $input->{check_rsync};

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task $step_name");
    exit 1 if $tag ne "ok";
}

