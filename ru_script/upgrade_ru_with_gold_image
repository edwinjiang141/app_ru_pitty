sub start_instance {
    my ($db_name_and_sid,$input_oracle_home) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    notify("start_instance for $db_name",'A');
    my $time_start = time();

    my $srvctl = catfile($oracle_home,"bin/srvctl");
    my $hostname = get_local_host_name();
    my $cmd;

    my $db_type = get_srvctl_database_type($db_name,$oracle_home);
    my $srvctl_instance_status = get_local_srvctl_instance_status($db_name,$oracle_home);
    my $local_node_can_start_rac_one_node = local_node_can_start_rac_one_node($db_name,$oracle_home);
    # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
    if ( $db_type eq "rac" ) {
        my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home);
        if ( $local_node_can_start_rac_db eq "no" ) {
            notify("local node can not start rac db $db_name, so skip it");
            return;
        }
    }

    my $dbstatus = check_db_process($oracle_sid);
    if ( $db_type eq "rac_one_node" ) {# rac one node 要确认本地节点有资格启动这个实例
        if ( $local_node_can_start_rac_one_node eq "yes" ) {
            if ( $srvctl_instance_status eq "not_running" ) {
                startup_instance_to_mount($oracle_sid,$oracle_home);
                alter_database_open($oracle_sid,$oracle_home);
            }
            # 此处，如果有进程，还需要进一步判断它是什么OPEN_MODE，判断过程交给 alter_instance_to_open
            elsif ( $srvctl_instance_status eq "running_at_local" ) {
                alter_instance_to_open($oracle_sid,$oracle_home);
            }
        }
    }
    else {
        if ( $dbstatus eq "db_is_not_running" ) {
            startup_instance_to_mount($oracle_sid,$oracle_home);
            alter_database_open($oracle_sid,$oracle_home);
        }
        # 此处，如果有进程，还需要进一步判断它是什么OPEN_MODE，判断过程交给 alter_instance_to_open
        else {
            alter_instance_to_open($oracle_sid,$oracle_home);
        }
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        unlink $cmd_log;
        unlink $error_log;
        my $get_random = get_random();
        my $cmd_log = "/tmp/cmd_log_" . $db_name . "_" . $get_random . ".log";
        my $error_log = "/tmp/error_log_" . $db_name . "_" . $get_random . ".log";
        notify("    cmd_log   is $cmd_log",'A');

        if ( $env_type eq "crs" ) {
            if ( $db_type eq "rac" ) {
                $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl start instance -d $db_name -instance $oracle_sid' 1>$cmd_log 2>$error_log";
            }
            elsif ( $db_type eq "rac_one_node" ) {
                # 确认本地节点有资格启动这个实例
                if ( $local_node_can_start_rac_one_node eq "yes" ) {
                    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl start database -d $db_name' 1>$cmd_log 2>$error_log";
                }
                else {
                    $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl status database -d $db_name' 1>$cmd_log 2>$error_log";
                }
            }
        }
        elsif ( $env_type eq "has" ) {
            $cmd = "su - $oracle_user -c 'export ORACLE_HOME=$oracle_home;$srvctl start database -d $db_name' 1>$cmd_log 2>$error_log";
        }

        notify("    cmd is $cmd",'A');
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    }

    if ( $db_type ne "rac_one_node" ) { # rac one node 要确认本地节点有资格启动这个实例
        $dbstatus = check_db_process($oracle_sid);

        if ( $db_type ne "rac_one_node" ) {
            if ( $local_node_can_start_rac_one_node eq "yes" ) {
                if ( $dbstatus eq "db_is_not_running" ) {
                    sleep 60;
                    $dbstatus = check_db_process($oracle_sid);
                    if ( $dbstatus eq "db_is_not_running" ) {
                        my $msg = "Error!  database instance $oracle_sid is not running";
                        notify("$msg");
                        print $error_fd "$msg\n";
                    }
                }
            }
        }
        else {
            if ( $dbstatus eq "db_is_not_running" ) {
                sleep 60;
                $dbstatus = check_db_process($oracle_sid);
                if ( $dbstatus eq "db_is_not_running" ) {
                    my $msg = "Error!  database instance $oracle_sid is not running";
                    notify("$msg");
                    print $error_fd "$msg\n";
                }
            }
        }
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task start_instance for $db_name");
}

