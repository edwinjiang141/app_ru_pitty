sub step_00_unzip {
    $step_name = "step_00_unzip";

    notify("*** starting step_00_unzip",'A');
    my $time_start = time();

    # 清理进度文件
    my $progress_file = catfile($log_dir,"progress_for_ru");
    unlink $progress_file if -e $progress_file;

    my $tag = "-";
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        if ( !-e $grid_image ) {
            notify("Error!  can not find $grid_image",'A');
            print $error_fd "Error!  can not find $grid_image\n";
            $tag = "error";
        }
    }
    if ( !-e $db_image ) {
        notify("Error!  can not find $db_image",'A');
        print $error_fd "Error!  can not find $db_image\n";
        $tag = "error";
    }

    # 检查 target_grid_home / target_oracle_home 是否存在
    if ( -e $target_grid_home ) {
        # 大小不能超过 1M
        chomp ($tmp = `du -sk $target_grid_home`);
        my $size = (split /\s+/,$tmp)[0];
        $size =~ s/^\s+|\s+$//g;        # 去掉前后空格
        if ( $size > 1024 ) {
            my $msg = "Error!  target_grid_home $target_grid_home is exist";
            notify("        $msg");
            print $error_fd "$msg\n";
            $tag = "error";
        }
    }

    if ( -e $target_oracle_home ) {
        # 大小不能超过 1M
        chomp ($tmp = `du -sk $target_oracle_home`);
        my $size = (split /\s+/,$tmp)[0];
        $size =~ s/^\s+|\s+$//g;        # 去掉前后空格
        if ( $size > 1024 ) {
            my $msg = "Error!  target_oracle_home $target_oracle_home is exist";
            notify("        $msg");
            print $error_fd "$msg\n";
            $tag = "error";
        }
    }

    if ( defined $input->{unzip_all_image} or defined $input->{unzip_switch_back_image} ) {
        my $oracle_home_for_unzip = $oracle_home . "_unzip_for_switchback";
        my $grid_home_for_unzip = $grid_home . "_unzip_for_switchback";
        if ( defined $input->{grid_image} and -e $grid_home_for_unzip ) {
            chomp ($tmp = `du -sk $grid_home_for_unzip`);
            my $size = (split /\s+/,$tmp)[0];
            if ( $size > 1024 ) {
                my $msg = "Error!  grid_home_for_unzip $grid_home_for_unzip is exist";
                notify("        $msg");
                print $error_fd "$msg\n";
                $tag = "error";
            }
        }
        if ( -e $oracle_home_for_unzip ) {
            chomp ($tmp = `du -sk $oracle_home_for_unzip`);
            my $size = (split /\s+/,$tmp)[0];
            if ( $size > 1024 ) {
                my $msg = "Error!  oracle_home_for_unzip $oracle_home_for_unzip is exist";
                notify("        $msg");
                print $error_fd "$msg\n";
                $tag = "error";
            }
        }
    }

    if ( $tag eq "error" ) {
        notify("Error!  something is wrong",'A');
        print_error();
        exit 1;
    }

    # backup_inventory();
    # backup_etc_oracle();
    # backup_profile();
    check_target_grid_db_dir();
    unzip_grid_image() if $env_type eq "crs" or $env_type eq "has";
    unzip_db_image();

    # 如果指定了 --unzip_all_image 就解压缩后面的2个image
    if ( defined $input->{unzip_all_image} or defined $input->{unzip_switch_back_image} ) {
        notify("Note: defined UNZIP_ALL_IMAGE, so start unzip grid/db image for switchback",'A');
        # oracle_home 路径为 $oracle_home + "_unzip_for_switchback"
        # grid_home 路径为 $grid_home + "_unzip_for_switchback"
        my $oracle_home_for_unzip = $oracle_home . "_unzip_for_switchback";
        my $grid_home_for_unzip = $grid_home . "_unzip_for_switchback";

        unzip_image_for_switch_back($grid_home_for_unzip,"grid_image") if defined $input->{grid_image};
        unzip_image_for_switch_back($oracle_home_for_unzip,"db_image");
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task step_00_unzip");
}

