sub change_grid_bin_permission {
    notify("*** change_grid_bin_permission",'A');
    return if $env_type ne "crs";
    my $tag = "ok";
    # oracle程序的权限
    my $oracle_home_for_grid = get_oracle_home_with_echo("$grid_user");
    my $oracle_bin_for_grid = catfile($oracle_home_for_grid,"bin/oracle");
    my $cmd = "ls -l $oracle_bin_for_grid";
    my $result = execute_cmd($cmd);
    notify("    $result->[0]","A");
    get_group_for_grid_oracle();
    my @F = split /\s+/, $result->[0];
    if ( $F[3] ne "oinstall" ) {
        # 此处要判断$F[3]的组名称，grid/oracle是否都在里面
        my $tag1 = "no";
        my $tag2 = "no";
        foreach my $group_name ( @$group_for_grid ) {
            $tag1 = "yes" if $group_name eq $F[3];
        }
        foreach my $group_name ( @$group_for_oracle ) {
            $tag2 = "yes" if $group_name eq $F[3];
        }
        if ( $tag1 eq "yes" and $tag2 eq "yes" ) {  # 都在当前组里面，不用修改
            notify("$oracle_bin_for_grid group is $F[3]","A");
            notify("$grid_user group is $str_group_for_grid","A");
            notify("$oracle_user group is $str_group_for_oracle","A");
        }
        else {
            # 分为2种情况，1种是系统有oinstall组，2种是系统没有oinstall组
            my $tag0 = "no_oinstall";
            foreach my $group_name ( @$group_for_grid ) {
                $tag0 = "yes_oinstall" if $group_name eq "oinstall";
            }
            if ( $tag0 eq "yes_oinstall" ) {     # grid在oinstall，要设置成oinstall
                notify("Warning! $oracle_bin_for_grid group must be oinstall","A");
                $tag = "error";
                my $solution02 = "chown $grid_user:oinstall $oracle_bin_for_grid";
                my $solution02_02 = "chmod 6751 $oracle_bin_for_grid";
                notify("    solution 2: $solution02","A");
                notify("                $solution02_02","A");
                execute_cmd($solution02);
                execute_cmd($solution02_02);
            }
            else {  # 没有 oinstall 要设置成grid_group的第1个值
                notify("Warning! $oracle_bin_for_grid group must be $group_for_grid->[0]","A");
                $tag = "error";
                my $solution02 = "chown $grid_user:$group_for_grid->[0] $oracle_bin_for_grid";
                my $solution02_02 = "chmod 6751 $oracle_bin_for_grid";
                notify("    solution 2: $solution02","A");
                notify("                $solution02_02","A");
                execute_cmd($solution02);
                execute_cmd($solution02_02);
            }
        }
    }
    #if ( $F[0] ne "-rwsr-s--x" ) {
    # -rwsr-s--x
    if ( $F[0] !~ m/\-rwsr\-s\-\-x\.?/ ) {
        $tag = "error";
        notify("Warning! $oracle_bin_for_grid permission must be -rwsr-s--x","A");
        my $solution = "chmod 6751 $oracle_bin_for_grid";
        notify("    solution: $solution","A");
        execute_cmd($solution);
    }

    notify("check $oracle_bin_for_grid is done","A") if $tag eq "ok";
    change_grid_bin_permission() if $tag ne "ok";
}

