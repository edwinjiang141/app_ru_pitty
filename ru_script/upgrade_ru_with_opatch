sub check_opatch_version {
    notify("*** check_opatch_version");
    # 验证 使用grid和oracle用户调用opatch命令
    ### grid_user: $grid_user
    ### oracle_user: $oracle_user
    foreach my $user ( $grid_user, $oracle_user ) {
        ### user: $user
        next if $user eq $grid_user and $env_type eq "fs";
        my $oracle_home = get_oracle_home_with_echo("$user");
        my $opatch = catfile($oracle_home,"OPatch/opatch");
        my $cmd = "su - $user -c '$opatch version' 1>$cmd_log 2>$error_log";
        notify("$cmd",'A');
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        # opatch版本不能低于RU指定的版本
        my $opatch_version = (split /:/, $result1->[0])[1];
        my $opatch_version_in_ru = $CONFIG->{ru}->{opatch};
        notify("opatch_version : $opatch_version",'A');
        notify("ru defined opatch_version : $opatch_version_in_ru",'A');
        $opatch_version =~ s/\.//g;
        $opatch_version_in_ru =~ s/\.//g;
        notify("opatch_version : $opatch_version",'N');
        notify("ru defined opatch_version : $opatch_version_in_ru",'N');
        if ( $opatch_version >= $opatch_version_in_ru ) {  # 升级成功
            notify("opatch update done",'A');
        }
        else {
            notify("Error! opatch version is not expected!",'A');
            exit 1;
        }
    }
}

sub check_zip_sha256sum {
    notify("*** check_zip_sha256sum");
    my $tag = "-";

    # 已经从 get_ru_number 得到所需要的值
    my ($sha256sum_ru,$sha256sum_ojvm);
    $sha256sum_ru = $CONFIG->{ru}->{sha256sum};
    notify("sha256sum_ru is $sha256sum_ru",'A');

    my $os_type;
    chomp ($os_type = `uname`);
    $os_type = lc $os_type;

    # aix下没有sha256sum命令
    return if $os_type ne "linux";

    if ( !-e $gi_patch_path ) {
        notify("Error! $gi_patch_path is not exist",'A');
        exit 1;
    }

    my $md5_cmd;
    $md5_cmd = "/usr/bin/sha256sum" if $os_type eq "linux";

    my $check_gi = "$md5_cmd $gi_patch_path";
    my $sha256sum = (split /\s+/,execute_cmd($check_gi)->[0])[0];
    ### $sha256sum
    notify("sha256sum for $gi_patch_path is",'A');
    notify("    $sha256sum",'A');
    if ( lc $sha256sum eq lc $sha256sum_ru ) {
        notify("sha256sum for $gi_patch_path is passed",'A');
    }
    else {
        notify("Error! sha256sum for $gi_patch_path is wrong",'A');
        push @$ERROR, "Error! sha256sum for $gi_patch_path is wrong" if not defined $input->{force};
        $tag = "error";
    }

    if ( defined $CONFIG->{ojvm}->{number} and $CONFIG->{ojvm}->{number} ne "00000000" ) {
        $sha256sum_ojvm = $CONFIG->{ojvm}->{sha256sum};
        notify("sha256sum_ojvm is $sha256sum_ojvm",'A');
        if ( !-e $ojvm_patch_path ) {
            notify("Error! $ojvm_patch_path is not exist",'A');
            exit 1;
        }
        my $check = "$md5_cmd $ojvm_patch_path";
        my $sha256sum = (split /\s+/,execute_cmd($check)->[0])[0];
        ### $sha256sum
        notify("sha256sum for $ojvm_patch_path is",'A');
        notify("    $sha256sum",'A');
        if ( lc $sha256sum eq lc $sha256sum_ojvm ) {
            notify("sha256sum for $ojvm_patch_path is passed",'A');
        }
        else {
            notify("Error! sha256sum for $ojvm_patch_path is wrong",'A');
            push @$ERROR, "Error! sha256sum for $ojvm_patch_path is wrong" if not defined $input->{force};
            $tag = "error";
        }
    }
    else {
        notify("not defined ojvm, skip sha256sum for ojvm",'A');
    }

    if ( $tag eq "error" ) {
        if ( defined $input->{force} ) {
            notify("Warning! sha256sum is wrong",'A');
        }
        else {
            notify("Error! sha256sum is wrong",'A');
            exit 1;
        }
    }
}

