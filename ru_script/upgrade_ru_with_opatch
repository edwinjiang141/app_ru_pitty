sub get_files {
    my ($dir,$new_dir) = @_;
    undef @FILE_LIST if defined $new_dir;
    undef @DIR_LIST if defined $new_dir;

    #print("dir is $dir\n");
    opendir (DIR,"$dir") or die "Can't open dir:$!";
    my @file = readdir(DIR);
    closedir(DIR);
    foreach (@file){
        next if $_ eq '.' or $_ eq '..';
        my $file = "$dir/$_";
        if (-d $file){
            #print("266 file is $file\n");
            # 重复递归查找
            push @DIR_LIST, $file;
            get_files($file);
        } else {
            push @FILE_LIST, $file;
        }
    }
    foreach my $dir ( @DIR_LIST ) {
        #print("275 dir : $dir\n");
    }
    return ( [ @FILE_LIST ] );
}

sub get_files_by_type {
    my ($dir,$type,$new_dir) = @_;
    undef @FILE_LIST if defined $new_dir;

    #print("dir is $dir\n");
    opendir (DIR,"$dir") or die "Can't open dir:$!";
    my @file = readdir(DIR);
    closedir(DIR);
    foreach (@file){
        next if $_ eq '.' or $_ eq '..';
        my @F = split /\./, $_;
        # notify("803 \$type is: $type") if defined $type;
        # notify("803 \$F[-1] is: $F[-1]") if defined $F[1];
        next if not defined $F[1];
        next if defined $type and defined $F[1] and $F[-1] ne $type;
        my $file = "$dir/$_";
        # notify("805 file is: $file");
        if (-d $file){
            # notify("806 file is dir: $file");
            # 重复递归查找
            push @DIR_LIST, $file;
            get_files_by_type($file) if not defined $type;
            get_files_by_type($file,$type) if defined $type;
        } else {
            push @FILE_LIST, $file;
        }
    }
    foreach my $dir ( @DIR_LIST ) {
        #print("275 dir : $dir\n");
    }
    #return ( [ @FILE_LIST ], [ @DIR_LIST ] );
    return ( [ @FILE_LIST ] );
}

sub crsctl_stat_res {
    my ($crsctl) = @_;
    unlink $cmd_log;
    my $cmd = "$crsctl stat res -t > $cmd_log";
    notify("    cmd: $cmd",'N');
    system($cmd);
    @tmp = get_all_line($cmd_log);
    #检查 TARGET 为 ONLINE  状态为 OFFLINE
    #ONLINE  OFFLINE
    my @tmp1 = grep { /ONLINE\s+OFFLINE/ } @tmp;
    if ( defined $tmp1[0] ) {
        notify("Error! crsctl status res -t has OFFLINE resource",'A');
        exit;
    }
}

