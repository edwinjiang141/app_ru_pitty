sub get_parent_dir_path {
    my $dir = shift;
    notify("    get_parent_dir_path for $dir",'A');

    if ( -f $dir ) {        # 如果是文件，就返回错误
        notify("Error! $dir is a file",'A');
        exit 1;
    }

    my @F = split /\//, $dir;
    # 去掉最后一个元素
    pop @F;

    my $up_dir = join("/",@F);
    notify("    the parent dir of $dir is $up_dir",'A');
    if ( !-e $up_dir ) {
        notify("Error! $up_dir is not exist!",'A');
        exit 1;
    }
    return $up_dir;
}

