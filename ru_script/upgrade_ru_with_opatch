sub get_group_for_grid_oracle {
    my ($cmd,$result,$id_for_oracle,$id_for_grid);
    # 取得grid/oracle的 id 命令的输出，得到组清单
    notify("    get $oracle_user/$grid_user group list","A");

    $cmd = "id $grid_user";
    $id_for_grid = execute_cmd($cmd);
    ### $id_for_grid
    my @F = split /\s+/, $id_for_grid->[0];
    shift @F;
    foreach my $str ( @F ) {
        ### $str
        if ( $str =~ m/gid/ ) {
            my ($group) = $str =~ m/\((\w*)\)/;
            ### $group
            push @$group_for_grid, $group;
        }
        elsif ( $str =~ m/groups/ ) {
            my @F2 = split /,/, $str;
            foreach my $str2 ( @F2 ) {
                my ($group) = $str2 =~ m/\((\w*)\)/;
                ### $group
                push @$group_for_grid, $group;
            }
        }
    }
    $group_for_grid = list_uniq($group_for_grid);
    ### $group_for_grid

    $cmd = "id $oracle_user";
    $id_for_oracle = execute_cmd($cmd);
    ### $id_for_oracle
    @F = split /\s+/, $id_for_oracle->[0];
    shift @F;
    foreach my $str ( @F ) {
        ### $str
        if ( $str =~ m/gid/ ) {
            my ($group) = $str =~ m/\((\w*)\)/;
            ### $group
            push @$group_for_oracle, $group;
        }
        elsif ( $str =~ m/groups/ ) {
            my @F2 = split /,/, $str;
            foreach my $str2 ( @F2 ) {
                my ($group) = $str2 =~ m/\((\w*)\)/;
                ### $group
                push @$group_for_oracle, $group;
            }
        }
    }
    $group_for_oracle = list_uniq($group_for_oracle);
    ### $group_for_oracle

    $str_group_for_grid = join(",",@$group_for_grid);
    $str_group_for_oracle = join(",",@$group_for_oracle);
}

sub check_oracle_bin_permission {
    notify("*** check_oracle_bin_permission","A");

    if ( $env_type eq "fs" ) {
        check_oracle_bin_permission_for_fs();
        return;
    }

    my $tag_global = "-";
    my $oracle_home_for_db = get_oracle_home_with_echo("$oracle_user");
    my $oracle_home_for_grid = get_oracle_home_with_echo("$grid_user");
    my $oracle_bin_for_db = catfile($oracle_home_for_db,"bin/oracle");
    my $oracle_bin_for_grid = catfile($oracle_home_for_grid,"bin/oracle");

    get_group_for_grid_oracle();
    my ($cmd,$result);
    # oracle_home_bin_oracle
    notify("checking $oracle_bin_for_db","A");
    $cmd = "ls -l $oracle_bin_for_db";
    $result = execute_cmd($cmd);
    notify("    $result->[0]","A");
    my @F = split /\s+/, $result->[0];
    if ( $F[3] ne "asmadmin" ) {
        # 2023-03-25 13:06:32
        # 此处增加一个判断分支，如果grid在asmadmin组里面，则oracle bin的属组必须为asmadmin
        my $tag_for_grid_asmadmin = "no_asmadmin";
        my $tag_for_oracle_asmadmin = "no_asmadmin";
        foreach my $group_name ( @$group_for_grid ) {
            $tag_for_grid_asmadmin = "yes_asmadmin" if $group_name eq "asmadmin";
        }
        foreach my $group_name ( @$group_for_oracle ) {
            $tag_for_oracle_asmadmin = "yes_asmadmin" if $group_name eq "asmadmin";
        }
        if ( $tag_for_grid_asmadmin eq "yes_asmadmin" and $tag_for_oracle_asmadmin eq "yes_asmadmin" ) {
            # 都在asmadmin 不用操作
            notify("$oracle_bin_for_db group is $F[3]","A");
            notify("$grid_user group is $str_group_for_grid","A");
            notify("$oracle_user group is $str_group_for_oracle","A");
        }
        elsif ( $tag_for_grid_asmadmin eq "yes_asmadmin" and $tag_for_oracle_asmadmin eq "no_asmadmin" ) {
            notify("Warning! $oracle_bin_for_db group must be asmadmin","A");
            my $setasmgidwrap = catfile($oracle_home_for_grid,"bin/setasmgidwrap");
            my $solution01 = "su - $grid_user -c '$setasmgidwrap o=$oracle_bin_for_db'";
            my $solution02 = "chown $oracle_user:asmadmin $oracle_bin_for_db";
            my $solution02_02 = "chmod 6751 $oracle_bin_for_db";
            notify("    solution 1: $solution01","A");
            notify("    solution 2: $solution02","A");
            notify("                $solution02_02","A");
            # execute_cmd($solution01);
            $tag_global = "oracle_bin_error";
        }
        # grid/oracle都不在asmadmin
        # 此处要判断$F[3]的组名称，grid/oracle是否都在里面
        else {
            my $tag1 = "no";
            my $tag2 = "no";
            foreach my $group_name ( @$group_for_grid ) {
                $tag1 = "yes" if $group_name eq $F[3];
            }
            foreach my $group_name ( @$group_for_oracle ) {
                $tag2 = "yes" if $group_name eq $F[3];
            }
            if ( $tag1 eq "yes" and $tag2 eq "yes" ) {
                # 虽然不是asmadmin 但是grid/oracle都在当前组里面，所以不用修改
                notify("$oracle_bin_for_db group is $F[3]","A");
                notify("$grid_user group is $str_group_for_grid","A");
                notify("$oracle_user group is $str_group_for_oracle","A");
            }
            else {
                # 没有asmadmin，要设置成oracle的第一个组
                notify("Warning! $oracle_bin_for_db group must be $group_for_oracle->[0]","A");
                my $setasmgidwrap = catfile($oracle_home_for_grid,"bin/setasmgidwrap");
                my $solution01 = "su - $grid_user -c '$setasmgidwrap o=$oracle_bin_for_db'";
                my $solution02 = "chown $oracle_user:$group_for_oracle->[0] $oracle_bin_for_db";
                my $solution02_02 = "chmod 6751 $oracle_bin_for_db";
                notify("    solution 1: $solution01","A");
                notify("    solution 2: $solution02","A");
                notify("                $solution02_02","A");
                # execute_cmd($solution01);
                $tag_global = "oracle_bin_error";
            }
        }
    }

    # if ( $F[0] !~ m/\-rwsr\-s\-\-x\.?/ ) {
    if ( $F[0] !~ m/\-rwsr.s..x\.?/ ) {
        notify("Error! $oracle_bin_for_db permission must be -rwsr-s--x","A");
        push @$ERROR, "Error! $oracle_bin_for_db permission must be -rwsr-s--x";
        my $solution = "chmod 6751 $oracle_bin_for_db";
        notify("    solution: $solution","A");
        $tag_global = "oracle_bin_error";
    }

    if ( $tag_global eq "oracle_bin_error" ) {
        notify("$oracle_bin_for_db must be correct!","A");
        notify("please use :","A");
        notify("    perl upgrade_ru_with_opatch --step_90_change_oracle_bin_permission","A");
        exit 1;
    }
    else {
        notify("check $oracle_bin_for_db is done","A");
    }

    # grid_home_bin_oracle
    notify("checking $oracle_bin_for_grid","A");
    $cmd = "ls -l $oracle_bin_for_grid";
    $result = execute_cmd($cmd);
    notify("    $result->[0]","A");
    @F = split /\s+/, $result->[0];
    $group_for_oinstall = "oinstall";
    if ( $F[3] ne "oinstall" ) {    # 系统当前有可能没有oinstall组
        # 此处要判断$F[3]的组名称，grid/oracle是否都在里面
        my $tag1 = "no";
        my $tag2 = "no";
        foreach my $group_name ( @$group_for_grid ) {
            $tag1 = "yes" if $group_name eq $F[3];
        }
        foreach my $group_name ( @$group_for_oracle ) {
            $tag2 = "yes" if $group_name eq $F[3];
        }
        if ( $tag1 eq "yes" and $tag2 eq "yes" ) {  # 都在当前组里面，不用修改
            notify("$oracle_bin_for_grid group is $F[3]","A");
            notify("$grid_user group is $str_group_for_grid","A");
            notify("$oracle_user group is $str_group_for_oracle","A");
            $group_for_oinstall = $F[3];
        }
        else {
            # 分为2种情况，1种是系统有oinstall组，2种是系统没有oinstall组
            my $tag = "no_oinstall";
            foreach my $group_name ( @$group_for_grid ) {
                $tag = "yes_oinstall" if $group_name eq "oinstall";
            }
            if ( $tag eq "yes_oinstall" ) {     # grid在oinstall，要设置成oinstall
                $group_for_oinstall = "oinstall";
                notify("Error! $oracle_bin_for_grid group must be oinstall","A");
                push @$ERROR, "Error! $oracle_bin_for_grid group must be oinstall";
                my $solution02 = "chown $grid_user:$group_for_oinstall $oracle_bin_for_grid";
                my $solution02_02 = "chmod 6751 $oracle_bin_for_grid";
                notify("    solution 2: $solution02","A");
                notify("                $solution02_02","A");
                $tag_global = "grid_bin_error";
            }
            else {  # 没有 oinstall 要设置成grid_group的第1个值
                $group_for_oinstall = $group_for_grid->[0];
                notify("Error! $oracle_bin_for_grid group must be $group_for_grid->[0]","A");
                push @$ERROR, "Error! $oracle_bin_for_grid group must be $group_for_grid->[0]";
                my $solution02 = "chown $grid_user:$group_for_grid->[0] $oracle_bin_for_grid";
                my $solution02_02 = "chmod 6751 $oracle_bin_for_grid";
                notify("    solution 2: $solution02","A");
                notify("                $solution02_02","A");
                $tag_global = "grid_bin_error";
            }
        }
    }
    notify("NOTE: group_for_oinstall is $group_for_oinstall","A");
    sleep 2;
    # if ( $F[0] !~ m/\-rwsr\-s\-\-x\.?/ ) {
    if ( $F[0] !~ m/\-rwsr.s..x\.?/ ) {
        notify("Error! $oracle_bin_for_grid permission must be -rwsr-s--x","A");
        push @$ERROR, "Error! $oracle_bin_for_grid permission must be -rwsr-s--x";
        my $solution = "chmod 6751 $oracle_bin_for_grid";
        notify("    solution: $solution","A");
        $tag_global = "grid_bin_error";
    }

    if ( $tag_global eq "grid_bin_error" ) {
        notify("$oracle_bin_for_grid must be correct!","A");
        notify("please use :","A");
        notify("    perl upgrade_ru_with_opatch --step_90_change_oracle_bin_permission","A");
        # exit 1;
    }
    else {
        notify("check $oracle_bin_for_grid is done","A");
    }

    return($tag_global);
}

