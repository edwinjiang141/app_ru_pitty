sub stop_listener_all_for_oracle_user {
    notify("*** stop_listener_all_for_oracle_user",'A');
    my $time_start = time();

    # 得到监听清单
    my $cmd = "ps -ef|grep $oracle_user|grep -v grep|grep tnslsnr";
    notify("$cmd",'A');
    my $result = execute_cmd($cmd);
    my $listener_list;
    foreach my $line ( @$result ) {
        $line =~ s/^\s+|\s+$//g;
        my @F = split /\s+/, $line;
        push @$listener_list, $F[-2];
    }
    ### listener_list: $listener_list
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $lsnrctl = catfile($oracle_home,"bin/lsnrctl");
    foreach my $listener ( @$listener_list ) {
        my $stop = $lsnrctl . " stop " . $listener;
        notify("$stop",'A');
        my $cmd = "su - $oracle_user -c '$stop' 1>$cmd_log 2>$error_log";
        system($cmd);
        notify("stop listener $listener for $oracle_user",'A');
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        if ( defined $result2->[0] ) {
            notify("Error! $cmd is error!");
            exit 1;
        }
    }

    my $time_stop = time();
    my $time_diff = time_diff($time_start,$time_stop);
    notify("time: $time_diff seconds to stop_listener_all");
}

