sub compare_remote_file {
    notify("*** compare_remote_file","N");
    my ($file_path,$user_name,$node_list,$fd) = @_;
    # 以下要一致：
    #     文件要存在
    #     文件属性一致
    #     文件大小一致
    #     文件内容一致
    # 有错误直接推送到 $ERROR ，在precheck结束时会打印$ERROR的内容，如果有内容会exit 1退出
    # 同时记录到precheck日志 $fd
    ### $file_path
    ### $user_name
    ### $node_list

    my $result;
    foreach my $node ( @$node_list ) {
        my $cmd = "su - $user_name -c 'ssh $node ls -l $file_path' 2>/dev/null";
        my $out01 = execute_cmd($cmd);
        $cmd = "su - $user_name -c 'ssh $node cat $file_path' 2>/dev/null";
        my $out02 = execute_cmd($cmd);
        $result->{$file_path}->{attribute}->{$node} = $out01;
        $result->{$file_path}->{contents}->{$node} = $out02;
    }

    # 对result进行比较 以文件为单位，比较各节点的输出
    # $result: {
    #            '/u01/app/oraInventory/ContentsXML/oui-patch.xml' => {
    #                                                                   attribute => {
    #                                                                                  testrac01 => [
    #                                                                                                 '-rw-rw-r-- 1 grid oinstall 174 Mar 24  2022 /u01/app/oraInventory/ContentsXML/oui-patch.xml'
    #                                                                                               ],
    #                                                                                  testrac02 => [
    #                                                                                                 '-rw-rw-r-- 1 oracle oinstall 174 Mar 24  2022 /u01/app/oraInventory/ContentsXML/oui-patch.xml'
    #                                                                                               ],
    #                                                                                  testrac03 => []
    #                                                                                },
    #                                                                   contents => {
    #                                                                                 testrac01 => [
    #                                                                                                '<?xml version="1.0" encoding="UTF-8"?>',
    #                                                                                                '<!-- Copyright (c) 2022 Oracle Corporation. All Rights Reserved.',
    #                                                                                                'Do not modify the contents of this file by hand.',
    #                                                                                                '-->',
    #                                                                                                '<ONEOFF_LIST/>'
    #                                                                                              ],
    #                                                                                 testrac02 => [
    #                                                                                                '<?xml version="1.0" encoding="UTF-8"?>',
    #                                                                                                '<!-- Copyright (c) 2022 Oracle Corporation. All Rights Reserved.',
    #                                                                                                'Do not modify the contents of this file by hand.',
    #                                                                                                '-->',
    #                                                                                                '<ONEOFF_LIST/>'
    #                                                                                              ],
    #                                                                                 testrac03 => []
    #                                                                               }
    #                                                                 }

    foreach my $file ( sort keys %$result ) {       # 第一层是文件路径
        my $attribute = $result->{$file}->{attribute};
        my $contents = $result->{$file}->{contents};
        ### $attribute
        # 对属性列，需要比较 -rw-rw---- 1 grid oinstall 551 也就是前面5个字段，要求全部一致
        # 按照节点清单来进行比较 node_list 以节点0为标准
        if ( not defined $attribute->{$node_list->[0]}->[0] ) {
            # 节点1不存在这个文件，报错，然后下一个文件
            my $msg = "Error! $file for $node_list->[0] is not exist";
            notify("$msg");
            push @$ERROR, $msg;
            print $fd "    # $msg\n";
            next;
        }
        my $node_0_attribute = $attribute->{$node_list->[0]}->[0];
        my $node_0_contents = $contents->{$node_list->[0]};
        ### $node_0_attribute
        my @F0 = split /\s+/, $node_0_attribute;
        my $att;
        $att->{permission} = $F0[0];
        $att->{user} = $F0[2];
        $att->{group} = $F0[3];
        $att->{size} = $F0[4];
        ### $att

        # /u01/app/oraInventory/ContentsXML/oui-patch.xml
        # 如果文件路径等于 $oraInventory/ContentsXML/oui-patch.xml 那么它的权限应该是rw-rw，owner为grid, group为oinstall
        my $oui_patch_xml = catfile($oraInventory,"ContentsXML/oui-patch.xml");
        my $hostname = get_local_host_name();
        if ( $file eq $oui_patch_xml ) {
            # if ( $att->{permission} ne "-rw-rw----" ) {
            if ( $att->{permission} !~ m/^.rw.rw/ ) {
                my $msg = "Error! attribute of $oui_patch_xml for $hostname not eq '-rw-rw----': $att->{permission}";
                notify("$msg");
                push @$ERROR, $msg;
                print $fd "    # $msg\n";
            }
            if ( $att->{user} ne $grid_user ) {
                my $msg = "Error! owner of $oui_patch_xml for $hostname not eq '$grid_user': $att->{user}";
                notify("$msg");
                push @$ERROR, $msg;
                print $fd "    # $msg\n";
            }
            # if ( $att->{group} ne "oinstall" ) {
            #     get_group_for_grid_oracle();
            #     # 此处要判断 $att->{group} 的组名称，grid/oracle是否都在里面
            #     my $tag1 = "no";
            #     my $tag2 = "no";
            #     foreach my $group_name ( @$group_for_grid ) {
            #         $tag1 = "yes" if $group_name eq $att->{group};
            #     }
            #     foreach my $group_name ( @$group_for_oracle ) {
            #         $tag2 = "yes" if $group_name eq $att->{group};
            #     }
            #     if ( $tag1 eq "yes" and $tag2 eq "yes" ) {
            #         # 虽然不是oinstall，但grid/oracle都在这个组，所以不用报错
            #     }
            #     else {
            #         my $msg = "Error! group of $oui_patch_xml for $hostname not eq 'oinstall': $att->{group}";
            #         notify("$msg");
            #         push @$ERROR, $msg;
            #         print $fd "    # $msg\n";
            #     }
            # }
        }

        foreach my $node ( sort keys %$attribute ) {
            if ( not defined $attribute->{$node}->[0] ) {
                my $msg = "Error! $file for $node is not exist";
                notify("$msg");
                push @$ERROR, $msg;
                print $fd "    # $msg\n";
                next;
            }
            my $value = $attribute->{$node}->[0];
            my @F = split /\s+/, $value;
            my $att_target;
            $att_target->{permission} = $F[0];
            $att_target->{user} = $F[2];
            $att_target->{group} = $F[3];
            $att_target->{size} = $F[4];
            ### $att_target

            # 权限/owner/group 这三个字段要求一致
            if ( $att->{permission} ne $att_target->{permission}
                or $att->{user} ne $att_target->{user}
                or $att->{group} ne $att_target->{group}
                ) {
                my $msg = "Error! attribute of $file in $node is not consistent with $node_list->[0]";
                notify("$msg");
                push @$ERROR, $msg;
                print $fd "    # $msg\n";
                $msg = "$node_list->[0]: permission $att->{permission}, user $att->{user}, group $att->{group}";
                notify("$msg");
                print $fd "    #        $msg\n";
                $msg = "$node: permission $att_target->{permission}, user $att_target->{user}, group $att_target->{group}";
                notify("$msg");
                print $fd "    #        $msg\n";
            }

            # 后面比较了cat出来的contents，所以大小就不比较了
            # # size 字段也要一致
            # if ( $att->{size} ne $att_target->{size} ) {
            #     # next if $file =~ m/oraclehomeproperties\.xml/;      # 排除oraclehomeproperties.xml
            #     my $msg = "Error! size of $file in $node is not consistent with $node_list->[0]";
            #     notify("$msg");
            #     push @$ERROR, $msg;
            #     print $fd "    # $msg\n";
            #     $msg = "$node_list->[0] size: $att->{size}, $node size: $att_target->{size}";
            #     notify("$msg");
            #     print $fd "    # $msg\n";
            # }

            # 比较内容
            # 某些文件不比较内容
            next if $file =~ m/oraclehomeproperties\.xml/;

            my $tag = "yes";        # 默认假设内容一致
            # 每一行与node0进行比较，不相同说明内容不一致
            my $idx = 0;
            foreach my $line_of_node_0 ( @$node_0_contents ) {
                if ( not defined $contents->{$node}->[$idx] ) {
                    $tag = "no";
                    last;
                }
                my $line_of_node = $contents->{$node}->[$idx];
                if ( $line_of_node_0 =~ m/INSTALL_TIME/i and $line_of_node =~ m/INSTALL_TIME/i ) {
                    $line_of_node = $line_of_node_0;
                }
                $tag = "no" if $line_of_node_0 ne $line_of_node;
                $idx ++;
            }
            if ( $tag ne "yes" ) {
                my $msg = "Error! contents of $file in $node is not consistent with $node_list->[0]";
                notify("$msg");
                push @$ERROR, $msg;
                print $fd "    # $msg\n";
            }
        }

    }
}

sub check_xml {
