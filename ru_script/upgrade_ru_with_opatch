sub do_sql_oracle {
    my ($sqls,$oracle_sid,$input_oracle_home,$display_switch,$sql_running_for_a_pdb,$sql_log_for_a_pdb) = @_;

    # 默认值为 $sql_running 如果指定了 $sql_running_for_a_pdb 就用 $sql_running_for_a_pdb
    my $sql_running_sql = $sql_running_for_a_pdb ? $sql_running_for_a_pdb : $sql_running;
    my $sql_running_log = $sql_log_for_a_pdb ? $sql_log_for_a_pdb : $sql_log;
    my $fd = IO::File->new("> $sql_running_sql");
    my $not_display = "yes" if defined $display_switch and $display_switch eq "not_display";
    print $fd "SET HEADING OFF\n";
    print $fd "SET FEEDBACK OFF\n";
    print $fd "SET PAGESIZE 0\n";
    print $fd "SET VERIFY OFF\n";
    print $fd "SET ECHO OFF\n";
    print $fd "SET TERMOUT OFF\n";
    print $fd "SET TRIMSPOOL ON\n";
    print $fd "SET TRIMOUT ON\n";
    print $fd "SET LINESIZE 10000\n";
    print $fd "SET LONG 5000\n";
    print $fd "SET ARRAYSIZE 20\n";
    print $fd "SET TRIMS ON\n";
    print $fd "SET SPACE 2\n";
    print $fd "SET NEWPAGE NONE\n";
    print $fd "SET NUMWIDTH 12\n";
    print $fd "SET SERVEROUTPUT ON\n";
    print $fd "SET WRAP OFF\n";
    print $fd "SET SQLBLANKLINES ON\n";
    print $fd "SET TERM OFF\n";

    print $fd "spool $sql_running_log\n";
    foreach my $sql ( @$sqls ) {
        print $fd "$sql\n";
        notify("        $sql",'A') if not defined $not_display;
        notify("        $sql",'N') if defined $not_display;
    }
    print $fd "spool off\n";
    print $fd "exit;\n";

    $fd->close();

    unlink $sql_running_log;
    system ("chmod 777 $sql_running_sql");
    notify("    sql_running is $sql_running_sql",'A') if not defined $not_display;
    notify("    sql_running is $sql_running_sql",'N') if defined $not_display;
    my @result = get_all_line($sql_running_sql);
    foreach my $line ( @result ) {
        notify("    $line",'A') if $line !~ m/^SET/ and $line !~ m/^spool/ and $line !~ m/^exit/ and not defined $not_display;
        notify("    $line",'N') if $line !~ m/^SET/ and $line !~ m/^spool/ and $line !~ m/^exit/ and defined $not_display;
    }
    $input_oracle_home = get_oracle_home_with_echo("$oracle_user") if not defined $input_oracle_home;
    my $sqlplus = catfile ($input_oracle_home,"bin/sqlplus");
    if ( !-e $sqlplus ) {
        notify("Error! can not find $sqlplus , please check ORACLE_HOME $input_oracle_home",'A');
        exit 1;
    }
    my $cmd = "su - $oracle_user -c 'export ORACLE_SID=$oracle_sid;export ORACLE_HOME=$input_oracle_home;$sqlplus \"/ as sysdba \" \@$sql_running_sql 1>/tmp/do_sql_oracle'";
    notify("    cmd is $cmd",'A') if not defined $not_display;
    notify("    cmd is $cmd",'N') if defined $not_display;
    system($cmd);
}

sub shutdown_instance_using_sqlplus {
    my ($oracle_sid) = @_;

    notify("shutdown_instance_using_sqlplus for $oracle_sid");
    my $time1 = time();

    my $dbstatus = check_db_process($oracle_sid);
    if ( $dbstatus eq "db_is_not_running" ) {
        notify("database instance $oracle_sid is not running",'A');
        return;
    }

    my $sql;
    push @$sql, "SHUTDOWN IMMEDIATE;";
    do_sql_oracle($sql,$oracle_sid);

    my $return = "ok";

    my @result = get_all_line($sql_log);
    foreach my $line ( @result ) {
        notify("    $line",'A');
        next if $line =~ m/01109/;    # ORA-01109: database not open
        next if $line =~ m/01507/;    # ORA-01507: database not mounted
        if ( $line =~ /^ORA-/ ) {
            $return = 'error';
        }
    }
    if ( $return eq 'error' ) {
        notify("Warning! SHUTDOWN IMMEDIATE for $oracle_sid has error");
        # exit 1;
    }
    else {
        notify("SHUTDOWN IMMEDIATE for $oracle_sid  done");
