        if ( $env_type eq "crs" ) {
            if ( $db_type eq "rac" ) {
                $cmd = "su - $oracle_user -c '$srvctl stop instance -d $db_name -instance $oracle_sid -force' 1>$cmd_log 2>$error_log";
            }
            elsif ( $db_type eq "rac_one_node" ) {
