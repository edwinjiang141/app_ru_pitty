sub get_all_line {
   my $file = shift;
   return "file not exists" if not defined $file;
   open my $fh, '<', $file or return;
   my @lines = <$fh>;
   @lines = grep { !/^#/ } @lines;
   @lines = grep { !/^\s+#/ } @lines;
   @lines = grep { !/^\s+?$/ } @lines;
   foreach (@lines) {
      chomp;
   }

   if ( wantarray ){
      return @lines;
   }
   else{
      return join '', @lines;
   }
}

sub get_all_line_without_null {
   my $file = shift;
   return "file is not exists" if not defined $file;
   open my $fh, '<', $file or return;
   my @lines = <$fh>;
   @lines = grep { !/^#/ } @lines;
   @lines = grep { !/^\s+?$/ } @lines;
   foreach (@lines) {
      chomp;
   }

   if ( wantarray ){
      return @lines;
   }
   else{
      return join '', @lines;
   }
}

sub get_all_line_with_space {
   my $file = shift;
   return "file not exists" if not defined $file;
   open my $fh, '<', $file or return;
   my @lines = <$fh>;
   foreach (@lines) {
      chomp;
   }

   if ( wantarray ){
      return @lines;
   }
   else{
      return join '', @lines;
   }
}

sub get_oracle_base_with_echo {
    my ($user) = @_;
    notify("    get_oracle_base_with_echo for $user",'A');
    my $cmd = "su - $user -c 'echo \$ORACLE_BASE'";
    my $result = execute_cmd($cmd);
    my $oracle_base;
    if ( defined $result->[0] ) {
        $oracle_base = $result->[0];
        if ( !-e $oracle_base ) {
            notify("Error! cat not find $oracle_base",'A');
            exit 1;
        }
        else {
            notify("    ORACLE_BASE is $oracle_base",'N');
        }
    }
    else {
        notify("Error! can not find \$ORACLE_BASE with: su - $user -c 'echo \$ORACLE_BASE'",'A');
        exit 1;
    }
    return $oracle_base;
}

