sub execute_cmd {
    my ($cmd,$option) = @_;
    # notify("execute: $cmd") if defined $option;
    notify("    execute: $cmd") if not defined $option;
    my @result = `$cmd`;
    my @return;
    foreach my $line ( @result ) {
        chomp $line;                    # 去掉换行符
        $line =~ s/^\s+|\s+$//g;        # 去掉前后空格
        next if $line =~ m/^$/;         # 去掉空行
        next if $line =~ m/^Welcome/i;         # 去掉顶头带welcome的行
        next if $line =~ m/YOU HAVE NEW MAIL/i;
        push @return, $line;
    }
    return [ @return ];
}

sub get_locatime_for_file {
    my $date = strftime '%Y%m%d_%H%M%S', localtime;
    my $random = int(rand(10));
    my $file_name = $date . "_" . $random;
    return $file_name;
}

