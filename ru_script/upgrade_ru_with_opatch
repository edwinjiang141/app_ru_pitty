        compare_remote_file($file,$oracle_user,$all_node_hostname,$fd); # 传递给 compare_remote_file 过程进行比较
    }
}

sub get_profile_name {
    # 取得grid/oracle的profile名称
    # 读取/etc/passwd，得到用户的shell
    notify("    get_profile_name","A");

    # 根据shell类型，确定profile文件名称
    my @passwd = get_all_line("/etc/passwd");
    foreach my $line ( @passwd ) {
        my @F = split /:/, $line;
        my $shell = $F[-1];
        my $profile;
        $profile = ".bash_profile" if $shell =~ m/\/bash/;
        $profile = ".profile" if $shell =~ m/\/sh/;
        $profile = ".profile" if $shell =~ m/\/ksh/;
        $profile_grid = $profile if $F[0] eq $grid_user;
        $profile_oracle = $profile if $F[0] eq $oracle_user;
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        if ( not defined $profile_grid or not defined $profile_oracle ) {
            notify("Error! can not get profile name for $grid_user and $oracle_user, please check /etc/passwd","A");
            exit 1;
        }
    }
    elsif ( $env_type eq "fs" ) {
        if ( not defined $profile_oracle ) {
            notify("Error! can not get profile name for $oracle_user, please check /etc/passwd","A");
            exit 1;
        }
    }
    notify("    profile for $grid_user is $profile_grid","A") if defined $profile_grid;
    notify("    profile for $oracle_user is $profile_oracle","A");
}

sub check_invalid_object_for_sys_precheck {
   my ($fd) = @_;
    print $fd "\n";
    print $fd "# check invalid object for sys\n";

    my $invalid_object_for_sys_global = "no";
    # 对每个DB进行检查
    my $db_name_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 检查当前实例是否有SYS和MDSYS的无效对象，如果有就告警
        my $oracle_home = get_oracle_home_with_echo("$oracle_user");
        my $sys_object_status = check_invalid_object_for_sys($oracle_sid,$oracle_home);
        if ( $sys_object_status eq "error" ) {
            notify("SYS/MDSYS has invalid object for SID $oracle_sid, can not do DATAPATCH");
            print $fd "    # SYS/MDSYS has invalid object for SID $oracle_sid, can not do DATAPATCH\n";
            $invalid_object_for_sys_global = "yes";
        }

    }

    if ( $invalid_object_for_sys_global eq "yes" ) {
        print $fd "    # Some SID has invalid object for SYS/MDSYS\n";
    }
    else {
        print $fd "    # no invalid object for SYS/MDSYS, all SID\n";
    }

    return $invalid_object_for_sys_global;
}

sub precheck {
    # oracle程序的权限 如果权限不对，下面的SQL会执行失败，所以这里必须要退出并且修改权限
    check_oracle_bin_permission();

    notify("*** precheck","A");
    my ($input) = @_;
    my $tag_global = "ok";
    my $tag = "ok";

    my $time_str = strftime '%Y-%m-%d %H:%M:%S', localtime;
    my $hostname = get_local_host_name();
    my $precheck_file = "/tmp/precheck_for_ru_" . $hostname . ".acs";
    # 写入记录文件 每次都重写覆盖
    my $fd = IO::File->new("> $precheck_file");
    print $fd "### precheck result for ru , $time_str\n";

    # 检查数据库版本
