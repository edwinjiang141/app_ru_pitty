sub check_invalid_object_for_sys {
    my ($oracle_sid,$input_oracle_home) = @_;
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    notify("*** do check_invalid_object_for_sys for $oracle_sid");
    my $time1 = time();

    # 先看看这个SID是否运行
    my $dbstatus = check_db_process($oracle_sid);
    if ( $dbstatus eq "db_is_not_running" ) {
        notify("database instance $oracle_sid is not running",'A');
        return;
    }

    my $sql;
    push @$sql, "set linesize 140;";
    push @$sql, "column owner format a20;";
    push @$sql, "column object_name format a30;";
    push @$sql, "column object_type format a20;";
    push @$sql, "column status format a20;";
    push @$sql, "column con_id format 999;";
    push @$sql, "select 'obj',con_id,owner,object_type,object_name,status from cdb_objects where status != 'VALID' and owner in ('SYS','MDSYS') order by con_id,owner,object_type,object_name;";
    do_sql_oracle($sql,$oracle_sid,$oracle_home);

    my $return = "ok";
    my @result = get_all_line($sql_log);
    my $file_name = "invaild_object_for_sys_" . $oracle_sid . "_" . get_locatime_for_file() . ".log";
    my $file_path = catfile($log_dir,$file_name);
    notify("write $file_path",'A');
    open myFile , "> $file_path";
    foreach my $line ( @result ) {
        print myFile "$line\n";
        if ( $line =~ /^ORA-/ ) {
            $return = 'error';
        }
    }
    close myFile;
    notify("write $file_path done",'A');

    if ( $return eq 'error' ) {
        notify("Warning! select_invalid_object for $oracle_sid has error");
        notify("instance of $oracle_sid may not be running");
    }

    # 检查是否有无效对象
    my @result1 = get_all_line($file_path);
    my $error_count = 0;
    foreach my $line ( @result1 ) {
        #'obj       1  WMSYS                 PACKAGE BODY          LT                              INVALID',
        next if $line !~ m/^obj/;
        $error_count ++;
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to select_invalid_object for $oracle_sid");

    if ( $error_count != 0 ) {
        notify("Error! SYS/MDSYS has invalid object for $oracle_sid, can not do DATAPATCH");
        return "error";
    }
    else {
        return "ok";
    }

}

