sub do_one_off {
    my ($patch_path,$username,$readme) = @_;
    my $patch_number = basename($patch_path);
    notify("        do_one_off for $patch_number, for $username",'A');
    my $target_home;
    $target_home = $grid_home if $username eq $grid_user;
    $target_home = $oracle_home if $username eq $oracle_user;
    my $opatch = catfile($target_home,"OPatch/opatch");

    my $conflict_check_result = do_patch_conflict_check($username,$opatch,$patch_path,$patch_number);
    if ( $conflict_check_result eq "ok" ) {
        my $msg = "        conflict check for $username\t $patch_number \t is passed";
        notify("$msg");
    }
    else {
        my $msg = "Error! conflict check for $username\t $patch_number \t is wrong, not apply it.";
        push @$ERROR, $msg;
        notify("$msg");
        return;
    }

    # 检查检查它是否需要修改某些文件的权限
        # As root user, change oradism permissions
        #    Pre-install    //these make the existing oradism owned by grid home owner and replaceable
        #    a.ls -ld $GI_HOME/bin/oradism
        #      i.-rwsr-x--- 1 root  dba  <GI_HOME>/bin/oradism
        #    b.change owner to the GI home owner (i.e oracle)
        #      i.chown oracle $GI_HOME/bin/oradism
        #      ii.chmod 0750 $GI_HOME/bin/oradism
        #    c.ls -ld $GI_HOME/bin/oradism

    my @readme = @$readme;
    my @chown_file_for_grid;
    my @chown_file_for_oracle;
    foreach my $line ( @readme ) {
        if ( $line =~ m/chown/ ) {
            my @F = split /\s+/, $line;
            my $file = $F[-1];
            # 将 GI_HOME 和 ORACLE_HOME 替换成实际的路径
            if ( $file =~ m/\$GI_HOME/ ) {
                $file =~ s/\$GI_HOME/$grid_home/;
                push @chown_file_for_grid, $file;
            }
            if ( $file =~ m/\$ORACLE_HOME/ ) {
                $file =~ s/\$ORACLE_HOME/$oracle_home/;
                push @chown_file_for_oracle, $file;
            }
        }
    }
    # 对 chown_file 去重
    my %ha;
    my @uni_chown_file_for_grid = grep {++$ha{$_}<2} @chown_file_for_grid;    # 去重
    ### @uni_chown_file_for_grid
    my @uni_chown_file_for_oracle = grep {++$ha{$_}<2} @chown_file_for_oracle;    # 去重
    ### @uni_chown_file_for_oracle

    if ( $username eq "grid" ) {
        if ( defined $uni_chown_file_for_grid[0] ) {
            foreach my $file ( @uni_chown_file_for_grid ) {
                notify("        file need to chown for $patch_path is: $file");
                # 此处执行chown 根据 $username 来决定权限给谁
                my ($cmd01,$cmd02);
                $cmd01 = "chown $grid_user $file";
                $cmd02 = "chmod 0750 $file";
                notify("        $cmd01");
                notify("        $cmd02");
                system($cmd01);
                system($cmd02);
            }
        }
    }

    elsif ( $username eq "oracle" ) {
        if ( defined $uni_chown_file_for_oracle[0] ) {
            foreach my $file ( @uni_chown_file_for_oracle ) {
                notify("        file need to chown for $patch_path is: $file");
                # 此处执行chown 根据 $username 来决定权限给谁
                my ($cmd01,$cmd02);
                $cmd01 = "chown $oracle_user $file";
                $cmd02 = "chmod 0750 $file";
                notify("        $cmd01");
                notify("        $cmd02");
                system($cmd01);
                system($cmd02);
            }
        }
    }

    # # 应用补丁 根据 $username 决定执行哪个用户的opatch
    #     #    $ <GI_HOME>/OPatch/opatch apply -oh <GI_HOME> -local <PATCH_TOP_DIR>/35784008
    #     #    $ <ORACLE_HOME>/OPatch/opatch apply -oh <ORACLE_HOME> -local <PATCH_TOP_DIR>/35784008
    $cmd = "su - $username -c '$opatch napply -local -silent -oh $target_home $patch_path' 1>$cmd_log 2>$error_log";
    notify("        cmd is $cmd",'A');
    notify("        patching one-off $patch_path for $username");
    unlink $cmd_log;
    unlink $error_log;
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    if ( defined $result2->[0] ) {
        # OPatch Session completed with warnings
        if ( grep { /OPatch Session completed/ } @$result2 ) {
            notify("        Warning! OPatch Session completed with warnings");
        }
        else {
            notify("Error! $cmd is wrong");
            push @$ERROR, "Error! $patch_number for $username apply failed";
        }
    }

    if ( grep { /OPatch failed with/ } @$result1 ) {
        notify("Error! $cmd is wrong");
        push @$ERROR, "Error! $patch_number for $username apply failed";
    }

    # 最后修改文件权限为root
    if ( $username eq "grid" ) {
        if ( defined $uni_chown_file_for_grid[0] ) {
            foreach my $file ( @uni_chown_file_for_grid ) {
                notify("        file need to chown for $patch_path is: $file");
                my ($cmd01,$cmd02);
                $cmd01 = "chown root $file";
                $cmd02 = "chmod 4750 $file";
                notify("        $cmd01");
                notify("        $cmd02");
                system($cmd01);
                system($cmd02);
            }
        }
    }

    elsif ( $username eq "oracle" ) {
        if ( defined $uni_chown_file_for_oracle[0] ) {
            foreach my $file ( @uni_chown_file_for_oracle ) {
                notify("        file need to chown for $patch_path is: $file");
                my ($cmd01,$cmd02);
                $cmd01 = "chown root $file";
                $cmd02 = "chmod 4750 $file";
                notify("        $cmd01");
                notify("        $cmd02");
                system($cmd01);
                system($cmd02);
            }
        }
    }

}

