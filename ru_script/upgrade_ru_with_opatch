sub check_patch_version {
    # 检查 opatch lspatches 版本，是否与输入的版本号一致
    my ($patch_version) = @_;
    notify("*** check_patch_version for $patch_version",'A');
    my $time_start = time();
    my $sqlplus_version = get_sqlplus_version();

    my $ru_local;
    foreach my $user ( $oracle_user, $grid_user ) {
        next if $user eq $grid_user and $env_type eq "fs";

        my $oracle_home = get_oracle_home_with_echo("$user");
        my $opatch = catfile($oracle_home,"OPatch/opatch");

        my $cmd = "su - $user -c '$opatch lspatches'";
        notify("$cmd",'A');
        my $result = execute_cmd($cmd);
        ### $result
        # 34318175;TOMCAT RELEASE UPDATE 19.0.0.0.0 (34318175)
        # 34133642;Database Release Update : 19.16.0.0.220719 (34133642)
        # 33575402;DBWLM RELEASE UPDATE 19.0.0.0.0 (33575402)
        # 34139601;ACFS RELEASE UPDATE 19.16.0.0.0 (34139601)
        # 34160635;OCW RELEASE UPDATE 19.16.0.0.0 (34160635)
        # 34133642;Database Release Update : 19.16.0.0.220719 (34133642)
        # 34160635;OCW RELEASE UPDATE 19.16.0.0.0 (34160635)

        # 33676842;INVALID MESSAGE DISCARDING GC BLOCK LOST CAUSE WAITING FOR GC CR REQUEST AND SUBSEQUENT DB OPEN TIME OUT
        # 33497706;ACFS Interim patch for 33497706
        # 33239955;TOMCAT RELEASE UPDATE 19.0.0.0.0 (33239955)
        # 33515361;Database Release Update : 19.14.0.0.220118 (33515361)
        # 33575402;DBWLM RELEASE UPDATE 19.0.0.0.0 (33575402)
        # 29585399;OCW RELEASE UPDATE 19.3.0.0.0 (29585399)

        # 33610989;TOMCAT RELEASE UPDATE 12.2.0.1.0(ID:RELEASE) (33610989)
        # 33587128;Database Jan 2022 Release Update : 12.2.0.1.220118 (33587128)
        # 33116894;ACFS JUL 2021 RELEASE UPDATE 12.2.0.1.210720 (33116894)
        # 33678030;OCW JAN 2022 RELEASE UPDATE 12.2.0.1.220118 (33678030)
        # 26839277;DBWLM RELEASE UPDATE 12.2.0.1.0(ID:170913) (26839277)
        # 33587128;Database Jan 2022 Release Update : 12.2.0.1.220118 (33587128)
        # 33678030;OCW JAN 2022 RELEASE UPDATE 12.2.0.1.220118 (33678030)

        foreach my $line ( @$result ) {
            my @tmp = split /;/, $line;
            next if not defined $tmp[1];
            my $patch_number = $tmp[0];
            my $name = lc ( (split /\s+/, $tmp[1])[0] );
            # 跳过所有非RU的补丁
            unless ( $name =~ m/OCW/i or $name =~ m/DATABASE/i or $name =~ m/OJVM/i or $name =~ m/TOMCAT/i
                    or $name =~ m/ACFS/i or $name =~ m/DBWLM/i ) {
                next;
            }
            my $version;
            ($version) = $tmp[1] =~ m/\s+(\d\d\.\d+\.\d+\.\d+\.\d+)[\s+|\(]/;
            # ocw 可能没有版本号
            if ( not defined $version and $name eq "ocw" ) {
                $version = "19"
            }
            if ( not defined $version and $name eq "acfs" ) {
                $version = "19"
            }
            notify("Warning! version not matched: $tmp[1]",'A') if not defined $version;
            # $version = "19.0.0" if not defined $version;
            notify("$name version: $version",'A') if defined $version;
            $ru_local->{$user}->{$name} = $version;
        }
    }
    ### $ru_local
    foreach my $user ( sort keys %$ru_local ) {
        foreach my $name ( sort keys %{ $ru_local->{$user} } ) {
            foreach my $version ( $ru_local->{$user}->{$name} ) {
                if ( not defined $version ) {
                    notify("Error! user $user $name version is not find",'A');
                    push @$ERROR, "Error! user $user $name version is not find";
                    next;
                }

                if ( $sqlplus_version =~ m/^19/ ) {
                    if ( $version =~ /^$patch_version/ ) {
                        notify("user $user $name version: $version, ok",'A');
                    }
                    else {
                        if ( $name eq "database" ) {
                            notify("Error! user $user $name version: $version, not like $patch_version",'A');
                            push @$ERROR, "Error! user $user $name version: $version, not like $patch_version";
                        }
                        else {
                            if ( $name eq "dbwlm" or $name eq "tomcat" ) {  # 已知无问题 版本就是等于19.0
                                notify("ser $user $name version: $version, ok",'A');
                            }
                            else {
                                notify("Warning! user $user $name version: $version, not like $patch_version",'A');
                            }
                        }
                    }
                }
                else {  # 12c 不需要顶格匹配
                    if ( $version =~ /$patch_version/ ) {
                        notify("user $user $name version: $version, ok",'A');
                    }
                    else {
                        if ( $name eq "database" ) {
                            notify("Error! user $user $name version: $version, not like $patch_version",'A');
                            push @$ERROR, "Error! user $user $name version: $version, not like $patch_version";
                        }
                        else {
                            if ( $name eq "dbwlm" or $name eq "tomcat" ) {
                                notify("ser $user $name version: $version, ok",'A');
                            }
                            else {
                                notify("Warning! user $user $name version: $version, not like $patch_version",'A');
                            }
                        }
                    }
                }
            }
        }
    }
    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to check_patch_version for $patch_version");
}

