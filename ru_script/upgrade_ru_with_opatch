        push @user_list, $oracle_user;
        my $time1 = time();

        # 按以下顺序执行 GI_MRP/DB_MRP/GI_ONEOFF/DB_ONEOFF
        if ( defined $tag->{"gi_mrp"} ) {
            notify("    do GI_MRP for $patch_number");
            $patch_type = "GI_MRP";
            do_gi_mrp($dir);
        }

        if ( defined $tag->{"db_mrp"} ) {
            notify("    do DATABASE_MRP for $patch_number");
            $patch_type = "DATABASE_MRP";
            do_db_mrp($dir);
        }

        if ( defined $tag->{"gi_oneoff"} ) {
