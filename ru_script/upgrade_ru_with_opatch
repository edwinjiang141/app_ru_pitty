sub print_cmd_log {
    my ($cmd_log,$error_log,$not_display) = @_;
    my @log1_tmp = get_all_line($cmd_log);
    my @log2 = get_all_line($error_log);
    my @log1;
    foreach my $line ( @log1_tmp ) {
        chomp $line;                    # 去掉换行符
        $line =~ s/^\s+|\s+$//g;        # 去掉前后空格
        next if $line =~ m/^$/;         # 去掉空行
        next if $line =~ m/^Welcome/i;         # 去掉顶头带welcome的行
        next if $line =~ m/YOU HAVE NEW MAIL/i;
        push @log1, $line;
    }

    if ( not defined $not_display ) {
        notify("        cat $cmd_log",'A') if defined $log1[0];
        foreach my $line ( @log1 ) {
            next if $line =~ m/ld: 0711/;               # ld: 0711-224 WARNING: Duplicate symbol: .aio_nwait_timeout64
            next if $line =~ m/Symbol was expected/;    # Symbol was expected to be local. Extra instructions
            next if $line =~ m/are being generated to reference the symbol/;    # are being generated to reference the symbol
            notify("            $line",'A');
        }
        notify("        cat $error_log",'A') if defined $log2[0];
        foreach my $line ( @log2 ) {
            notify("            $line",'A');
        }
    }
    else {
        notify("        cat $cmd_log",'N') if defined $log1[0];
        foreach my $line ( @log1 ) {
            notify("            $line",'N');
        }
        notify("        cat $error_log",'N') if defined $log2[0];
        foreach my $line ( @log2 ) {
            notify("            $line",'N');
        }
    }
    return ([ @log1 ],[ @log2 ]);
}

sub time_diff_in_minutes {
    my ($time1,$time2) = @_;

    if ( not defined $time1 or not defined $time2 ) {
       return "error,not defined";
    }

    # notify ( "      time_diff_in_seconds, time1 is:$time1 , time2 is:$time2","N" );

    #比较的time1/time2格式为：2012-05-22 22:25:34

    my $seconds1 = $time1;
    my $seconds2 = $time2;

    my ($time_diff_in_seconds,$time_diff_in_minutes);
    #此处做自动判断，哪个数值大，哪个放在前面
    if ( $seconds1 > $seconds2 ) {
       $time_diff_in_seconds = $seconds1 - $seconds2;
    }
    else {
       $time_diff_in_seconds = $seconds2 - $seconds1;
    }
    # notify ( "      time_diff_in_seconds is $time_diff_in_seconds","N" );
    $time_diff_in_seconds =~ s/-//;
    # notify ( "      time_diff_in_seconds is $time_diff_in_seconds","N" );
    $time_diff_in_minutes = $time_diff_in_seconds / 60;
    $time_diff_in_minutes = sprintf "%.2f", $time_diff_in_minutes;

    return ($time_diff_in_seconds,$time_diff_in_minutes);
}

sub time_diff {
    my ($time1,$time2) = @_;

    if ( not defined $time1 or not defined $time2 ) {
       return "error,not defined";
    }

    #notify ( "debug" =>  "time_diff, time1 is:$time1 , time2 is:$time2" );

    #比较的time1/time2格式为：2012-05-22 22:25:34

    my $seconds1 = $time1;
    my $seconds2 = $time2;

    my $time_diff;
    #此处做自动判断，哪个数值大，哪个放在前面
    if ( $seconds1 > $seconds2 ) {
       $time_diff = $seconds1 - $seconds2;
    }
    else {
       $time_diff = $seconds2 - $seconds1;
    }
    $time_diff =~ s/-//;

    return $time_diff;
}

sub format_number {
   my $number = shift;
   if ( not defined $number ) {
      $number = 0;
   }
   if ( $number =~ m/^(\d+)?\.\d+/ ) {
      $number = sprintf "%.2f", $number;
   }
   local $_  = $number;
   1 while s/((?:\A|[^.0-9])[-+]?\d+)(\d{3})/$1,$2/s;
   return $_;
}

