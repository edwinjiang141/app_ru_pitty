sub fuser_for_a_dir {
    my ($dir) = @_;
    notify("fuser for $dir",'A');
    my $cmd = "fuser -c $dir 2>/dev/null";
    notify("    fuser cmd is $cmd",'A');
    my $fuser = execute_cmd($cmd);
    my $ps = execute_cmd("ps -ef");
    my @fuser = split /\s+/, $fuser->[0];
    foreach my $id ( @fuser ) {
        next if $id !~ m/^\d/;
        # notify("fuser: $id",'A');
        foreach my $process ( @$ps ) {
            $process =~ s/^\s+|\s+$//g;         # 去掉前后空格
            next if $process =~ m/\s+sshd/;
            next if $process =~ m/\s+sh$/;
            next if $process =~ m/bash$/;
            next if $process =~ m/\s+pts/;
            my @F2 = split /\s+/, $process;
            if ( $id eq $F2[1] ) {
                notify("    in use: $process",'A');
                # 此时可以 kill 此进程
                my $kill_cmd = "kill -9 $id";
                notify("    kill process cmd is: $kill_cmd",'A');
                system($kill_cmd);
            }
        }
    }
}

sub get_sqlplus_version {

    # 返回sqlplus的版本 19.0.0.0.0 / 19.14.0.0.0 / 12.2.0.1.0 / 11.2.0.4.0
    notify("    get_sqlplus_version",'N');
    $ENV{ORACLE_HOME} = get_oracle_home_with_echo("$oracle_user");
    my $sqlplus = catfile ($ENV{ORACLE_HOME},"bin/sqlplus");
    my @result = `$sqlplus -v`;
    my ($sqlplus_version);
    foreach my $line ( @result ) {
        if ( $line =~ m/Version/ ) {
            my @tmp = split /\s+/, $line;
            $sqlplus_version = $tmp[1];
        }
    }
    if ( not defined $sqlplus_version ) {
        foreach my $line ( @result ) {
            if ( $line =~ m/Release/ ) {
                my @tmp = split /\s+/, $line;
                $sqlplus_version = $tmp[2];
            }
        }
    }
    notify("    sqlplus_version is $sqlplus_version",'A');
    return $sqlplus_version;
}

