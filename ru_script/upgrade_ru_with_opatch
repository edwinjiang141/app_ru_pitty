sub check_conflict {
    notify("*** check_conflict",'A');

    my $time_str = strftime '%Y-%m-%d %H:%M:%S', localtime;
    my $hostname = get_local_host_name();
    my $conflict_check_file = "/tmp/conflict_check_for_ru_" . $hostname . ".acs";
    # 写入记录文件 每次都重写覆盖
    my $fd = IO::File->new("> $conflict_check_file");
    print $fd "### conflict check result for ru , $time_str\n";

    # 所有目录从$CONFIG变量中取得
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $grid_home = get_oracle_home_with_echo("$grid_user") if $env_type eq "crs" or $env_type eq "has";
    my $opatch_for_grid = catfile($grid_home,"OPatch/opatch") if $env_type eq "crs" or $env_type eq "has";
    my $opatch_for_db = catfile($oracle_home,"OPatch/opatch");

    my $ru = $CONFIG->{ru};
    my $patch_dir = $CONFIG->{patch_dir};
    ### $patch_dir
    ### $ru
    my $conflict_check_result;
    foreach my $patch_name ( sort keys %$patch_dir ) {
        ### $patch_name
        my $patch_path = $patch_dir->{$patch_name};
        if ( $patch_name eq "ocw"
            or $patch_name eq "acfs"
            or ( $patch_name eq "dbwlm" and defined $ru->{dbwlm} and $ru->{dbwlm} ne "00000000" )      # dbwlm 有可能不存在
            or $patch_name eq "db"
            or $patch_name eq "tomcat"
            ) {
            # grid 用户执行冲突检测
            notify("check_conflict_for_grid",'A') if $env_type eq "crs" or $env_type eq "has";
            $conflict_check_result->{$grid_user}->{$patch_name} = do_patch_conflict_check($grid_user,$opatch_for_grid,$patch_path,$patch_name) if $env_type eq "crs" or $env_type eq "has";
        }
        if ( $patch_name eq "ocw"
            or $patch_name eq "db"
            or ( $patch_name eq "ojvm" and defined $CONFIG->{ojvm}->{number} and $CONFIG->{ojvm}->{number} ne "00000000" )       # ojvm 有可能不存在
            ) {
            # db 用户执行冲突检测
            notify("check_conflict_for_db",'A');
            $conflict_check_result->{$oracle_user}->{$patch_name} = do_patch_conflict_check($oracle_user,$opatch_for_db,$patch_path,$patch_name);
        }
    }
    ### $conflict_check_result
    my $tag = "-";
    foreach my $username ( sort keys %$conflict_check_result ) {
        foreach my $patch_name ( sort keys %{ $conflict_check_result->{$username} } ) {
            my $check_result = $conflict_check_result->{$username}->{$patch_name};
            if ( $check_result eq "ok" ) {
                my $msg = "conflict check for $username\t $patch_name \t is passed";
                notify("$msg");
                print $fd "    # $msg\n";
            }
            else {
                my $msg = "Error! conflict check for $username\t $patch_name \t is wrong";
                push @$ERROR, $msg;
                notify("$msg");
                print $fd "    # $msg\n";
                $tag = "error";
            }
        }
    }

    $fd->close();
}

sub do_patch_conflict_check {
    my ($username,$opatch,$patch_dir,$patch_name) = @_;
    notify("        do_patch_conflict_check for $username $patch_name, patch_dir $patch_dir",'A');
    my $opatch_cmd = $opatch . " prereq CheckConflictAgainstOHWithDetail -phBaseDir";
    my $cmd = "su - $username -c '$opatch_cmd $patch_dir' 1>$cmd_log 2>$error_log";
    notify("        cmd is $cmd",'A');
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display_log");
    my $result = "error";
    if ( defined $result2->[0] ) {
        $result = "error";
    }
    $result = "ok" if grep { /Prereq \"checkConflictAgainstOHWithDetail\" passed/ } @$result1;

    # 此处列出有冲突的补丁号
    ### $result1
    ### $result2
    my @conflict;
    foreach my $line ( @$result1 ) {
        next if $line !~ m/Conflict with/;
        my @F = split /\s+/, $line;
        push @conflict , $F[-1];
    }
    if ( defined $conflict[0] ) {
        notify("        conflict 1719",'A');
        foreach my $patch ( @conflict ) {
            my $msg = "Error! $patch is conflict with patch $patch_name for $username";
            notify("$msg",'A');
            push @$ERROR, $msg;
        }
    }
    return $result;
}

