sub only_drop_null_dir {
    my ($dir) = @_;

    if ( -e $dir ) {
        # 检查大小，如果>1m，就不删除，报错退出
        my @size = `du -sk $dir`;
        my $size = shift @size;
        chomp $size;
        notify("du -sk is $size",'A');
        $size = (split /\s/,$size)[0];
        if ( $size > 1024 ) {
            notify("Error! $dir is not null",'A');
            exit 1;
        }
        # 小于1m，说明是空目录，删除
        my $cmd = "rm -rf $dir 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system("$cmd");
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display_log");
        if ( defined $result2->[0] ) {
            notify("Error! $cmd is error!");
            exit 1;
        }
    }
}

sub parse_crsconfig_params {
    notify("parse_crsconfig_params",'A');
    my $time1 = time();

    my ($grid_user,$grid_home,$group_for_dba,$group_for_asm);
    $grid_user = "not_find";
    $grid_home = "not_find";
    $group_for_dba = "not_find";
    $group_for_asm = "not_find";
    return ($grid_user,$grid_home,$group_for_dba,$group_for_asm) if !-e "/etc/oracle/olr.loc";

    if ( -e "/etc/oracle/olr.loc" ) {
        notify("    check /etc/oracle/olr.loc",'A');
        my @ocr_loc = get_all_line("/etc/oracle/olr.loc");
        # 取得 GRID_HOME
        foreach my $line ( @ocr_loc ) {
            if ( $line =~ m/crs_home/i ) {
                my @F = split /=/,$line;
                $grid_home = $F[1] if defined $F[1];
            }
        }

        if ( defined $grid_home ) {
            # $ORACLE_HOME/crs/install/crsconfig_params
            my $crsconfig = catfile($grid_home,"crs/install/crsconfig_params");
            my @a1 = get_all_line_without_null($crsconfig);
            foreach my $line ( @a1 ) {
                if ( $line =~ m/^ORA_DBA_GROUP/i ) {
                    my @F = split /=/,$line;
                    $group_for_dba = $F[1] if defined $F[1];
                }
                if ( $line =~ m/^ORA_ASM_GROUP/i ) {
                    my @F = split /=/,$line;
                    $group_for_asm = $F[1] if defined $F[1];
                }
                if ( $line =~ m/^ORACLE_OWNER/i ) {
                    my @F = split /=/,$line;
                    $grid_user = $F[1] if defined $F[1];
                }
            }
        }
    }

    notify("    grid_home is $grid_home","A");
    notify("    grid_user is $grid_user","A");
    notify("    group_for_dba is $group_for_dba","A");
    notify("    group_for_asm is $group_for_asm","A");

    my $time2 = time();
    my $time_diff = time_diff($time2,$time1);
    # notify("    time: $time_diff seconds to get_grid_home");

    return ($grid_user,$grid_home,$group_for_dba,$group_for_asm);
}

