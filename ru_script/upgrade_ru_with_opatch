        notify("    time: $time_diff_minutes minutes to update $patch_type $patch_number");

    }


    my $time_stop = time();
    my ($time_diff_seconds,$time_diff_minutes) = time_diff_in_minutes($time_start,$time_stop);
    notify("time: $time_diff_seconds seconds to update_one_off");
    notify("time: $time_diff_minutes minutes to update_one_off");

}

