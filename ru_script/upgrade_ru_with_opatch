sub do_datapatch {
    my ($oracle_sid) = @_;

    notify("do_datapatch for $oracle_sid",'A');
    my $time1 = time();
    # OPatch/datapatch -verbose
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    # my $datapatch = catfile($oracle_home,"OPatch/datapatch -verbose -apply -force");
    my $datapatch = catfile($oracle_home,"OPatch/datapatch -verbose");
    my $cmd = "su - $oracle_user -c 'export ORACLE_SID=$oracle_sid;$datapatch' 1>$cmd_log 2>$error_log";
    notify("    cmd is $cmd",'A');
    system($cmd);

    my $datapatch_log = "$log_dir/datapatch_log_$oracle_sid." . get_locatime_for_file() . ".log";
    copy ($cmd_log, $datapatch_log);
    notify("datapatch log is $datapatch_log");
    my $datapatch_error_log = "$log_dir/datapatch_error_log_$oracle_sid" . get_locatime_for_file() . ".log";
    copy ($error_log, $datapatch_error_log);
    notify("datapatch error log is $datapatch_error_log");

    ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display");

    # Patch 33561310 apply: WITH ERRORS
    # Patch 33515361 apply: SUCCESS
    my $tag = 'ok';
    foreach my $line ( @$result1 ) {
        $tag = "with_errors" if $line =~ m/WITH ERRORS/;
        $tag = "failed" if $line =~ m/catconExec failed/;
        $tag = "failed" if $line =~ m/Prereq check failed/;
    }
    if ( $tag eq "with_errors" ) {
        notify("Warning! datapatch for $oracle_sid has error, please check $cmd_log",'A');
        print_cmd_log($cmd_log,$error_log);
    }
    if ( $tag eq "failed" ) {
        notify("Error! datapatch for $oracle_sid is failed, please check $cmd_log",'A');
        push @$ERROR, "Error! datapatch for $oracle_sid is failed, please check $cmd_log";
        print_cmd_log($cmd_log,$error_log);
    }
    if ( $tag eq "ok" ) {
        notify("datapatch for $oracle_sid is done",'A');
    }

    my $time2 = time();
    my $time_diff_total = time_diff($time1,$time2);
    notify("time: $time_diff_total seconds to do_datapatch for $oracle_sid");
    return $tag;
}

sub start_database_using_srvctl {
    my ($db_name_and_sid) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};

    if ( $env_type eq "fs" ) {
        start_instance($db_name_and_sid);
        return;
    }

    # 检查ASM进程
    my $asm_status = check_asm_process();
    if ( $asm_status eq "asm_is_not_running" ) {
        notify("Error! asm is not running");
        exit 1;
    }

    notify("start_database_using_srvctl for $db_name",'A');
    my $time_start = time();

    unlink $cmd_log;
    unlink $error_log;
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $srvctl = catfile($oracle_home,"bin/srvctl");
    my $cmd = "su - $oracle_user -c '$srvctl start database -d $db_name' 1>$cmd_log 2>$error_log";
    notify("    cmd is $cmd",'A');
    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);

    if ( $env_type eq "crs" ) {
        # 此处添加检查语句
        my $all_node_hostname = get_all_node_hostname();
        my $nodes = join(',',@$all_node_hostname);
        # srvctl status instance -db orcl -node rac12c01
        my $hostname = get_local_host_name();
        my $db_type = get_srvctl_database_type($db_name);
        $cmd = "su - $oracle_user -c '$srvctl status instance -d $db_name -n $nodes' 1>$cmd_log 2>$error_log" if $db_type eq "rac";
        $cmd = "su - $oracle_user -c '$srvctl status database -d $db_name' 1>$cmd_log 2>$error_log" if $db_type eq "rac_one_node";
    }
    $cmd = "su - $oracle_user -c '$srvctl status database -d $db_name' 1>$cmd_log 2>$error_log" if $env_type eq "has";
    notify("    cmd is $cmd",'A');
    system($cmd);

    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    my $tag = "no";
    foreach my $line ( @$result1 ) {
        if ( $line =~ m/is running/i ) {
            $tag = "yes";
        }
    }
    if ( $tag eq "yes" ) {
        notify("srvctl start database -d $db_name is done",'A');
    }
    else {
        notify("Error! srvctl start database -d $db_name has error",'A');
        push @$ERROR, "Error! srvctl start database -d $db_name has error";
    }

    # 如果是RAC ONE NODE，要先检查本地是否启动了实例
    my $db_type = get_srvctl_database_type($db_name);
    my $srvctl_instance_status = get_local_srvctl_instance_status($db_name);
    if ( $db_type eq "rac_one_node" ) {
        if ( $srvctl_instance_status eq "running_at_local" ) {
            my $pdb = check_pdb($oracle_sid);
            # 打开所有节点的PDB
            open_pdb_all_node($oracle_sid) if $pdb eq "yes";
        }
    }
    else {
        my $pdb = check_pdb($oracle_sid);
        # 打开所有节点的PDB
        open_pdb_all_node($oracle_sid) if $pdb eq "yes";
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task start_database_using_srvctl for $db_name");
}

sub start_listener_all_for_oracle_user {
    notify("*** start_listener_all_for_oracle_user",'A');
    my $time_start = time();

    # 启动 oracle 用户下的监听
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $cmd = "su - $oracle_user -c 'echo \$TNS_ADMIN'";
    my $result = execute_cmd($cmd);
    my $tns_admin = $result->[0];
    my $listener_config;
    $listener_config = catfile($tns_admin,"listener.ora") if defined $tns_admin;
    $listener_config = catfile($oracle_home,"network/admin/listener.ora") if not defined $tns_admin;
    my @listener_file_content = get_all_line_without_null($listener_config);
    my $listener_list;
    foreach my $line ( @listener_file_content ) {
        # 监听名称标准： LISTENR = 或者  LSNR =
        # 以字符开头，=号结束，前面没有括号
        next if $line =~ m/\(/;
        next if $line =~ m/\)/;
        ### $line
        if ( $line =~ m/=$/ ) {
            my @F = split /\s+/, $line;
            push @$listener_list, $F[0];
        }
    }
    ### listener_list: $listener_list

    # 取得已经启动的监听清单
    $cmd = "ps -ef|grep $oracle_user|grep -v grep|grep tnslsnr";
    notify("$cmd",'A');
    $result = execute_cmd($cmd);
    my $listener_started;
    foreach my $line ( @$result ) {
        $line =~ s/^\s+|\s+$//g;
        my @F = split /\s+/, $line;
        push @$listener_started, $F[-2];
    }

    my $lsnrctl = catfile($oracle_home,"bin/lsnrctl");
    foreach my $listener ( @$listener_list ) {
        my $started = "no";
        foreach my $listener2 ( @$listener_started ) {
            $started = "yes" if $listener eq $listener2;
        }
        if ( $started eq "yes" ) {
            notify("listener $listener for $oracle_user is already started",'A');
            next;
        }

        my $start = $lsnrctl . " start " . $listener;
        notify("$start",'A');
        my $cmd = "su - $oracle_user -c '$start' 1>$cmd_log 2>$error_log";
        system($cmd);
        notify("start listener $listener for $oracle_user",'A');
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        if ( defined $result2->[0] ) {
            notify("Error! $cmd is error!");
            exit 1;
        }
    }

    my $time_stop = time();
    my $time_diff = time_diff($time_start,$time_stop);
    notify("time: $time_diff seconds to start_listener_all_for_oracle_user");
}

