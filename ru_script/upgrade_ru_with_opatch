sub get_environment_type {
    notify("    get_environment_type",'A');
    # 判断环境类型，分为RAC/HAS/fs
    my $time1 = time();
    my ($environment_type);

    # 有可能是crs/has没有启动，从/etc/oracle/olr.loc文件来检查
    my $grid_home;
    if ( -e "/etc/oracle/olr.loc" ) {
        notify("    check /etc/oracle/olr.loc",'A');
        my @ocr_loc = get_all_line("/etc/oracle/olr.loc");
        # 取得 GRID_HOME
        foreach my $line ( @ocr_loc ) {
            if ( $line =~ m/crs_home/i ) {
                my @F = split /=/,$line;
                $grid_home = $F[1] if defined $F[1];
            }
        }
        if ( defined $grid_home ) {
            # $ORACLE_HOME/crs/install/crsconfig_params
            my $crsconfig = catfile($grid_home,"crs/install/crsconfig_params");
            notify("    check $crsconfig",'A');
            my @aa = get_all_line($crsconfig);
            ### @aa
            foreach my $line ( @aa ) {
                if ( $line =~ m/^NODE_NAME_LIST/i ) {   # NODE_NAME_LIST=db19ce01,db19ce02
                    ### $line
                    my @F = split /=/,$line;
                    $environment_type = "crs" if defined $F[1];
                    $environment_type = "has" if not defined $F[1];
                }
            }
        }
    }
    else {
        # 文件系统
        $environment_type = "fs";
    }

    notify("    environment_type is $environment_type","A");

    my $time2 = time();
    my $time_diff = time_diff($time2,$time1);
    notify("    time: $time_diff seconds to get_environment_type");

    return $environment_type;
}

sub get_crsctl_status_res_t {
    notify("get_crsctl_status_res_t");
    my $environment_type = get_environment_type();
    if ( $environment_type eq "fs" ) {
        return;
    }

    my $time1 = time();
    my $crs_home = get_crs_home();
    my $crsctl = $crs_home . "/bin/crsctl";

    # 检查CRS各资源栈状态 crsctl status res -t
    my $cmd = "$crsctl status res -t";
    notify("execute: $cmd");
    my $result = execute_cmd($cmd);

    my @crsctl_status_res_t;
    foreach my $line ( @$result ) {
        next if $line =~ m/^\-/;
        next if $line =~ m/^Name/;
        next if $line =~ m/^NAME/;
        next if $line =~ m/^Local Resources/;
        next if $line =~ m/^Cluster Resources/;
        push @crsctl_status_res_t, $line;
    }

    my @crsctl_status_res_t_new;
    my $merge_line = '';
    my $idx = 0;
    foreach my $line ( @crsctl_status_res_t ) {         # 合并为1行，加上;号作为分隔符
        #           'ora.orcl.db',
        #           '      1        ONLINE  ONLINE       testrac01                Open,HOME=/u01/app/o',
        #           '                                                             racle/product/19.3.0',
        #           '                                                             /db_1,STABLE',
        chomp $line;
        $line =~ s/^\s+|\s+$//g;        # 去掉空白
        next if $line =~ m/^$/;         # 跳过空行
        if ( $line =~ m/^ora\./ ) {     # 新的1行开始
            $merge_line =~ s/;$// if defined $merge_line;                               # 去掉最后一个;号
            push @crsctl_status_res_t_new, $merge_line if defined $merge_line;          # 将merge_line的内容加到列表
            $merge_line = '';
            $merge_line = $line . ";";
        }
        else {
            # 如果已经是最后一行，就跳过这个操作
            next if $idx == $#crsctl_status_res_t;
            # 如果下一行只有一个字段，本行就不添加;号
            my $next_line = $crsctl_status_res_t[$idx + 1];
            $next_line =~ s/^\s+|\s+$//g;        # 去掉空白
            my @F = split /\s+/, $next_line;
            if ( defined $F[1] ) {
                $merge_line .= $line . ";";
            }
            else {
                $merge_line .= $line;
            }
        }
        $idx ++;
    }

    # 每一行以;号为分隔符，第1部分是资源名称，后面每个部分是每个节点的状态
    # Name           Target  State        Server                   State details
    my $crsctl_status_res_t;
    foreach my $line ( @crsctl_status_res_t_new ) {
        $line =~ s/^\s+|\s+$//g;        # 去掉空白
        next if $line =~ m/^$/;
        my @F = split /;/, $line;
        my $resource_name = shift @F;
        notify("    resource_name is $resource_name","N");
        foreach my $line2 ( @F ) {
            # Local Resources
            #   Target  State  Server  State_details
            # Cluster Resources
            #   node Target  State  Server  State_details
            my @F2 = split /\s+/, $line2;
            my ($node,$target,$state,$server,$state_details);
            if ( $F2[0] =~ m/^\d/ ) {   # 是数字，说明是Cluster Resources
                # Cluster Resource有几个类型，会有一个额外的节点行，此行没有server字段
                if ( defined $F2[4] ) {
                    $node = $F2[0];
                    $target = $F2[1];
                    $state = $F2[2];
                    $server = $F2[3];
                    $state_details = $F2[4];
                }
                elsif ( defined $F2[3] ) {
                    $node = $F2[0];
                    $target = $F2[1];
                    $state = $F2[2];
                    $server = '-';
                    $state_details = $F2[3];
                }
                elsif ( defined $F2[2] ) {
                    $node = $F2[0];
                    $target = $F2[1];
                    $state = $F2[2];
                    $server = '-';
                    $state_details = '-';
                }
                else {
                    notify("Error! resource $resource_name status has error.");
                    $node = $F2[0];
                    $target = $F2[1];
                    $state = $F2[2];
                    $server = '-';
                    $state_details = '-';
                }
            }
            else {
                $node = '-';
                if ( defined $F2[3] ) {
                    $target = $F2[0];
                    $state = $F2[1];
                    $server = $F2[2];
                    $state_details = $F2[3];
                }
                elsif ( defined $F2[2] ) {
                    $target = $F2[0];
                    $state = $F2[1];
                    $server = $F2[2];
                    $state_details = '-';
                }
                else {
                    $target = $F2[0];
                    $state = $F2[1];
                    $server = '-';
                    $state_details = '-';
                }
            }

            notify("    node is $node,target is $target,state is $state,server is $server,state_details is $state_details","N");
            # 添加到 crsctl_status_res_t
            my $hash;
            $hash->{resource_name} = $resource_name;
            $hash->{node} = $node;
            $hash->{target} = $target;
            $hash->{state} = $state;
            $hash->{server} = $server;
            $hash->{state_details} = $state_details;

            push @$crsctl_status_res_t, $hash;
        }
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to get_crsctl_status_res_t");

    return $crsctl_status_res_t;
}

sub get_crs_type_with_crsctl {
    my ($crsctl) = @_;
    notify("get_crs_type_with_crsctl",'A');

    # 判断是CRS还是HAS
    my ($crs_type,@cmd,@tmp,$tmp);
    @cmd = `$crsctl check crs`;
    foreach my $line ( @cmd ) {
        #chmod($line);
        #print("1413 $line\n");
    }
    if ( $cmd[0] =~ m/Parse error/ ) {
        @cmd = `$crsctl check has`;
        if ( $cmd[0] =~ m/Oracle High Availability Services/ ) {
            $crs_type = "has";
        }
        else {
            $crs_type = "has_but_error";
        }
    }
    elsif ( $cmd[0] =~ m/Oracle High Availability Services/ ) {
        $crs_type = "crs";
    }
    else {
        $crs_type = "crs_but_error";
    }
    notify("crs type is $crs_type");

    notify("Error! crs type is $crs_type") if $crs_type =~ m/error/;

    return($crs_type);
    #return if $crs_type =~ m/error/;
}

