sub get_dir {
    my ($dir,$new_dir) = @_;
    undef @FILE_LIST if defined $new_dir;
    undef @DIR_LIST if defined $new_dir;

    #print("dir is $dir\n");
    opendir (DIR,"$dir") or die "Can't open dir:$!";
    my @file = readdir(DIR);
    ### @file
    closedir(DIR);
    foreach (@file){
        next if $_ eq '.' or $_ eq '..';
        my $file = "$dir/$_";
        ### $file
        if (-d $file){
            #print("266 file is $file\n");
            push @DIR_LIST, $file;
        }
    }
    ### @DIR_LIST
    return ( [ @DIR_LIST ] );
}

sub update_one_off {
    return if not defined $CONFIG->{patch_dir}->{one_off_dir};
