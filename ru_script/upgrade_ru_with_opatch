sub check_backup_space {
    notify("*** check_backup_space",'A');

    my ($du_grid_home);
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        chomp ($tmp = `du -sk $grid_home 2>/tmp/du_grid_home`);
        $du_grid_home = (split /\s+/,$tmp)[0];
        if ( defined $du_grid_home ) {
            $du_grid_home = int($du_grid_home/1024);
            my $format_du_grid_home = format_number($du_grid_home);
            notify("grid_home size in mb:\t\t $format_du_grid_home",'A');
        }
        else {
            notify("Error! can not get du -sk $grid_home",'A');
            exit 1;
        }
    }

    chomp ($tmp = `du -sk $oracle_home 2>/tmp/du_oracle_home`);
    my $du_oracle_home = (split /\s+/,$tmp)[0];
    if ( defined $du_oracle_home ) {
        $du_oracle_home = int($du_oracle_home/1024);
        my $format_du_oracle_home = format_number($du_oracle_home);
        notify("oracle_home size in mb:\t\t $format_du_oracle_home",'A');
    }
    else {
        notify("Error! can not get du -sk $oracle_home",'A');
        exit 1;
    }

    chomp ($tmp = `du -sk $oraInventory`);
    my $du_inventory_dir = (split /\s+/,$tmp)[0];
    if ( defined $du_inventory_dir ) {
        $du_inventory_dir = int($du_inventory_dir/1024);
        my $format_du_inventory_dir = format_number($du_inventory_dir);
        notify("oraInventory dir size in mb:\t $format_du_inventory_dir",'A');
    }
    else {
        notify("Error! can not get du -sk $oraInventory",'A');
        exit 1;
    }

    my ($backup_need_mb,$format_backup_need_mb);
    ### du_grid_home: $du_grid_home
    ### du_oracle_home: $du_oracle_home
    ### du_inventory_dir: $du_inventory_dir
    $backup_need_mb = $du_grid_home + $du_oracle_home + $du_inventory_dir if $env_type eq "crs" or $env_type eq "has";
    $backup_need_mb = $du_oracle_home + $du_inventory_dir if $env_type eq "fs";
    $format_backup_need_mb = format_number($backup_need_mb);
    notify("backup_need_mb:\t\t\t $format_backup_need_mb",'A');

    #检查备份目录是否存在，如果不存在，则建立
    if ( $backup_dir eq "not_defined" ) {
        notify("not defined backup_dir",'A');
        $TAG->{backup} = "no";
    }
    else {
        if ( !-e $backup_dir ) {
            mkdir $backup_dir or die;
        }
        #检查备份目录空间是否足够 (grid_home + oracle_home + inventory_dir) * 1.5
        my $free_space = get_free_space ( $backup_dir );
        notify("free_space $free_space",'A');
        $free_space = int($free_space/1024);
        my $format_free_space = format_number($free_space);
        notify("free space of backup_dir in mb:\t $format_free_space",'A');

        if ( $free_space >= $backup_need_mb * 1.5 ) {
            $TAG->{backup} = "yes";
        }
        else {
            # 此处检查是否有备份，如果有备份，就忽略
            # my $msg = "Error! 剩余空间不足，备份需要 $backup_need_mb MB，空间建议 1.5 倍";
            my $msg = "Error! Insufficient space for $backup_dir, free space is: $free_space MB, backup needs $backup_need_mb MB.";
            push @$ERROR, $msg;
            notify("$msg",'A');
            $TAG->{backup} = "no";
            exit 1;
        }
    }

}

sub check_crs { #2023-10-23 9:26:56 为支持多个节点同时升级，去掉对offline的报错退出
    notify("check_crs","A");
    my ($fd,$tag_global,$tag_for_precheck) = @_;

    print $fd "\n" if defined $fd;
    print $fd "# check CRS\n" if defined $fd;

    # 检查CRS资源是否有OFFLINE
    my $get_crsctl_status_res_t = get_crsctl_status_res_t();
    my $tag_crs_status = "ok";
    foreach my $line ( @$get_crsctl_status_res_t ) {
        if ( $line->{target} eq "ONLINE" and $line->{state} ne "ONLINE" ) {
            next if $line->{resource_name} =~ m/ASMNET1LSNR_ASM/;   # 忽略 ora.ASMNET1LSNR_ASM.lsnr
            my $msg;
            if ( not defined $tag_for_precheck ) {
                $msg = "Note: $line->{resource_name} status is $line->{state} but target is $line->{target}";
                # push @$ERROR, $msg;
            }
            else {
                $msg = "Error! $line->{resource_name} status is $line->{state} but target is $line->{target}";
                push @$ERROR, $msg;
            }
            print $fd "    # $msg\n" if defined $fd;
            $tag_global = "error" if defined $tag_global;
            notify("    $msg","A");
            $tag_crs_status = "error";
        }
    }
    if ( $tag_crs_status eq "ok" ) {
        notify("    crsctl status res -t is ok","A");
        print $fd "    # crsctl status res -t is ok\n" if defined $fd;
    }
    else {
        notify("    crsctl status res -t is OFFLINE","A");
        print $fd "    # crsctl status res -t is OFFLINE\n" if defined $fd;
    }

    # 检查OCR
    my $crs_home = get_crs_home();
    my $ocrcheck = $crs_home . "/bin/ocrcheck";
    my $cmd = "$ocrcheck";
    my $result = execute_cmd($cmd);
    # $result: [
    #            'Status of Oracle Cluster Registry is as follows :',
    #            'Version                  :          4',
    #            'Total space (kbytes)     :     409568',
    #            'Used space (kbytes)      :       2472',
    #            'Available space (kbytes) :     407096',
    #            'ID                       :  903862678',
    #            'Device/File Name         :       +CRS',
    #            'Device/File integrity check succeeded',
    #            'Device/File not configured',
