        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/30787757 is a DB ONE OFF
        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/34672698 is a GI ONE OFF
        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/34774667 is a DB ONE OFF
        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/35122824 is a DB ONE OFF
        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/36420641 is a DB ONE OFF
        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/36479472 is a DB ONE OFF
        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/36907797 is a DATABASE MRP
