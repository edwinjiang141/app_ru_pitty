    print $fd "SET FEEDBACK OFF\n";
    print $fd "SET PAGESIZE 0\n";
    print $fd "SET VERIFY OFF\n";
    print $fd "SET ECHO OFF\n";
    print $fd "SET TERMOUT OFF\n";
    print $fd "SET TRIMSPOOL ON\n";
    print $fd "SET TRIMOUT ON\n";
    print $fd "SET LINESIZE 10000\n";
    print $fd "SET LONG 5000\n";
    print $fd "SET ARRAYSIZE 20\n";
    print $fd "SET TRIMS ON\n";
    print $fd "SET SPACE 2\n";
    print $fd "SET NEWPAGE NONE\n";
    print $fd "SET NUMWIDTH 12\n";
    print $fd "SET SERVEROUTPUT ON\n";
    print $fd "SET WRAP OFF\n";
    print $fd "SET SQLBLANKLINES ON\n";
    print $fd "SET TERM OFF\n";

    print $fd "spool $sql_log\n";
