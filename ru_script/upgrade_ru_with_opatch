    # $ru_defined->{34762026}->{sha256sum}->{hp_ia64} = "826A5674073737A5C11E585B868B9FEC90211AAD48FE38913F5D52836BFBCF0A";

    $ru = $ru_defined->{$gi_number};
    foreach my $version ( sort keys %$ru_defined ) {
