        my $patch_lspatches_for_grid = $opatch_for_grid . " lspatches";

        my $patch_lspatches_for_grid_cmd = "su - $grid_user -c '$patch_lspatches_for_grid' 1>$cmd_log 2>$error_log";
        notify("    cmd is $patch_lspatches_for_grid_cmd",'A');
        system($patch_lspatches_for_grid_cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        foreach my $line ( @$result1 ) {    # 29585399;OCW RELEASE UPDATE 19.3.0.0.0 (29585399)
            my @tmp = split /;/, $line;     # $tmp[0] 是补丁号
            next if not defined $tmp[1];
            my $patch_number = $tmp[0];
            my $patch_name = lc ( (split /\s+/, $tmp[1])[0] );
            # grid 用户执行补丁确认
            notify("    opatch lspatches verify for grid, patch_number: $patch_number, patch_name: $patch_name",'A');
            # $patch_verify_result->{$grid_user}->{$patch_name} = do_opatch_lspatches_verify($grid_user,$opatch_for_grid,$patch_number);
            if ( $patch_name eq "database" or $patch_name eq "ocw" ) {
                $patch_verify_result->{$grid_user}->{$patch_name} = "ok";
            }
            else {
                $patch_verify_result->{$grid_user}->{$patch_name} = do_opatch_lspatches_verify($grid_user,$opatch_for_grid,$patch_number);
            }
        }
    }

    my $oracle_home_for_db = get_oracle_home_with_echo("$oracle_user");
    my $opatch_for_db = catfile($oracle_home_for_db,"OPatch/opatch");
    my $patch_lspatches_for_db = $opatch_for_db . " lspatches";

    my $patch_lspatches_for_db_cmd = "su - $oracle_user -c '$patch_lspatches_for_db' 1>$cmd_log 2>$error_log";
    notify("    cmd is $patch_lspatches_for_db_cmd",'A');
    system($patch_lspatches_for_db_cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    foreach my $line ( @$result1 ) {    # 29585399;OCW RELEASE UPDATE 19.3.0.0.0 (29585399)
        my @tmp = split /;/, $line;     # $tmp[0] 是补丁号
        next if not defined $tmp[1];
        my $patch_number = $tmp[0];
        my $patch_name = lc ( (split /\s+/, $tmp[1])[0] );
        # oracle 用户执行补丁确认
        notify("    opatch lspatches verify for oracle, patch_number: $patch_number, patch_name: $patch_name",'A');
        # $patch_verify_result->{$oracle_user}->{$patch_name} = do_opatch_lspatches_verify($oracle_user,$opatch_for_db,$patch_number);
        if ( $patch_name eq "database" or $patch_name eq "ocw" ) {
            $patch_verify_result->{$oracle_user}->{$patch_name} = "ok";
        }
        else {
            $patch_verify_result->{$oracle_user}->{$patch_name} = do_opatch_lspatches_verify($oracle_user,$opatch_for_db,$patch_number);
        }
    }

    ### $patch_verify_result

    foreach my $username ( sort keys %$patch_verify_result ) {
        foreach my $patch_name ( sort keys %{ $patch_verify_result->{$username} } ) {
            my $check_result = $patch_verify_result->{$username}->{$patch_name};
            notify("opatch lspatches verify for $username $patch_name is $check_result",'A');
            if ( $check_result eq "ok" ) {
                my $msg = "opatch lspatches verify for $username $patch_name is passed";
                notify("$msg");
            }
            elsif ( $check_result eq "skip" ) {
                my $msg = "opatch lspatches verify for $username $patch_name is skiped";
                notify("$msg");
            }
            else {
                if ( $patch_name eq "database" or $patch_name eq "ocw" ) {        # opatch lspatches verify 不支持 DBRU/OCWRU
                    my $msg = "opatch lspatches verify for $username $patch_name is ignore";
                    notify("$msg");
                }
                else {
                    my $msg = "Error! opatch lspatches verify for $username $patch_name is wrong";
                    push @$ERROR, $msg;
                    notify("$msg");
                    $tag_local = "error_for_opatch_lspatches_verify_from_lspatches";
                    print $fd "    # $msg\n" if defined $fd;
                }
            }
        }
    }

    return($tag_local);
}

sub relocate_scan_ip {      # 对于每个scan-ip，将它切换给除自己以外的第一个节点
    notify("relocate_scan_ip",'A');
    # 取得 $srvctl
    my $grid_home = get_oracle_home_with_echo("$grid_user");
    my $srvctl = catfile($grid_home,"bin/srvctl");
    if ( !-e $srvctl ) {
        notify("Error! cat not find $srvctl",'A');
        exit 1;
    }

    my $all_node_hostname = get_all_node_hostname();
    ### $all_node_hostname
    my $hostname = get_local_host_name();
    notify("    hostname is $hostname",'A');
    my ($cmd,$result);
    $cmd = "$srvctl status scan";
    my $result01 = execute_cmd($cmd);
    ### $result01

    $cmd = "$srvctl config scan";
    my $result02 = execute_cmd($cmd);
    ### $result02

    foreach my $line ( @$result01 ) {
        next if $line !~ m/running on node/;
        my @F = split /\s+/, $line;
        my $running_host = $F[-1];
        notify("    running_host is $running_host",'N');
        my $scan_name = $F[2];
        notify("    scan_name is $scan_name",'N');
        my ($scan_number) = $F[2] =~ m/scan(\d*)/;
        notify("    scan_number is $scan_number",'N');
        notify("    $scan_name is running on $running_host",'A');
        next if $running_host ne $hostname;
        foreach my $host ( @$all_node_hostname ) {
            next if $host eq $hostname;
            # 执行relocate
            my $cmd = "$srvctl relocate scan -i $scan_number -n $host 1>$cmd_log 2>$error_log";
            notify("    relocate scan-ip cmd is $cmd",'A');
            system($cmd);
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
            if ( defined $result2->[0] ) {
                notify("Error! Error! $cmd is error!");
                exit 1;
            }
            last;   # 只在一个节点执行一次
        }
    }
}

