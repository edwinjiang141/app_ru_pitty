    system($cmd);
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
    if ( defined $result2->[0] ) {
        notify("Error! $cmd is wrong");
        push @$ERROR, "Error! $cmd is wrong";
        exit 1;
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        notify("restore grid_home");
        # 杀掉所有grid进程
        # ps -ef|grep grid|awk '{print $2}'|xargs kill -9
        $cmd = "ps -ef|grep $grid_user|grep -v grep|awk '{print \$2}'|xargs kill -9 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd");
        system($cmd);

        # 删除 grid_home
