sub step_09_verify {
    my $step_name = "step_09_verify";
    notify("*** starting $step_name",'A');
    my $time_start = time();
    my $tag = "ok";

    # 取得记录的patch号
    get_config_from_file();

    # 检查补丁版本
    check_patch_version( $CONFIG->{ru}->{version} );

    # 检查软件版本
    my $oracle_home = get_oracle_home_with_echo("$oracle_user");

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        my $grid_home = get_oracle_home_with_echo("$grid_user");
        my $crsctl = catfile($grid_home,"bin/crsctl");
        my $cmd;
        $cmd = "$crsctl query crs releasepatch" if $env_type eq "crs";
        $cmd = "$crsctl query has releasepatch" if $env_type eq "has";
        notify("    cmd is $cmd");
        my $result = execute_cmd($cmd);
        my $crs_patch;
        my $sqlplus_version = get_sqlplus_version();
        ($crs_patch) = $result->[0] =~ m/release patch string is \[(.*?)\]/ if $sqlplus_version =~ m/^19/;
        ($crs_patch) = $result->[0] =~ m/patch level is \[(.*?)\]/ if $sqlplus_version =~ m/^12/;

        notify("crs_patch is $crs_patch");      # 此处需要判断版本是否正确
    }


    # 检查 opatch lspatches 一致
    my $tag01 = check_lspatches_between_rac_node() if $env_type eq "crs";

    # 验证RU补丁
    my $tag02 = opatch_lspatches_verify_from_config();

    # 检查 oui-patch.xml
    my $tag03 = check_oui_patch_xml() if $env_type eq "crs";

    # 检查节点间crs version是否一致
    my $tag04 = check_crs_releasepatch_between_rac_node() if $env_type eq "crs";   # error_for_crs_releasepatch

    # 检查节点间sqlplus版本是否一致
    my $tag06 = check_sqlplus_version_between_rac_node() if $env_type eq "crs";   # error_for_sqlplus_version

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        # 检查ASM实例
        my $cmd = "ps -ef|grep dbw0|grep ASM|grep -v grep";
        my $result = execute_cmd($cmd);
        if ( not defined $result->[0] ) {
            notify("Error! ASM is not running");
            push @$ERROR, "Error! ASM is not running";
            $tag = "error";
        }
        else {
            notify("ASM is running");
        }
    }

    check_oracle_bin_permission();              # 检查文件权限

    # 检查DB实例
    my $tag_for_datapatch;
    my $db_name_list = get_db_list();
    foreach my $db_name_and_sid ( @$db_name_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }

        my $dbstatus = check_db_process($oracle_sid);
        if ( $dbstatus ne "db_is_running" ) {
            notify("Error! database instance $oracle_sid is not running");
            push @$ERROR, "Error! database instance $oracle_sid is not running";
        }
        else {
