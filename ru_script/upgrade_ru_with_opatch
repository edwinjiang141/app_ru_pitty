    my @F01 = get_all_line($file_path);
    ### @F01
    foreach my $line ( @F01 ) {
        $line =~ s/^\s+|\s+$//g;
        ### $line
        my @F02 = split /=/, $line;
        if ( not defined $F02[1] ) {
            notify("Error! can not find patch number value from $file_path",'A');
