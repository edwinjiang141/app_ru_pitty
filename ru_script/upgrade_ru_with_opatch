        if ( $patch_name eq "ocw"
            or $patch_name eq "db"
            or ( $patch_name eq "ojvm" and defined $CONFIG->{ojvm}->{number} and $CONFIG->{ojvm}->{number} ne "00000000" )       # ojvm 有可能不存在
            ) {
            # db 用户执行补丁确认
            notify("opatch lspatches verify for db",'N');
            $patch_verify_result->{$oracle_user}->{$patch_name} = do_opatch_lspatches_verify($oracle_user,$opatch_for_db,$patch_number);
        }
    }

    # OJVM
    if ( defined $ojvm->{number} and $ojvm->{number} ne "00000000" ) {
        notify("opatch lspatches verify for ojvm",'N');
        $patch_verify_result->{$oracle_user}->{ojvm} = do_opatch_lspatches_verify($oracle_user,$opatch_for_db,$ojvm->{number});
    }

    ### $patch_verify_result

    my $tag = "ok";
    foreach my $username ( sort keys %$patch_verify_result ) {
        next if $username eq $oracle_user and $env_type eq "fs";
        foreach my $patch_name ( sort keys %{ $patch_verify_result->{$username} } ) {
            my $check_result = $patch_verify_result->{$username}->{$patch_name};
            if ( $check_result eq "ok" ) {
                my $msg = "opatch lspatches verify for $username $patch_name is passed";
                notify("$msg");
            }
            elsif ( $check_result eq "skip" ) {
                my $msg = "opatch lspatches verify for $username $patch_name is skiped";
                notify("$msg");
            }
            else {
                if ( $patch_name eq "db" or $patch_name eq "ocw" ) {        # opatch lspatches verify 不支持 DBRU/OCWRU
                    my $msg = "opatch lspatches verify for $username $patch_name is ignore";
                    notify("$msg");
                }
                else {
                    my $msg = "Error! opatch lspatches verify for $username $patch_name is wrong";
                    push @$ERROR, $msg;
                    notify("$msg");
                    $tag = "error";
                }
            }
        }
    }

    return($tag);
}

sub do_opatch_lspatches_verify {
    notify("    do_opatch_lspatches_verify",'A');
    my ($username,$opatch,$patch_number) = @_;
    notify("        do_opatch_lspatches_verify for $username , patch_number $patch_number",'A');
    # opatch lspatches -id 31668882 -verify
    my $opatch_cmd = $opatch . " lspatches -id " . $patch_number . " -verify";
    my $cmd = "su - $username -c '$opatch_cmd' 1>$cmd_log 2>$error_log";
    notify("        cmd is $cmd",'A');
    system($cmd);
    # ($result1,$result2) = print_cmd_log($cmd_log,$error_log,"not_display_log");
    ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
