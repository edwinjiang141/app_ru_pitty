sub do_rollback_ru {
    my $step_name = "do_rollback_ru";
    notify("*** starting $step_name",'A');
    my $time_start = time();

    # 按照/tmp/ru.acs的补丁号，回退所有已经安装的ru补丁
    # 只做回退操作，其它prepatch和postpatch由其它过程控制
    # 按照 db_db/db_ocw/gi_tomcat/gi_dbwlm/gi_acfs/gi_ocw 的顺序进行回退
    # ru.gi=33583921
    # ru.acfs=33116894
    # ru.db=33587128
    # ru.dbwlm=26839277
    # ru.ocw=33678030
    # ru.tomcat=33610989

    # lspatch 列出所有补丁号
    # 如果以下补丁号存在，就rollback
    my ($cmd);
    my $opatch_oracle = catfile($oracle_home,"OPatch/opatch");

    my @rollback_grid;
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        my $opatch_grid = catfile($grid_home,"OPatch/opatch");
        $cmd = "su - $grid_user -c '$opatch_grid lspatches'";
        notify("$cmd",'A');
        my $lspatches_grid = execute_cmd($cmd);

        push @rollback_grid, $ru->{tomcat};
        push @rollback_grid, $ru->{db};
        push @rollback_grid, $ru->{dbwlm};
        push @rollback_grid, $ru->{acfs};
        push @rollback_grid, $ru->{ocw};

        foreach my $patch ( @rollback_grid ) {
            my $tag = "no";
            foreach my $lspatches ( @$lspatches_grid ) {
                $tag = "yes" if $lspatches =~ m/$patch/;
            }
            next if $tag eq "no";       # 不存在

            # opatch rollback -local -silent -id 33610989
            my $cmd = "su - $grid_user -c '$opatch_grid rollback -local -silent -id $patch' 1>$cmd_log 2>$error_log";
            notify("    cmd is $cmd",'A');
            system($cmd);
            ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
            foreach my $line ( @$result1 ) {
                $tag = "ok" if $line =~ m/OPatch succeeded/;
            }

            unless ( $tag eq "ok" ) {
                notify("Error! $cmd is wrong, please check $cmd_log and $error_log");
                exit 1;
            }
        }

    }

    $cmd = "su - $oracle_user -c '$opatch_oracle lspatches'";
    notify("$cmd",'A');
    my $lspatches_oracle = execute_cmd($cmd);

    my @rollback_db;
    push @rollback_db, $ru->{db};
    push @rollback_db, $ru->{ocw};

    foreach my $patch ( @rollback_db ) {
        my $tag = "no";
        foreach my $lspatches ( @$lspatches_oracle ) {
            $tag = "yes" if $lspatches =~ m/$patch/;
        }
        next if $tag eq "no";       # 不存在

        # opatch rollback -local -silent -id 33610989
        my $cmd = "su - $oracle_user -c '$opatch_oracle rollback -local -silent -id $patch' 1>$cmd_log 2>$error_log";
        notify("    cmd is $cmd",'A');
        system($cmd);
        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        foreach my $line ( @$result1 ) {
            $tag = "ok" if $line =~ m/OPatch succeeded/;
        }

        unless ( $tag eq "ok" ) {
            notify("Error! $cmd is wrong, please check $cmd_log and $error_log");
            exit 1;
        }
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to $step_name");
}

