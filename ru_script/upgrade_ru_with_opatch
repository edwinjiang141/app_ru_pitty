sub check_oui_patch_xml {
    notify("*** check_oui_patch_xml","A");
    my ($fd,$tag_global) = @_;
    $tag_global = "do_not_print_file" if not defined $tag_global;

    my $sqlplus_version = get_sqlplus_version();
    return $tag_global unless $sqlplus_version =~ m/^19/;

    my $all_node_hostname = get_all_node_hostname();
    ### $all_node_hostname

    my $oui_patch_xml = catfile($oraInventory,"ContentsXML/oui-patch.xml");
    notify("checking $oui_patch_xml","A");
    print $fd "\n" if defined $fd;
    print $fd "# check $oui_patch_xml\n" if defined $fd;
    my $oui_patch;
    foreach my $host ( @$all_node_hostname ) {
        $cmd = "su - $grid_user -c 'ssh $host cat $oui_patch_xml' 2>/dev/null";
        my $result = execute_cmd($cmd);
        ### $result
        $oui_patch->{$host}->{content} = $result;
        $cmd = "su - $grid_user -c 'ssh $host ls -l $oui_patch_xml' 2>/dev/null";
        $result = execute_cmd($cmd);
        ### $result
        $oui_patch->{$host}->{attribute} = $result;
    }
    ### $oui_patch
    # 假定节点1是正确的（通常节点1是安装发起的节点）
    my $tag;
    my $msg;
    if ( defined $oui_patch->{$all_node_hostname->[0]}->{attribute}->[0] ) {
        my $attribute_of_oui_patch_xml_node_0 = (split /\s+/,$oui_patch->{$all_node_hostname->[0]}->{attribute}->[0])[0];
        my $owner_of_oui_patch_xml_node_0 = (split /\s+/,$oui_patch->{$all_node_hostname->[0]}->{attribute}->[0])[2];
        my $group_of_oui_patch_xml_node_0 = (split /\s+/,$oui_patch->{$all_node_hostname->[0]}->{attribute}->[0])[3];
        # if ( $attribute_of_oui_patch_xml_node_0 ne "-rw-rw----" ) {
        if ( $attribute_of_oui_patch_xml_node_0 !~ m/^.rw.rw/ ) {
            # 属性不正确
            $tag->{attribute} = "error";
            $msg = "Error! attribute of $oui_patch_xml for $all_node_hostname->[0] not eq '-rw-rw----': $attribute_of_oui_patch_xml_node_0";
            notify("$msg");
            push @$ERROR, $msg;
            print $fd "    # $msg\n" if defined $fd;
        }
        elsif ( $owner_of_oui_patch_xml_node_0 ne $grid_user ) {
            # owner不正确
            $tag->{owner} = "error";
            $msg = "Error! owner of $oui_patch_xml for $all_node_hostname->[0] not eq '$grid_user': $owner_of_oui_patch_xml_node_0";
            notify("$msg");
            push @$ERROR, $msg;
            print $fd "    # $msg\n" if defined $fd;
        }
        elsif ( $group_of_oui_patch_xml_node_0 ne "oinstall" ) {
            get_group_for_grid_oracle();
            # 此处要判断 $group_of_oui_patch_xml_node_0 的组名称，grid/oracle是否都在里面
            my $tag1 = "no";
            my $tag2 = "no";
            foreach my $group_name ( @$group_for_grid ) {
                $tag1 = "yes" if $group_name eq $group_of_oui_patch_xml_node_0;
            }
            foreach my $group_name ( @$group_for_oracle ) {
                $tag2 = "yes" if $group_name eq $group_of_oui_patch_xml_node_0;
            }
            if ( $tag1 eq "yes" and $tag2 eq "yes" ) {
                # 虽然不是 oinstall 但oracle/grid都在这个组里面，所以不用报错
            }
            else {
                # group不正确
                $tag->{group} = "error";
                $msg = "Error! group of $oui_patch_xml for $all_node_hostname->[0] not eq 'oinstall': $group_of_oui_patch_xml_node_0";
                notify("$msg");
                push @$ERROR, $msg;
                print $fd "    # $msg\n" if defined $fd;
            }
        }
        else {
            notify("attribute_of_oui_patch_xml of $all_node_hostname->[0] is $attribute_of_oui_patch_xml_node_0");
            # 节点1的文件正确，开始对每个节点做比较
            foreach my $host ( sort keys %$oui_patch ) {
                if ( not defined $oui_patch->{$host}->{attribute}->[0] ) {
                    # 如果attribute为空，报错
                    $tag->{not_exist} = "yes";
                    $msg = "Error! $oui_patch_xml for $host is not exist";
                    push @$ERROR, $msg;
                    notify("$msg");
                    print $fd "    # $msg\n" if defined $fd;
                    # 解决方法是从节点1复制
                    # 判断当前是哪个节点，不同的节点，采用的命令不一样
                    my $hostname = get_local_host_name();
                    if ( $hostname eq $all_node_hostname->[0] ) {       # 当前是节点1，采用的命令是从节点1直接复制到其它节点
                        my $solution = "su - $grid_user -c 'scp $oui_patch_xml $host:$oui_patch_xml'";
                        my $solution_02 = "su - $grid_user -c 'ssh $host chmod 660 $oui_patch_xml'";
                        notify("    solution: $solution","A");
                        notify("    solution: $solution_02","A");
                        print $fd "    $solution\n" if defined $fd;
                        print $fd "    $solution_02\n" if defined $fd;
                    }
                    else {  # 当前不是节点1，需要从节点1 scp
                        my $solution = "su - $grid_user -c 'scp $all_node_hostname->[0]:$oui_patch_xml $oui_patch_xml'";
                        my $solution_02 = "chmod 660 $oui_patch_xml";
                        notify("    solution: $solution","A");
                        notify("    solution: $solution_02","A");
                        print $fd "    $solution\n" if defined $fd;
                        print $fd "    $solution_02\n" if defined $fd;
                    }
                }
                else {  # 属性与节点0不一致，报错
                    my $attribute_of_oui_patch_xml = (split /\s+/,$oui_patch->{$host}->{attribute}->[0])[0];
                    if ( $attribute_of_oui_patch_xml_node_0 ne $attribute_of_oui_patch_xml ) {
                        $tag->{attribute} = "not_consistent";
                        $msg = "Error! attribute of $oui_patch_xml for $host is not consistent with $all_node_hostname->[0]";
                        push @$ERROR, $msg;
                        notify("$msg");
                        print $fd "    # $msg\n" if defined $fd;
                    }
                }
            }
        }
    }
    else {
        # 节点1没有 $oui_patch_xml 说明RAC安装顺序不正确，此时不能使用脚本进行操作
        $tag->{not_exist} = "yes";
        $msg = "Error! $oui_patch_xml for $all_node_hostname->[0] is not exist";
        push @$ERROR, $msg;
        notify("$msg");
        print $fd "    # $msg\n" if defined $fd;
    }
    if ( not defined $tag->{not_exist} ) {
        $msg = "$oui_patch_xml is exist for all node";
        notify("$msg");
        print $fd "    # $msg\n" if defined $fd;
    }
    if ( not defined $tag->{not_exist} and not defined $tag->{attribute} ) {
        $msg = "$oui_patch_xml is correct for all node";
        notify("$msg");
        print $fd "    # $msg\n" if defined $fd;
    }
    else {
        $tag_global = "error_for_oui_patch_xml";
    }

    return $tag_global;
}

sub check_lspatches_between_rac_node {
    notify("*** check_lspatches_between_rac_node","A");
    my ($fd,$tag_local) = @_;
    $tag_local = "do_not_print_file" if not defined $tag_local;
    my $all_node_hostname = get_all_node_hostname();
    ### $all_node_hostname

    # 检查 opatch lspatches
    notify("checking opatch lspatches","A");
    print $fd "\n" if defined $fd;
    print $fd "# check opatch lspatches\n" if defined $fd;
    my ($patches,$msg);
    my $oracle_home_for_db = get_oracle_home_with_echo("$oracle_user");
    my $oracle_home_for_grid = get_oracle_home_with_echo("$grid_user");
    my $opatch_for_grid = catfile($oracle_home_for_grid,"OPatch/opatch");
    my $opatch_for_db = catfile($oracle_home_for_db,"OPatch/opatch");
    foreach my $host ( @$all_node_hostname ) {
        $cmd = "su - $grid_user -c 'ssh $host . ~/$profile_grid;$opatch_for_grid lspatches'";
        my $result = execute_cmd($cmd);
        ### $result
        # $patches->{$host}->{$grid_user} = $result;
        $patches->{$grid_user}->{$host} = $result;
        $cmd = "su - $oracle_user -c 'ssh $host . ~/$profile_oracle;$opatch_for_db lspatches'";
        $result = execute_cmd($cmd);
        ### $result
        # $patches->{$host}->{$oracle_user} = $result;
        $patches->{$oracle_user}->{$host} = $result;
    }
    ### $patches
    foreach my $user ( sort keys %$patches ) {
        # 将每个节点的PATCH信息，与节点0做对比
        my $patch_normal = $patches->{$user}->{$all_node_hostname->[0]};
        ### $patch_normal
        my $tag_patch_number = "yes";
        my $tag_patch_consist = "yes";
        foreach my $host ( sort keys %{ $patches->{$user} }) {
            my $patch = $patches->{$user}->{$host};
            ### $patch
            # 数量要一致
            my $number_of_patche = scalar @$patch;
            my $number_of_patch_normal = scalar @$patch_normal;
            if ( $number_of_patche ne $number_of_patch_normal ) {
                $tag_patch_number = "no";
                $msg = "Error! patch for $user is not consistent between $all_node_hostname->[0] and $host";
                push @$ERROR, $msg;
                notify("$msg");
                print $fd "    # $msg\n" if defined $fd;
            }
            # 每个patch要相同
            my $idx = 0;
            foreach my $line ( @$patch_normal ) {
                my $patch_exist = "no";
                my @F01 = split /;/, $line;
                my $patch_id = $F01[0];
                # my @F02 = split /;/, $patch->[$idx];
                # ### @F01
                # ### @F02
                # if ( $F01[0] ne $F02[0] and $F01[0] !~ m/^OPatch/ ) {   # 不比较 OPatch succeeded. 这样的行，避免中文环境变量
                #     $tag = "no";
                #     $msg = "Error! patch $F01[0] for $user is not consistent between $all_node_hostname->[0] and $host";
                #     push @$ERROR, $msg;
                #     notify("$msg");
                #     print $fd "    # $msg\n" if $tag_local ne "do_not_print_file";
                # }
                # $idx ++;
                # 节点0为标准，patch的每一个id，都要在其它节点有记录，顺序可能不一致
                foreach my $line_of_other_node ( @$patch ) {
                    my @F02 = split /;/, $line_of_other_node;
                    my $patch_id_other_node = $F02[0];
                    $patch_exist = "yes" if $patch_id eq $patch_id_other_node;
                }
                $tag_patch_consist = "no" if $patch_exist eq "no";
            }
        }
        if ( $tag_patch_consist eq "yes" and $tag_patch_number eq "yes" ) {      # patch相同
            $msg = "patch for $user is consistent between rac node";
            notify("$msg");
            print $fd "    # $msg\n" if defined $fd;
        }
        else {
            $tag_local = "error_for_opatch_lspatches";
        }
    }

    return($tag_local);
}

sub get_sqlplus_version_for_a_user {
    my ($oracle_user) = @_;
    # 返回sqlplus的版本 19.0.0.0.0 / 19.14.0.0.0 / 12.2.0.1.0 / 11.2.0.4.0
    notify("    get_sqlplus_version",'N');
    $ENV{ORACLE_HOME} = get_oracle_home_with_echo("$oracle_user");
    my $sqlplus = catfile ($ENV{ORACLE_HOME},"bin/sqlplus");
    my @result = `$sqlplus -v`;
    my ($sqlplus_version);
    foreach my $line ( @result ) {
        if ( $line =~ m/Version/ ) {
            my @tmp = split /\s+/, $line;
            $sqlplus_version = $tmp[1];
        }
    }
    if ( not defined $sqlplus_version ) {
        foreach my $line ( @result ) {
            if ( $line =~ m/Release/ ) {
                my @tmp = split /\s+/, $line;
                $sqlplus_version = $tmp[2];
            }
        }
    }
    notify("    sqlplus_version is $sqlplus_version",'A');
    return $sqlplus_version;
}

sub check_sqlplus_version_between_rac_node {
    notify("*** check_sqlplus_version_between_rac_node","A");
    my ($fd,$tag_local) = @_;
    $tag_local = "do_not_print_file" if not defined $tag_local;
    my $all_node_hostname = get_all_node_hostname();
    ### $all_node_hostname

    notify("checking sqlplus version","A");
    print $fd "\n" if defined $fd;
    print $fd "# check sqlplus version\n" if defined $fd;
    my ($sqlplus_version_for_grid,$sqlplus_version_for_oracle,$sqlplus_version,$msg);

    my $oracle_home_for_db = get_oracle_home_with_echo("$oracle_user");
    my $oracle_home_for_grid = get_oracle_home_with_echo("$grid_user");
    my $sqlplus_grid = catfile($oracle_home_for_grid,"bin/sqlplus");
    my $sqlplus_oracle = catfile($oracle_home_for_db,"bin/sqlplus");
    $sqlplus_version_for_grid = get_sqlplus_version_for_a_user($grid_user);
    $sqlplus_version_for_oracle = get_sqlplus_version_for_a_user($oracle_user);

    foreach my $host ( @$all_node_hostname ) {
        my $cmd = "su - $grid_user -c 'ssh $host . ~/$profile_grid;$sqlplus_grid -V'";
        my $result = execute_cmd($cmd);
        ### $result
        $sqlplus_version->{$host}->{$grid_user} = $result;
        $cmd = "su - $oracle_user -c 'ssh $host . ~/$profile_grid;$sqlplus_grid -V'";
        $result = execute_cmd($cmd);
        ### $result
        $sqlplus_version->{$host}->{$oracle_user} = $result;
    }
    ### $sqlplus_version
    my $tag01 = "yes";
    foreach my $host ( sort keys %$sqlplus_version ) {
        # 将每个节点的PATCH信息，与节点0做对比
        my $sqlplus_grid_normal = $sqlplus_version->{$all_node_hostname->[0]}->{$grid_user}->[-1];
        my $sqlplus_oracle_normal = $sqlplus_version->{$all_node_hostname->[0]}->{$oracle_user}->[-1];
        ### $sqlplus_grid_normal
        ### $sqlplus_oracle_normal
        my $sqlplus_grid_host = $sqlplus_version->{$host}->{$grid_user}->[-1];
        my $sqlplus_oracle_host = $sqlplus_version->{$host}->{$oracle_user}->[-1];
