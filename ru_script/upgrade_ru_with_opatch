    $dbstatus = check_db_process($oracle_sid);
    if ( $dbstatus eq "db_is_running" ) {
        notify("Error! database instance $oracle_sid is running",'A');
        exit 1;
    }
    else {
        notify("database instance $oracle_sid is not running",'A');
    }

    my $time2 = time();
    my $time_diff = time_diff($time1,$time2);
    notify("time: $time_diff seconds to shutdown_instance_using_sqlplus for $oracle_sid ");
}

sub startup_instance_to_nomount {
