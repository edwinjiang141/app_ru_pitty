        @readme_html = get_all_line($readme_html) if -e $readme_html;

        $current_patch ++;
        notify("    applying       $current_patch / $total_patch");

        my $tag;
        # 分成4种补丁类型 gi_mrp/db_mrp/gi_oneoff/db_oneoff
        # 首先检查该目录是否为GI补丁
        # 检查标准是必须包含 GI_HOME 这一行
        if ( grep { /GI MRP/ } @readme_html ) {
            $tag->{gi_mrp} = "yes";
            notify("    $dir is a GI MRP");
        }
        elsif ( grep { /DATABASE MRP/ } @readme_html ) {
            $tag->{db_mrp} = "yes";
            notify("    $dir is a DATABASE MRP");
        }
        elsif ( grep { /GI_HOME/ } @readme_html ) {
            $tag->{gi_oneoff} = "yes";
            notify("    $dir is a GI ONE-OFF");
        }
        elsif ( grep { /GI_HOME/ } @readme_txt ) {
            $tag->{gi_oneoff} = "yes";
            notify("    $dir is a GI ONE-OFF");
        }
        elsif ( grep { /DATABASE_HOME/ } @readme_html ) {
            $tag->{db_oneoff} = "yes";
            notify("    $dir is a DB ONE-OFF");
        }
        elsif ( grep { /ORACLE_HOME/ } @readme_txt ) {
            $tag->{db_oneoff} = "yes";
            notify("    $dir is a DB ONE-OFF");
        }
        else {
            $tag->{unknown} = "yes";
            notify("    $dir is a UNKNOWN patch");
        }


        # /u01/patch/19.23/one_off_dir/unziped_for_opatch/27482397 is a DB ONE OFF
