sub do_datapatch_with_ojvm {
    my ($db_name_and_sid) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};

    notify("*** starting do_datapatch_with_ojvm for $db_name",'A');
    my $time_start = time();

    # 启动对方实例（更新srvctl状态）
    start_database_using_srvctl($db_name_and_sid);

    # 停止DB
    stop_database_using_srvctl($db_name_and_sid);

    # startup nomount
    startup_instance_to_nomount($oracle_sid);

    # CLUSTER_DATABASE=FALSE
    modify_cluster_true_or_false($oracle_sid,"no") if $env_type eq "crs";

    # SHUTDOWN
    stop_instance($db_name_and_sid);

    # STARTUP UPGRADE
    startup_instance_to_open_upgrade($oracle_sid);

    # ALTER PLUGGABLE DATABASE ALL OPEN UPGRADE
    open_pdb_upgrade($oracle_sid);

    # datapatch -verbose
    my $status;
    for ( my $i=1; $i <= 3; $i++ ) {
        $status = do_datapatch($oracle_sid);
        last if $status eq "ok";
        if ( $i == 3 ) {
            notify("Error! datapatch for $oracle_sid has error");
            push @$ERROR, "Error! datapatch for $oracle_sid has error";
            push @$datapatch_error_sid, $oracle_sid;
        }
    }

    if ( $status eq "ok" ) {
        push @$datapatch_done_sid, $oracle_sid;
    }
    elsif ( $status eq "failed" ) {
        push @$datapatch_error_sid, $oracle_sid;
    }

    # CLUSTER_DATABASE=TRUE
    modify_cluster_true_or_false($oracle_sid,"yes") if $env_type eq "crs";

    # SHUTDOWN
    stop_instance($db_name_and_sid);

    # 启动本节点的实例，打开所有PDBA
    start_instance($db_name_and_sid);

    # 启动对方实例
    start_database_using_srvctl($db_name_and_sid);

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task do_datapatch_with_ojvm for $db_name");
}

sub change_oracle_bin_permission {
    notify("*** change_oracle_bin_permission",'A');
    my $tag = "ok";
    my (@F,$oracle_bin_for_db,$oracle_home_for_db);
    $oracle_home_for_db = get_oracle_home_with_echo("$oracle_user");
    $oracle_bin_for_db = catfile($oracle_home_for_db,"bin/oracle");
    my $cmd = "ls -l $oracle_bin_for_db";
    my $result = execute_cmd($cmd);
    notify("    $result->[0]","A");
    @F = split /\s+/, $result->[0];
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        # oracle程序的权限
        my $oracle_home_for_grid = get_oracle_home_with_echo("$grid_user");
        my $oracle_bin_for_grid = catfile($oracle_home_for_grid,"bin/oracle");
        get_group_for_grid_oracle();
        if ( $F[3] ne "asmadmin" ) {
            # 2023-03-25 13:06:32
            # 此处增加一个判断分支，如果grid在asmadmin组里面，则oracle bin的属组必须为asmadmin
            my $tag_for_grid_asmadmin = "no_asmadmin";
            my $tag_for_oracle_asmadmin = "no_asmadmin";
            foreach my $group_name ( @$group_for_grid ) {
                $tag_for_grid_asmadmin = "yes_asmadmin" if $group_name eq "asmadmin";
            }
            foreach my $group_name ( @$group_for_oracle ) {
                $tag_for_oracle_asmadmin = "yes_asmadmin" if $group_name eq "asmadmin";
            }
            if ( $tag_for_grid_asmadmin eq "yes_asmadmin" and $tag_for_oracle_asmadmin eq "yes_asmadmin" ) {
                # 都在asmadmin 不用操作
                notify("$oracle_bin_for_db group is $F[3]","A");
                notify("$grid_user group is $str_group_for_grid","A");
                notify("$oracle_user group is $str_group_for_oracle","A");
            }
            elsif ( $tag_for_grid_asmadmin eq "yes_asmadmin" and $tag_for_oracle_asmadmin eq "no_asmadmin" ) {
                notify("Warning! $oracle_bin_for_db group must be asmadmin","A");
                $tag = "error";
                my $setasmgidwrap = catfile($oracle_home_for_grid,"bin/setasmgidwrap");
                my $solution01 = "su - $grid_user -c '$setasmgidwrap o=$oracle_bin_for_db'";
                my $solution02 = "chown $oracle_user:asmadmin $oracle_bin_for_db";
                my $solution02_02 = "chmod 6751 $oracle_bin_for_db";
                notify("    solution 1: $solution01","A");
                notify("    solution 2: $solution02","A");
                notify("                $solution02_02","A");
                execute_cmd($solution01);
            }
            # grid/oracle都不在asmadmin
            # 此处要判断$F[3]的组名称，grid/oracle是否都在里面
            else {
                my $tag1 = "no";
                my $tag2 = "no";
                foreach my $group_name ( @$group_for_grid ) {
                    $tag1 = "yes" if $group_name eq $F[3];
                }
                foreach my $group_name ( @$group_for_oracle ) {
                    $tag2 = "yes" if $group_name eq $F[3];
                }
                if ( $tag1 eq "yes" and $tag2 eq "yes" ) {
                    # 虽然不是asmadmin 但是grid/oracle都在当前组里面，所以不用修改
                    notify("$oracle_bin_for_db group is $F[3]","A");
                    notify("$grid_user group is $str_group_for_grid","A");
                    notify("$oracle_user group is $str_group_for_oracle","A");
                }
                else {
                    # 没有asmadmin，要设置成oracle的第一个组
                    notify("Warning! $oracle_bin_for_db group must be $group_for_oracle->[0]","A");
                    $tag = "error";
                    my $setasmgidwrap = catfile($oracle_home_for_grid,"bin/setasmgidwrap");
                    my $solution01 = "su - $grid_user -c '$setasmgidwrap o=$oracle_bin_for_db'";
                    my $solution02 = "chown $oracle_user:$group_for_oracle->[0] $oracle_bin_for_db";
                    my $solution02_02 = "chmod 6751 $oracle_bin_for_db";
                    notify("    solution 1: $solution01","A");
                    notify("    solution 2: $solution02","A");
                    notify("                $solution02_02","A");
                    execute_cmd($solution01);
                }
            }
        }
    }

    # if ( $F[0] !~ m/\-rwsr\-s\-\-x\.?/ ) {
    if ( $F[0] !~ m/\-rwsr.s..x\.?/ ) {
        $tag = "error";
        notify("Warning! $oracle_bin_for_db permission must be -rwsr-s--x","A");
        my $solution = "chmod 6751 $oracle_bin_for_db";
        notify("    solution: $solution","A");
        execute_cmd($solution);
    }

    notify("check $oracle_bin_for_db is done","A") if $tag eq "ok";
    change_oracle_bin_permission() if $tag ne "ok";
}

