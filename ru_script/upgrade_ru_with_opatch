sub step_08_datapatch {
    my $step_name = "step_08_datapatch";
    notify("*** starting $step_name",'A');
    my $time_start = time();

    notify("grid_user     is $grid_user") if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_user   is $oracle_user");
    notify("grid_base     is $grid_base") if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_base   is $oracle_base");
    notify("oraInventory  is $oraInventory");
    notify("grid_home     is $grid_home") if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_home   is $oracle_home");

    my $oracle_home = get_oracle_home_with_echo("$oracle_user");
    my $opatch = catfile($oracle_home,"OPatch/opatch");
    my $cmd = "su - $oracle_user -c '$opatch lspatches'";
    notify("$cmd",'A');
    my $result = execute_cmd($cmd);
    my $ojvm = "no";
    foreach my $a ( @$result ) {
        notify("$a",'A');
        $ojvm = "yes" if $a =~ m/OJVM/;
    }

    # 先清理所有的记录文件
    my $db_name_list = get_db_list($oracle_home);

    foreach my $db_name_and_sid ( @$db_name_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};
        my $fork_file = catfile("/tmp","fork_for_$oracle_sid");
        notify("do unlink $fork_file");
        unlink $fork_file if -e $fork_file;

        # 清理datapatch for sid的结果标记
        # /tmp/datapatch_result_for_sid
        my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
        notify("do unlink $datapatch_result_for_sid");
        unlink $datapatch_result_for_sid if -e $datapatch_result_for_sid;

        # 清理cdb层面的util结果标记
        my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
        notify("do unlink $cdb_utlrp_result_for_sid");
        unlink $cdb_utlrp_result_for_sid if -e $cdb_utlrp_result_for_sid;

        # 清除每个PDB的命令文件和日志文件
        my $pdbs = get_pdb_list($oracle_sid,$oracle_home);
        if ( $pdbs->[0] ne "nopdb" ) {
            foreach my $pdb_name ( @$pdbs ) {
                # sql_running_sid_pdb.sql
                my $sql_running = "/tmp/" . "sql_running_" . $oracle_sid . "_" . $pdb_name . ".sql";
                notify("do unlink $sql_running");
                unlink $sql_running if -e $sql_running;
                my $sql_running_log = "/tmp/" . "sql_running_" . $oracle_sid . "_" . $pdb_name . ".log";
                notify("do unlink $sql_running_log");
                unlink $sql_running_log if -e $sql_running_log;

                # 清理pdb层面的util结果标记
                # /tmp/pdb_utlrp_result_for_pdb_name
                my $pdb_utlrp_result_for_pdb_name = "/tmp/pdb_utlrp_result_for_" . $oracle_sid . "_" . $pdb_name;
                notify("do unlink $pdb_utlrp_result_for_pdb_name");
                unlink $pdb_utlrp_result_for_pdb_name if -e $pdb_utlrp_result_for_pdb_name;
            }
        }
    }

    # 对每个DB进行 datapatch
    foreach my $db_name_and_sid ( @$db_name_list ) {
        my $db_name = $db_name_and_sid->{db_name};
        my $oracle_sid = $db_name_and_sid->{oracle_sid};

        # 如果是RAC ONE NODE，要先检查本地是否启动了实例
        my $db_type = get_srvctl_database_type($db_name,$oracle_home);
        my $srvctl_instance_status = get_local_srvctl_instance_status($db_name,$oracle_home);
        if ( $db_type eq "rac_one_node" ) {
            next if $srvctl_instance_status ne "running_at_local";
        }
        # 如果是RAC类型，有可能3个节点只允许2个节点启动某个实例，所以要跳过没有配置实例的节点
        if ( $db_type eq "rac" ) {
            my $local_node_can_start_rac_db = local_node_can_start_rac_db($db_name,$oracle_home);
            if ( $local_node_can_start_rac_db eq "no" ) {
                notify("local node can not start rac db $db_name, so skip it");
                next;
            }
        }

        # 启动本节点的实例，打开所有PDB
        start_instance($db_name_and_sid,$oracle_home);   # 这里只操作INSTANCE，有可能节点不认识sqlplus启动的实例

        # 只对主库进行datapatch 备库直接跳过
        my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
        if ( $open_mode ne "READ WRITE" ) {
            notify("Note: only READ WRITE can do datapatch, open mode for $oracle_sid is $open_mode");

            # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
            my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
            my $fd = IO::File->new("> $datapatch_result_for_sid");
            print $fd "datapatch skiped for standby db $oracle_sid\n";
            push @$datapatch_done_sid, $oracle_sid;
            $fd->close();

            next;
        }

        # 检查当前实例是否有SYS和MDSYS的无效对象，如果有，就跳过，不做datapatch，避免组件失效
        my $sys_object_status = check_invalid_object_for_sys($oracle_sid,$oracle_home);
        notify("SID $oracle_sid sys_object_status is $sys_object_status");
        next if $sys_object_status ne "ok" and defined $input->{force};     # 指定 force 参数 可以继续运行datapatch

        # 创建闪回点，如果不具备创建闪回点的条件，就跳过，不做datapatch（此操作需要使用参数 --create_restore_point_before_datapatch ）
        create_restore_point($oracle_sid,$oracle_home) if defined $input->{create_restore_point_before_datapatch};

        # select currently_used, name from  dba_feature_usage_statistics where name like '%Java%';
        # SELECT comp_id, version, status FROM dba_registry WHERE comp_id='JAVAVM';

        my $sql;
        push @$sql, "set linesize 140;";
        push @$sql, "column name format a70;";
        push @$sql, "column comp_name format a50;";
        push @$sql, "column status format a10;";
        push @$sql, "SELECT comp_id, version, status FROM dba_registry WHERE comp_id='JAVAVM';";
        push @$sql, "select currently_used, name from  dba_feature_usage_statistics where name like '%Java%';";
        do_sql_oracle($sql,$oracle_sid,$oracle_home);

        my $return = "ok";
        my @result = get_all_line($sql_log);
        foreach my $line ( @result ) {
            notify("$line");
        }
        # JServer JAVA Virtual Machine                        VALID
        # FALSE  Oracle Java Virtual Machine (user)
        # TRUE   Oracle Java Virtual Machine (system)
        if ( $result[0] =~ m/JAVAVM/ ) {      # 有JVM组件
            notify("JServer JAVA Virtual Machine is installed");
            # 再检查 Oracle Java Virtual Machine (user) 是否为 FALSE
            my $tag = "-";
            foreach my $line ( @result ) {
                if ( $line =~ m/Oracle Java Virtual Machine \(user\)/ and $line =~ /FALSE/ ) {
                    notify("JAVAVM is installed but not used, skip OJVM datapatch for $oracle_sid!");
                    $ojvm = "no";
                }
            }
        }
        else {
            notify("JServer JAVA Virtual Machine is not installed, skip OJVM datapatch for $oracle_sid!");
            $ojvm = "no";
        }

        # 此处开始放入后台 以子进程方式运行
        # 删除标志文件
        my $pid = fork();
        my $fork_file = catfile("/tmp","fork_for_$oracle_sid");
        if ( not defined $pid ) {
            notify("Error! datapatch for $oracle_sid in fork is error!");
            next;
        }
        elsif ( $pid == 0 ) {   # 子进程
            notify("    this is fork process");
            notify("11306 pid is $pid");
            notify("11297 fork_file is $fork_file");
            do_datapatch_in_fork($oracle_sid,$oracle_home,$db_name_and_sid,$pid,$fork_file) if !-e $fork_file;
            notify("*** datapatch result");
            foreach my $oracle_sid ( @$datapatch_done_sid ) {
                notify("\t sid $oracle_sid \t datapatch is done");
            }

            if ( defined $datapatch_error_sid->[0] ) {
                foreach my $oracle_sid ( @$datapatch_error_sid ) {
                    notify("\t Error! sid $oracle_sid \t datapatch has error, please check!");
                    push @$ERROR, "Error! sid $oracle_sid \t datapatch has error, please check!";
                }
            }
        }
        else {  # 父进程
            notify("11301 pid is $pid");
            next;
        }
        # do_datapatch_with_ojvm($db_name_and_sid) if $ojvm eq "yes";
        # do_datapatch_no_ojvm($db_name_and_sid) if $ojvm eq "no";
    }

    # 此处等待所有子进程完成任务
    my $kid;
    do {
        $kid = waitpid -1, 0;
    } while ($kid > 0);

    notify("11322 kid is $kid");
    if ( $kid == -1 ) {
        foreach my $db_name_and_sid ( @$db_name_list ) {
            my $db_name = $db_name_and_sid->{db_name};
            my $oracle_sid = $db_name_and_sid->{oracle_sid};

            # 跳过备库
            my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
            if ( $open_mode ne "READ WRITE" ) {
                notify("Note: only READ WRITE can do utlrp.sql, open mode for $oracle_sid is $open_mode");

                # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
                my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
                my $fd = IO::File->new("> $cdb_utlrp_result_for_sid");
                notify("@?/rdbms/admin/utlrp.sql skiped for standby cdb $oracle_sid");
                print $fd "utlrp skiped for standby cdb $oracle_sid\n";
                $fd->close();

                next;
            }

            # 重新编译无效对象
            do_utlrp_sql($oracle_sid,$oracle_home);
            my $pdbs = get_pdb_list($oracle_sid,$oracle_home);
            if ( $pdbs->[0] ne "nopdb" ) {
                foreach my $pdb_name ( @$pdbs ) {
                    # 此处对每个PDB进行并行操作 在fork里面再次进行fork
                    my $pid02 = fork();
                    if ( not defined $pid02 ) {
                        notify("Error! do_utlrp_sql_for_pdb for $oracle_sid in fork is error!");
                        next;
                    }
                    elsif ( $pid02 == 0 ) {
                        do_utlrp_sql_for_pdb($oracle_sid,$pdb_name,$oracle_home,$pid02);
                    }
                }
            }

            my $kid02;
            do {
                $kid02 = waitpid -1, 0;
            } while ($kid02 > 0);
            notify("11360 kid02 is $kid02");

            if ( $kid02 == -1 ) {
                record_invalid_object($oracle_sid,"after_datapatch");
                compare_invalid_object($oracle_sid);        # 分析比较无效对象

                # 检查cdb_registry_sqlpatch
                select_cdb_registry_sqlpatch($oracle_sid,$oracle_home);
            }
        }

        # 此处检查datapatch和utlrp操作的结果文件
        foreach my $db_name_and_sid ( @$db_name_list ) {
            my $db_name = $db_name_and_sid->{db_name};
            my $oracle_sid = $db_name_and_sid->{oracle_sid};
            my $pdbs = get_pdb_list($oracle_sid,$oracle_home);
            notify("*** step_08_datapatch result for $oracle_sid:");

            my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
            notify("datapatch_result_for_sid for $oracle_sid is: $datapatch_result_for_sid","N");
            my @result = get_all_line($datapatch_result_for_sid);
            if ( grep { /sucesfull/ } @result ) {
                notify("datapatch for $oracle_sid is ok");
            }
            elsif ( grep {/skiped for standby db/ } @result ) {
                notify("datapatch for $oracle_sid is skiped because standby");
            }
            elsif ( grep {/failed/ } @result ) {
                notify("Error! datapatch for $oracle_sid is failed!");
            }

            my $cdb_utlrp_result_for_sid = "/tmp/cdb_utlrp_result_for_" . $oracle_sid;
            notify("    cdb_utlrp_result_for_sid for $oracle_sid is: $cdb_utlrp_result_for_sid","N");
            @result = get_all_line($cdb_utlrp_result_for_sid);
            if ( grep { /sucesfull/ } @result ) {
                notify("    utlrp.sql for $oracle_sid is ok");
            }
            elsif ( grep {/skiped for standby cdb/ } @result ) {
                notify("utlrp.sql skiped for standby cdb $oracle_sid");
            }
            elsif ( grep {/failed/ } @result ) {
                notify("Error! utlrp.sql for $oracle_sid is failed!");
            }

            my $open_mode = get_open_mode_using_sqlplus($oracle_sid,$oracle_home);
            if ( $pdbs->[0] ne "nopdb" and $open_mode eq "READ WRITE" ) {
                foreach my $pdb_name ( @$pdbs ) {
                    # /tmp/pdb_utlrp_result_for_pdb_name
                    my $pdb_utlrp_result_for_pdb_name = "/tmp/pdb_utlrp_result_for_" . $oracle_sid . "_" . $pdb_name;
                    notify("    pdb_utlrp_result_for_pdb_name for $oracle_sid.$pdb_name is: $pdb_utlrp_result_for_pdb_name","N");
                    my @result = get_all_line($pdb_utlrp_result_for_pdb_name);
                    if ( grep { /sucesfull/ } @result ) {
                        notify("    utlrp.sql for $oracle_sid.$pdb_name is ok");
                    }
                    elsif ( grep {/failed/ } @result ) {
                        notify("Error! utlrp.sql for $oracle_sid.$pdb_name is failed!");
                    }
                }
            }
        }

        my $time_stop = time();
        my $time_diff_total = time_diff($time_start,$time_stop);
        notify("time: $time_diff_total seconds to task 11427 $step_name");
    }

}

