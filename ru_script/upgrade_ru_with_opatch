        ($result1,$result2) = print_cmd_log($cmd_log,$error_log);
        if ( defined $result2->[0] ) {
            notify("Error! $cmd is wrong");
            push @$ERROR, "Error! $cmd is wrong";
            exit 1;
        }

        # 更新ru.acs 恢复 process.done=nothing
        # update_config_file("nothing");

        # 启动CRS
        start_crs_for_rollback();

        # 启动TFA
        start_tfa() if $env_type eq "crs";
    }

    my $time_stop = time();
    my $time_diff_total = time_diff($time_start,$time_stop);
    notify("time: $time_diff_total seconds to task $step_name");

    print_error();
