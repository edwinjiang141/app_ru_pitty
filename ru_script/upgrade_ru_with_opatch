sub do_datapatch_no_ojvm {
    my ($db_name_and_sid,$input_oracle_home) = @_;
    my $db_name = $db_name_and_sid->{db_name};
    my $oracle_sid = $db_name_and_sid->{oracle_sid};
    my $oracle_home = $input_oracle_home ? $input_oracle_home : get_oracle_home_with_echo("$oracle_user");

    notify("*** starting do_datapatch_no_ojvm for $db_name",'A');
    my $time_start = time();

    my $status;
    for ( my $i=1; $i <= 3; $i++ ) {
        $status = do_datapatch($oracle_sid,$oracle_home);
        last if $status eq "ok";
        if ( $i == 3 ) {
            notify("Error! datapatch for $oracle_sid has error");
            push @$ERROR, "Error! datapatch for $oracle_sid has error";
            push @$datapatch_error_sid, $oracle_sid;
        }
    }

    # 写入结果文件 fork 之后变量不能传递回主进程 使用文件来传递结果
    my $datapatch_result_for_sid = "/tmp/datapatch_result_for_" . $oracle_sid;
    my $fd = IO::File->new("> $datapatch_result_for_sid");
    if ( $status eq "ok" ) {
        print $fd "datapatch sucesfull for $oracle_sid\n";
        push @$datapatch_done_sid, $oracle_sid;
    }
    elsif ( $status eq "failed" ) {
        print $fd "datapatch failed for $oracle_sid\n";
        push @$datapatch_error_sid, $oracle_sid;
    }
    $fd->close();

    # 重新启动当前节点的数据库实例
    # stop_instance($db_name_and_sid,$oracle_home);
    # start_instance($db_name_and_sid,$oracle_home);

