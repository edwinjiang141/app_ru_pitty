sub get_inventory_loc {
    # 根据操作系统读取 oraInst.loc
    my $ora_inst_loc;
    my $os_type;
    chomp ($os_type = `uname`);
    if ( lc $os_type eq "linux" ) {
        $ora_inst_loc = "/etc/oraInst.loc";
    }
    elsif ( lc $os_type eq "aix" ) {
        $ora_inst_loc = "/etc/oraInst.loc";
    }
    notify("    get_inventory_loc from $ora_inst_loc");
    my @ora_inst_loc = get_all_line($ora_inst_loc);
    # 取得  inventory_loc=/u01/app/oraInventory
    #       inst_group=oinstall
    my ($inventory_loc,$inst_group);
    foreach my $line ( @ora_inst_loc ) {
        if ( $line =~ m/inventory_loc/i ) {
            my @F = split /=/,$line;
            $inventory_loc = $F[1] if defined $F[1];
        }
        if ( $line =~ m/inst_group/i ) {
            my @F = split /=/,$line;
            $inst_group = $F[1] if defined $F[1];
        }
    }
    notify("    ora_inst_loc : $ora_inst_loc");
    notify("    inventory_loc: $inventory_loc");
    notify("    inst_group   : $inst_group");
    return($inventory_loc,$inst_group);
}

sub modify_lang_for_a_user {
    my ($username) = @_;
    notify("*** modify_lang_for_a_user for $username",'A');

    my $os_type;
    chomp ($os_type = `uname`);
    $os_type = lc $os_type;

    my $cmd = "su - $username -c 'echo \$HOME'";
    my $result = execute_cmd($cmd);
    my $home = $result->[0];
    notify("home for $username is $home",'A');

    $cmd = "su - $username -c 'echo \$SHELL'";
    $result = execute_cmd($cmd);
    my $shell = $result->[0];
    notify("shell for $username is $shell",'A');

    # 如果SHELL是bash，PROFILE是.bash_profile
    # 如果SHELL是sh，profile是.profile
    my $profile;
    if ( $shell =~ m/\/bash/ ) {
        $profile = ".bash_profile";
    }
    elsif ( $shell =~ m/\/sh/ ) {
        $profile = ".profile";
    }
    elsif ( $shell =~ m/\/ksh/ ) {
        $profile = ".profile";
    }

    my $profile_path = catfile($home,$profile);

    # 修改PROFILE 增加 LANG=C;export LANG=C
    my $tag = "na";
    my @profile = `cat $profile_path`;
    foreach my $line ( @profile ) {
        chomp($line);
        $tag = "yes" if $line =~ m/LANG=en_US.utf8; export LANG/ and $os_type eq "linux";
        $tag = "yes" if $line =~ m/LANG=C; export LANG/ and $os_type eq "aix";
    }
    if ( $tag eq "na" ) {
        # 备份PROFILE
        my $profile_backup_file_name = $profile . ".backup_before_change_LANG_to_en_US." . get_locatime_for_file();
        my $profile_backup_file_path = catfile($home,$profile_backup_file_name);
        notify("copy $profile_path to $profile_backup_file_path",'A');
        copy($profile_path,$profile_backup_file_path);
        if ( !-e $profile_backup_file_path ) {
            notify("Error!  copy $profile_path to $profile_backup_file_path is failed !",'A');
            exit 1;
        }

        # 增加一行
        # LANG=en_US.utf8;export LANG
        push @profile, "LANG=en_US.utf8; export LANG" if $os_type eq "linux";
        push @profile, "LANG=C; export LANG" if $os_type eq "linux";

        # 写入文件
        notify("rewrite $profile_path",'A');
        open myFile , "> $profile_path";
        foreach my $a ( @profile ) {
            print myFile "$a\n";
        }
        close myFile;
        notify("write $profile_path done",'A');
    }
}

sub check_environment { # grid_home oracle_home 会在这个过程中取得
    my ($before_backup) = @_;
    notify("*** check_environment",'A');
    # 检查运行环境
    $ENV{LANG} = "C";

    # 检查版本
    my $sqlplus_version = get_sqlplus_version();
    if ( $sqlplus_version !~ m/^1[2|8|9]/ ) {
        unless ( defined $input->{step_00_precheck} ) {
            notify("Error! $sqlplus_version is not supported!",'A');
            exit 1;
        }
    }

    # 脚本以root运行
    my @cmd = `id`;
    my $tmp = $cmd[0];
    $tmp =~ s/^\s+//g;
    my ($id) = $tmp =~ m/\((.*)\)\s+gid/;
    $id =~ s/^\s+|\s+$//g;
    notify("id 657 $id",'N');
    $id = substr($id,0,8);
    notify("id 659 $id",'N');
    if ( $id ne "root" ) {
        notify("Error! must running as root",'A');
        exit 1;
    }

    # DB是否运行
    # @cmd = `ps -ef|grep ora_pmon|grep -v grep|grep $oracle_user`;
    @cmd = `ps -ef|grep ora_pmon|grep -v grep`;
    if ( not defined $cmd[0] ) {
        my $msg = "not find pmon, database instance is not started";
        notify("$msg",'A');
        # push @$ERROR, $msg;
    }

    if ( $env_type eq "crs" or $env_type eq "has" ) {
        $grid_home = get_grid_home();
        if ( $grid_home eq "not_find" ) {
            notify("Error! can not find grid_home in /etc/oracle/olr.loc",'A');
            exit 1;
        }
        else {
            notify("grid_home     is $grid_home",'A');
        }
        # 取得CRS_HOME
        @cmd = `ps -ef|grep ohasd.bin|grep -v grep|grep $grid_user`;
        if ( defined $cmd[0] ) {
            my $crs_home = $cmd[0];
            $crs_home =~ s/\s+reboot.*$//;
            $crs_home =~ s/\s+restart*$//;
            $crs_home = (split /\s+/,$crs_home)[-1];
            ($crs_home) = $crs_home =~ m/(.*)\/bin\/ohasd\.bin/;
            $crs_home =~ s/^\s+|\s+$//g;
        }
        else {
            notify("Error! can not find ohasd.bin",'A');
            exit 1;
        }
    }

    # 取得ORACLE_HOME
    my $cmd = "su - $oracle_user -c 'echo \$ORACLE_HOME'";
    my $result = execute_cmd($cmd);
    if ( defined $result->[0] ) {
        $oracle_home = $result->[0];
        my $srvctl = catfile($oracle_home,"bin/srvctl");
        if ( !-e $srvctl ) {
            notify("Error! cat not find $srvctl",'A');
            exit 1;
        }
        else {
            notify("oracle_home   is $oracle_home",'A');
        }
    }
    else {
        notify("Error! can not find \$ORACLE_HOME with: su - $oracle_user -c 'echo \$ORACLE_HOME'",'A');
        exit 1;
    }

    # 检查 $oraInventory,$grid_base,$oracle_base 目录是否存在
    unless ( -e $oraInventory ) {
        notify("Error! $oraInventory not exists'",'A');
        exit 1;
    }
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        unless ( -e $grid_base ) {
            notify("Error! $grid_base not exists'",'A');
            exit 1;
        }
    }
    unless ( -e $oracle_base ) {
        notify("Error! $oracle_base not exists'",'A');
        exit 1;
    }

    notify("grid_base     is $grid_base",'A') if $env_type eq "crs" or $env_type eq "has";
    notify("oracle_base   is $oracle_base",'A');
    notify("oraInventory  is $oraInventory",'A');

    my $du_grid_home;
    if ( $env_type eq "crs" or $env_type eq "has" ) {
        chomp ($tmp = `du -sk $grid_home 2>/tmp/du_grid_home`);
        $du_grid_home = (split /\s+/,$tmp)[0];
        if ( defined $du_grid_home ) {
            $du_grid_home = int($du_grid_home/1024);
            my $format_du_grid_home = format_number($du_grid_home);
            notify("grid_home size in mb:\t\t $format_du_grid_home",'A');
        }
        else {
            notify("Error! can not get du -sk $grid_home",'A');
            exit 1;
        }
    }

    chomp ($tmp = `du -sk $oracle_home 2>/tmp/du_oracle_home`);
    my $du_oracle_home = (split /\s+/,$tmp)[0];
    if ( defined $du_oracle_home ) {
        $du_oracle_home = int($du_oracle_home/1024);
        my $format_du_oracle_home = format_number($du_oracle_home);
        notify("oracle_home size in mb:\t\t $format_du_oracle_home",'A');
    }
    else {
        notify("Error! can not get du -sk $oracle_home",'A');
        exit 1;
    }

    chomp ($tmp = `du -sk $oraInventory`);
    my $du_inventory_dir = (split /\s+/,$tmp)[0];
    if ( defined $du_inventory_dir ) {
        $du_inventory_dir = int($du_inventory_dir/1024);
        my $format_du_inventory_dir = format_number($du_inventory_dir);
        notify("oraInventory dir size in mb:\t $format_du_inventory_dir",'A');
    }
    else {
        notify("Error! can not get du -sk $oraInventory",'A');
        exit 1;
    }

    my ($backup_need_mb,$format_backup_need_mb);
    $backup_need_mb = $du_grid_home + $du_oracle_home + $du_inventory_dir if $env_type eq "crs" or $env_type eq "has";
    $backup_need_mb = $du_oracle_home + $du_inventory_dir if $env_type eq "fs";
    $format_backup_need_mb = format_number($backup_need_mb);
    notify("backup_need_mb:\t\t\t $format_backup_need_mb",'A');

    # 检查 ORACLE_BASE 空间是否足够 backup_need_mb
    my $free_space_advice = $backup_need_mb * 2;
    my ($free_space,$target_base);
    if ( $env_type eq "fs" ) {
        $target_base = $oracle_base;
    }
    else {
        $target_base = $grid_base;
    }
    $free_space = get_free_space ( $target_base );
    $free_space = int($free_space/1024);
    my $format_free_space = format_number($free_space);
    notify("free space of $target_base in mb:\t $format_free_space",'A');
    if ( $free_space >= $free_space_advice ) {
        $TAG->{grid_base_space} = "yes";
    }
    else {
        if ( defined $before_backup ) {
            my $msg = "Error! Insufficient space for $target_base, free space is: $free_space MB, GI+OH is $backup_need_mb MB, Advice: $free_space_advice MB if no backup.";
            push @$ERROR, $msg;
            notify("$msg",'A');
            $TAG->{grid_base_space} = "no";
        }
        else {  # 已经备份，减去一个备份的空间要求
            if ( $free_space <= $backup_need_mb ) {
                $TAG->{grid_base_space} = "no";
                my $msg = "Error! Insufficient space for $target_base, free space is: $free_space MB, GI+OH is $backup_need_mb MB, Advice: $backup_need_mb MB if backup is done.";
                push @$ERROR, $msg;
                notify("$msg",'A');
            }
        }
    }
}

